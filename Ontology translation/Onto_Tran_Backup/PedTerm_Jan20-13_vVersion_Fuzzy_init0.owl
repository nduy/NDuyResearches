    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hormone_Imbalance">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormal finding indicating that the level of a particular hormone is not within the expected normal values.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92809</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hormone Imbalance</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hormone_Imbalances</ace_lexicon:CN_pl>
