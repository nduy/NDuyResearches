    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Crouzon_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Crouzon_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome inherited in an autosomal dominant pattern. It is characterized by early fusion of the bones of the skull and face. Patients have a distinctive facial appearance which includes low-set ears, brachycephaly, hypertelorism, exophthalmos, and mandibular prognathism.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84653</ID>
        <NCI_PT rdf:datatype="&xsd;string">Craniofacial Dysostosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Crouzon_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Crouzon_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


