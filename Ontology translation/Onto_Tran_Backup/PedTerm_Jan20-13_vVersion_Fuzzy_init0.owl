        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A subependymal hemorrhage that involves the cerebral hemispheres and ventricles and occurs in the perinatal period.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C103187</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
