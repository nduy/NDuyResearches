</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Vesicoureteral reflux in which there is urine reflux into the ureter and renal pelvis. Moderate dilatation of the ureter and the calyces is present.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Vesicoureteric Reflux, Grade IV</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
