        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A pregnancy involving twins or higher-order multiple fetuses (e.g., triplets, quadruplets).</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87097</ID>
