        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neutral_Fetal_Attitude</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neutral_Fetal_Attitudes</ace_lexicon:CN_pl>
    </owl:Class>
    


