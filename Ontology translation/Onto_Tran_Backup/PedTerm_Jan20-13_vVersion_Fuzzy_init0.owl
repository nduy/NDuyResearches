    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Medication_Given_at_Birth -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Medication_Given_at_Birth">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Therapeutic_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C90603</ID>
