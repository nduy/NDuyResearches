        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Refers to a fetus or infant who is smaller than expected for the age or gender, or who has a birthweight less than the 10th percentile.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Low_Birth_Weights</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Low_Birth_Weight</ace_lexicon:CN_sg>
    </owl:Class>
    


