        <ace_lexicon:CN_pl>Ventricular_Arrhythmias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Fibrillation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Fibrillation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Arrhythmia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An arrhythmia characterized by rapid, usually more than 300 bpm (cycle length: 180 ms or less), grossly irregular ventricular rhythm with marked variability in QRS cycle length, morphology, and amplitude.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50799</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Ventricular Fibrillation</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Ventricular_Fibrillations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Ventricular_Fibrillation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Septal_Defect -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Septal_Defect">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiac_Septal_Defects"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C84506</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The presence of a defect (opening) in the septum that separates the two ventricles of the heart. The VSD can be congenital or acquired.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Ventricular Septal Defect</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Ventricular_Septal_Defects</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Ventricular_Septal_Defect</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Tachycardia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Tachycardia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Arrhythmia"/>
        <NCI_Definition rdf:datatype="&xsd;string">An arrhythmia characterized by 3 or more consecutive complexes in duration emanating from the ventricles at a rate of greater than 100 bpm (cycle length: less than 600 ms).</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50802</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Pediatric Non-Congenital Ventricular Tachycardia</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Ventricular Tachycardia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ventricular_Tachycardia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ventricular_Tachycardias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vernier_Caliper -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vernier_Caliper">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Measurement_Device"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A medical device that is a combination of ruler and caliper that can measure the distance between two points. The configuration of this device permits the measurement of internal dimensions.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">An instrument for measuring external or internal dimensions. It consists of an L-shaped frame with a linear scale along its longer arm and an L-shaped sliding attachment with a vernier, used to read directly the dimension of an object represented by the separation between the inner or outer edges of the two shorter arms.</NICHD_Definition>
        <ID rdf:datatype="&xsd;string">C81184</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Vernier Caliper</NCI_PT>
        <ace_lexicon:CN_sg>Vernier_Caliper</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vernier_Calipers</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vernix_Caseosa -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vernix_Caseosa">
