    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Periventricular_Leukomalacia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Periventricular_Leukomalacia">
