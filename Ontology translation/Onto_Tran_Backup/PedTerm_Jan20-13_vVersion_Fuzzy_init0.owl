        <ace_lexicon:CN_pl>Enlarged_Uteruses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Enlarged_Uterus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Epidermolysis_Bullosa -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Epidermolysis_Bullosa">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Connective_Tissue_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An autosomal recessive inherited skin disorder caused by mutations in the genes encoding keratins 5 and 14, collagen VII or laminin 5. It is characterized by skin fragility and the formation of blisters. The blisters may become large and ulcerated, resulting in skin infections and loss of body fluids.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C67383</ID>
        <NCI_PT rdf:datatype="&xsd;string">Epidermolysis Bullosa</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Epidermolysis_Bullosa</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Epidermolysis_Bullosas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Epidural_Block -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Epidural_Block">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Regional_Anesthesia_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An anesthetic procedure that involves administering pharmaceutical agents into the epidural space of the spinal canal. Frequently administered agents include local anesthetics and analgesics.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C15642</ID>
        <NCI_PT rdf:datatype="&xsd;string">Epidural Block</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Epidural_Blocks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Epidural_Block</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Epidural_Hemorrhage -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Epidural_Hemorrhage">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Intracranial_Hemorrhage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C50555</ID>
        <NCI_PT rdf:datatype="&xsd;string">Extradural Hemorrhage</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Intracranial hemorrhage into the epidural space.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Epidural_Hemorrhage</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Epidural_Hemorrhages</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Epilepsy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Epilepsy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Brain_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A brain disorder characterized by episodes of abnormally increased neuronal discharge resulting in transient episodes of sensory or motor neurological dysfunction, or psychic dysfunction. These episodes may or may not be associated with loss of consciousness or convulsions.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3020</ID>
        <NCI_PT rdf:datatype="&xsd;string">Epilepsy</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Seizure_Disorder</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Epilepsies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Epilepsy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Episiotomy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Episiotomy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Surgical_Incision"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A surgical widening of the introitus by cutting into the musculature of the maternal perineum with a linear midline or oblique incision so as to facilitate vaginal childbirth.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92774</ID>
        <NCI_PT rdf:datatype="&xsd;string">Episiotomy</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Episiotomy</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Episiotomies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Epispadias -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Epispadias">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Reproductive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality that mostly affects males. In males, it is characterized by the presence of the urethral opening in the dorsal surface of the penis. In females, this abnormality is even rarer and is characterized by the presence of an elongated urethra that has developed too far anteriorly.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98923</ID>
        <NCI_PT rdf:datatype="&xsd;string">Epispadias</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Epispadias</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Epispadiases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Escobar_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Escobar_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_Syndrome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital disorder, this is the non-lethal variant of multiple pterygium syndrome, characterized by orthopedic and craniofacial abnormalities, pterygium and akinethesia. The majority of cases are autosomal dominant.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101039</ID>
        <NCI_PT rdf:datatype="&xsd;string">Escobar Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Escobar_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Escobar_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Esophageal_Atresia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Esophageal_Atresia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality of the esophagus in which the upper esophagus ends as a blind pouch and does not connect with the lower esophagus; it is often accompanied by a tracheoesophageal fistula. Signs and symptoms in a newborn with this abnormality include excessive salivation, choking, coughing, and the development of cyanosis and respiratory distress when fed.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87072</ID>
        <SYN rdf:datatype="&xsd;string">Congenital Atresia of Esophagus</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Esophageal Atresia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Esophageal_Atresias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Esophageal_Atresia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Esophageal_Fistula -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Esophageal_Fistula">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormal communication between the esophagus and another organ or anatomic site.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C79574</ID>
        <NCI_PT rdf:datatype="&xsd;string">Esophageal Fistula</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Esophageal_Fistulas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Esophageal_Fistula</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Esophageal_Varices -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Esophageal_Varices">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Abnormally dilated vein(s) of the esophagus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C53506</ID>
        <NCI_PT rdf:datatype="&xsd;string">Esophageal Varix</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
