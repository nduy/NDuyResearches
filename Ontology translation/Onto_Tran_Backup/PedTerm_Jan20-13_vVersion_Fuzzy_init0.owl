        <ID rdf:datatype="&xsd;string">C101270</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Encephalopathy in infants due to high levels of unconjugated bilirubin that are a result of Rh incompatibility between the mother and the fetus.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Kernicterus due to Isoimmunization</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
