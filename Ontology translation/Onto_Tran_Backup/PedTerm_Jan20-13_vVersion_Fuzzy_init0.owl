        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare X-linked inherited lysosomal storage disorder characterized by deficiency of the enzyme alpha-galactosidase A. It results in the accumulation of glycolipids in the blood vessels and tissues. Signs and symptoms include hypertension, cardiomyopathy, angiokeratomas, neuropathy, hypohidrosis, keratopathy, proteinuria, and renal failure.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84701</ID>
        <NCI_PT rdf:datatype="&xsd;string">Fabry Disease</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Fabry_s_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Fabry_s_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


