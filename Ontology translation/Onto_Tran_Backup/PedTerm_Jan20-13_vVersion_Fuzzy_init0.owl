        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Abnormal flow of urine from the urinary bladder back into the ureters.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84467</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
