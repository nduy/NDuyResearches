    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mitochondrial_Trifunctional_Protein_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mitochondrial_Trifunctional_Protein_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare, autosomal recessive inherited disorder caused by mutations in the HADHA and HADHB genes. It is characterized by the deficiency of an enzyme involved in the fatty acid oxidation process. Signs and symptoms may appear early or later in life and may be triggered by periods of fasting or illnesses. They include feeding difficulties, lethargy, hypoglycemia, hypotonia, liver abnormalities, heart abnormalities, peripheral neuropathy, coma, and sudden death.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98991</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mitochondrial Trifunctional Protein Deficiency</NCI_PT>
