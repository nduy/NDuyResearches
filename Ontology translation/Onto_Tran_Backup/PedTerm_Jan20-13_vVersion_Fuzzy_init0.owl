        <ace_lexicon:CN_sg>Meningitis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Meningitises</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Meningocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Meningocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Spina_Bifida"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality of the spine in which the meninges protrude through a defect in the spinal column.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101209</ID>
        <NCI_PT rdf:datatype="&xsd;string">Meningocele</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Spinal Meningocele</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Meningoceles</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Meningocele</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Meningococcal_Conjugate_Vaccine_MCV-4 -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Meningococcal_Conjugate_Vaccine_MCV-4">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Conjugate_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A conjugate vaccine of meningococcal polysaccharide used for active immunization against invasive meningococcal disease caused by Neisseria meningiditis serogroups A, C, Y, and W-135.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96391</ID>
        <NCI_PT rdf:datatype="&xsd;string">Meningococcal Conjugate Vaccine MCV4</NCI_PT>
