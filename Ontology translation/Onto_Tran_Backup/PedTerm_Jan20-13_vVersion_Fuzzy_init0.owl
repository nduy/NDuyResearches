    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ischemic_Necrosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ischemic_Necrosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C103225</ID>
        <NCI_PT rdf:datatype="&xsd;string">Ischemic Necrosis</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Loss of vascularization and tissue death caused by the disruption in the arterial access. Common causes include trauma due to accidents, insect or reptile bites, severe cold exposure or pathological conditions such as infarctions or blood dyscrasias.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ischemic_Necrosis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ischemic_Necroses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Islet_Cell_Hyperplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Islet_Cell_Hyperplasia">
