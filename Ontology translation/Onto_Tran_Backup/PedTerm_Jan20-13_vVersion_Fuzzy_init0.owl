        <NCI_PT rdf:datatype="&xsd;string">Encephalomalacia</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Localized atrophy of the brain parenchyma due to aging, hemorrhage, infarct, or inflammation.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Encephalomalacia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Encephalomalacias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Encephalopathy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Encephalopathy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Brain_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A functional and/or structural disorder of the brain caused by diseases (e.g. liver disease, kidney disease), medications, chemicals, and injuries.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26920</ID>
        <NCI_PT rdf:datatype="&xsd;string">Encephalopathy</NCI_PT>
