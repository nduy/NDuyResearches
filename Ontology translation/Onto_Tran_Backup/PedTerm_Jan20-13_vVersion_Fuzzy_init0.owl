</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Mental_Development_Indexes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Mental_Development_Index</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mental_Retardation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mental_Retardation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Childhood_Mental_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A developmental disorder characterized by less than average intelligence and significant limitations in adaptive behavior with onset before the age of 18.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84392</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mental Retardation</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
