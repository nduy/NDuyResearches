</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Lower_Uterine_Segment_Incisions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Lower_Uterine_Segment_Incision</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lumbar_Meningocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lumbar_Meningocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Meningocele"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in the lumbar region of the spine in which the meninges protrude through a defect in the spinal column.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101211</ID>
        <NCI_PT rdf:datatype="&xsd;string">Lumbar Meningocele</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Lumbar_Meningocele</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Lumbar_Meningoceles</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lumbar_Myelocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lumbar_Myelocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Myelocele"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98976</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Herniation of spinal cord tissue and meninges through a defect in the lumbar region of the vertebral column. The protrusion of the tissue is flush with the level of the skin surface.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Lumbar Myelocele</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Lumbar_Myeloceles</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Lumbar_Myelocele</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lumbar_Myelomeningocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lumbar_Myelomeningocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Myelomeningocele"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in the lumbar region of the spine, in which the spinal cord and meninges protrude through a defect in the spinal column. The protrusion is above the skin surface.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101203</ID>
        <SYN rdf:datatype="&xsd;string">Lumbar Meningomyelocele</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Lumbar Myelomeningocele</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Lumbar_Myelomeningocele</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Lumbar_Myelomeningoceles</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lung_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lung_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_System_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic or neoplastic condition affecting the lung. Representative examples of non-neoplastic conditions include chronic obstructive pulmonary disease and pneumonia. Representative examples of neoplastic conditions include benign processes (e.g., respiratory papilloma) and malignant processes (e.g., lung carcinoma and metastatic cancer to the lung).</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3198</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Lung</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Lung Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Lung_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Lung_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lung_Overinflation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lung_Overinflation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Abnormal permanent enlargement of the lung air spaces distal to terminal bronchiole not resulted from wall destruction, e.g. due to loss of opposite lung.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50644</ID>
        <NCI_PT rdf:datatype="&xsd;string">Lung Overinflation</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Lung_Overinflation</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Lung_Overinflations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lupus_Anticoagulant_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lupus_Anticoagulant_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autoimmune_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome associated with a variety of diseases, notably systemic lupus erythematosus and other connective tissue diseases, thrombopenia, and arterial or venous thromboses, marked by the presence of antibodies directed against phospholipids.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Antiphospholipid Syndrome</NCI_PT>
        <ID rdf:datatype="&xsd;string">C61283</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Lupus_Anticoagulant_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Lupus_Anticoagulant_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lupus_Erythematosus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lupus_Erythematosus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autoimmune_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An autoimmune, connective tissue chronic inflammatory disorder affecting the skin, joints, kidneys, lungs, heart, and the peripheral blood cells. It is more commonly seen in women than men. Variants include discoid and systemic lupus erythematosus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C27153</ID>
        <NCI_PT rdf:datatype="&xsd;string">Lupus Erythematosus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Lupus_Erythematosus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Lupus_Erythematosuses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lymphangioma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lymphangioma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A benign neoplasm arising from the lymphatics. The tumor is composed of dilated lymphatic channels. Painless swelling is the usual clinical manifestation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C8965</ID>
        <NCI_PT rdf:datatype="&xsd;string">Lymphangioma</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Lymphangioma</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Lymphangiomas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lysosomal_Enzyme_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lysosomal_Enzyme_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A group of autosomal recessive or X-linked inherited metabolic disorders caused by defects in the function of the lysosomes. Signs and symptoms include hepatomegaly, splenomegaly, nervous system manifestations, skeletal abnormalities, and mental deterioration. Representative examples include Gaucher disease, Niemann-Pick disease, Wolman disease, and Fabry disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C61250</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Lysosomal Enzymes</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Lysosomal Storage Disease</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Lysosomal_Enzyme_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Lysosomal_Enzyme_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mach_mau_lon -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mach_mau_lon">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cau_truc_he_tim_mach"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any of the major arteries or veins attached to the cardiac atria or ventricles. This includes the aorta, superior and inferior vena cava and the pulmonary arteries and veins.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C102955</ID>
        <NCI_PT rdf:datatype="&xsd;string">Great Blood Vessel</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Great_Blood_Vessel</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Great_Blood_Vessels</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Macrocephaly -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Macrocephaly">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Deformity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormally large head. Causes include hydrocephalus, enlarged brain, and cranial hyperostosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35268</ID>
        <NCI_PT rdf:datatype="&xsd;string">Macrocephaly</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Macrocephaly</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Macrocephalies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Maiden_Name -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Maiden_Name">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Personal_Information"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A woman&apos;s surname before marriage.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C25381</ID>
        <NCI_PT rdf:datatype="&xsd;string">Maiden Name</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Maiden_Name</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Maiden_Names</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Malabsorption_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Malabsorption_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome resulting from the inadequate absorption of nutrients in the small intestine. Symptoms include abdominal pain, bloating, and diarrhea.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3214</ID>
        <NCI_PT rdf:datatype="&xsd;string">Malabsorption Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Malabsorption_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Malabsorption_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Malaria -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Malaria">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Parasitic_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A protozoan infection caused by the genus Plasmodium. There are four species of Plasmodium that can infect humans: Plasmodium falciparum, vivax, ovale, and malariae. It is transmitted to humans by infected mosquitoes. Signs and symptoms include paroxysmal high fever, sweating, chills, and anemia.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34797</ID>
        <NCI_PT rdf:datatype="&xsd;string">Malaria</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Malarias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Malaria</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Male -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Male">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Sex"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A person who belongs to the sex that normally produces sperm. The term is used to indicate biological sex distinctions, cultural gender role distinctions, or both.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C20197</ID>
        <NCI_PT rdf:datatype="&xsd;string">Male</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Male</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Males</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Male_Reproductive_System_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Male_Reproductive_System_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Reproductive_System_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic or neoplastic disorder that affects the male genital system. Representative examples of non-neoplastic disorders include infection, testicular torsion, and undescended testis. Representative examples of neoplastic disorders include germ cell tumors, carcinoma, lymphoma, and sarcoma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C27019</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Male Reproductive System</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Male Reproductive System Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Male_Reproductive_System_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Male_Reproductive_System_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Malignant_Fibromatous_Neoplasm -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Malignant_Fibromatous_Neoplasm">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Sarcoma"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A malignant mesenchymal tumor affecting soft tissues and bone. It is classified as adult or infantile. Infantile fibrosarcomas generally have a much more favorable prognosis than adult fibrosarcomas.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3043</ID>
        <NCI_PT rdf:datatype="&xsd;string">Fibrosarcoma</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Malignant_Fibromatous_Neoplasms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Malignant_Fibromatous_Neoplasm</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Malignant_Neoplastic_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Malignant_Neoplastic_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A tumor composed of atypical neoplastic, often pleomorphic cells that invade other tissues. Malignant neoplasms often metastasize to distant anatomic sites and may recur after excision. The most common malignant neoplasms are carcinomas (adenocarcinomas or squamous cell carcinomas), Hodgkin and non-Hodgkin lymphomas, leukemias, melanomas, and sarcomas.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C9305</ID>
        <NCI_PT rdf:datatype="&xsd;string">Malignant Neoplasm</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Malignant_Neoplastic_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Malignant_Neoplastic_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Malignant_Tumor_of_Kidney_Parenchyma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Malignant_Tumor_of_Kidney_Parenchyma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Malignant_Neoplastic_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C7548</ID>
        <NCI_PT rdf:datatype="&xsd;string">Malignant Renal Neoplasm</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Primary or metastatic malignant neoplasm involving the kidney.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Malignant_Tumor_of_Kidney_Parenchymas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Malignant_Tumor_of_Kidney_Parenchyma</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Malpresentation_of_Fetus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Malpresentation_of_Fetus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Birth_Complication"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormal position assumed by the fetus in the birth canal during the childbirth process.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92793</ID>
        <NCI_PT rdf:datatype="&xsd;string">Fetal Malpresentation</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Malpresentation_of_Fetus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Malpresentation_of_Fetuses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mannosidosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mannosidosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive lysosomal storage disease characterized by a deficient activity of the enzymes alpha-D-mannosidase or beta-mannosidase. Clincal signs and symptoms include hepatomegaly, splenomegaly, hearing loss, mental retardation, skeletal abnormalities, and recurrent respiratory infections.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C61275</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mannosidosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
