        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Stage of Labor</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The various distinct periods of the labor and childbirth process. It involves uterine contractions and cervical dilation to expel the fetus and for the baby to be born.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Stages_of_Labors</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Stages_of_Labor</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Stepping_Reflex -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Stepping_Reflex">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infant_Reflex"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An involuntary, primal response in the neonate to take brisk steps when the feet are placed on a surface whilst in a supported standing position.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81322</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Step Reflex</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Stepping_Reflexes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Stepping_Reflex</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Steroid_21-Monooxygenase_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Steroid_21-Monooxygenase_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
