        <ace_lexicon:CN_pl>Viral_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Viral_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Virus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Virus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Organism"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">An infectious agent which consists of two parts, genetic material and a protein coat. These organisms lack independent metabolism, and they must infect the cells of other types of organisms to reproduce. Most viruses are capable of passing through fine filters that retain bacteria, and are not visible through a light microscope.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C14283</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Virus</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Virus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Viruses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vision_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vision_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Sensory_Disorder"/>
        <ID rdf:datatype="&xsd;string">C35126</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vision Disorder</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Visual impairments limiting one or more of the basic functions of the eye: visual acuity, dark adaptation, color vision, or peripheral vision. These may result from eye diseases, optic nerve diseases, visual pathway diseases, occipital lobe diseases, ocular motility disorders&apos; and other conditions.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Visual_System_Disorder; Disorder of Visual System</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vision_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vision_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Visual_Cortex_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Visual_Cortex_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vision_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A vision disorder that results from damage of the part of the cerebral cortex that is involved in the processing of visual information.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35275</ID>
        <SYN rdf:datatype="&xsd;string">Cortical Visual Impairment</SYN>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Visual Cortex Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Visual_Cortex_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Visual_Cortex_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vital_Sign_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vital_Sign_Measurement">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Diagnostic_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A character or string that represents the vital signs examination.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C49672</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Vital Signs</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Vital_Sign_Measurement</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vital_Sign_Measurements</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_B6_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_B6_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_Deficiency"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C85221</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Deficiency of vitamin B6. It is usually caused by alcoholism, malabsorption, or as a side effect of medications. Signs and symptoms include stomatitis, glossitis, dermatitis, peripheral neuropathy, irritability, seizures, and anemia.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vitamin B6 Deficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Vitamin_B6_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vitamin_B6_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Nutritional_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder that is caused by the deficiency of a vitamin. The deficiency may result from either suboptimal vitamin intake or conditions that prevent the vitamin&apos;s use or absorption in the body. Representative examples include beriberi caused by thiamine deficiency, scurvy caused by vitamin C deficiency, and rickets caused by vitamin D deficiency.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35772</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vitamin Deficiency Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Vitamin_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vitamin_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_K -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_K">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C943</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The term &quot;vitamin K&quot; refers to a group of chemically similar fat-soluble compounds called naphthoquinones: vitamin K1 (phytonadione) is found in plants and is the primary source of vitamin K for humans through dietary consumption, vitamin K2 compounds (menaquinones) are made by bacteria in the human gut, and vitamin K3 (menadione) is a water-soluble preparation available for adults only. Vitamin K is necessary for the liver to produce the coagulation factors II, VII, IX, and X, as well as the clotting factors protein C, protein S, and protein Z; vitamin K deficiency can result in deficiencies of these coagulation factors and excess bleeding. An injection of vitamin K is routinely given to newborn infants to prevent vitamin K deficiency bleeding, also known as hemorrhagic disease of the newborn. Vitamin K deficiency is rare in adults but may result from chronic malnutrition or an inability to absorb dietary vitamins.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Vitamin K</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vitamin_Ks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vitamin_K</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_K_Deficiency_Coagulation_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_K_Deficiency_Coagulation_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Coagulation_Factor_Deficiency_Syndrome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99108</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Deficiency of vitamin K. It may lead to bleeding, manifested with ecchymoses, petechiae, and hematomas. In infants it may cause hemorrhagic disease of newborn with intracranial and retroperitoneal bleeding.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vitamin K Deficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vitamin_K_Deficiency_Coagulation_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vitamin_K_Deficiency_Coagulation_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vocal_Cord_Palsy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vocal_Cord_Palsy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Nervous_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C47814</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Paralysis of the muscles of one or both vocal cords. Signs and symptoms include hoarseness, weak voice, dyspnea, and coughing. Affected individuals are at risk for aspiration pneumonia.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Vocal Cord Paralysis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vocal_Cord_Palsies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vocal_Cord_Palsy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Voice_Finding -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Voice_Finding">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C61043</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Change in the sound and/or speed of the voice. Causes include laryngeal polyp, laryngitis, laryngeal carcinoma, throat carcinoma, Parkinson&apos;s disease, multiple sclerosis, stroke, hypothyroidism, oral surgery, tracheostomy, tracheal injury, and laryngeal injury.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Voice Alteration</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Voice_Finding</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Voice_Findings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vomiting -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vomiting">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3442</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The reflex act of ejecting the contents of the stomach through the mouth.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Vomiting</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vomitings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vomiting</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Von_Willebrand_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Von_Willebrand_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Coagulation_Factor_Deficiency_Syndrome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C68677</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Hereditary or acquired coagulation disorder characterized by a qualitative or quantitative deficiency of the von Willebrand factor. The latter plays an important role in platelet adhesion. Signs and symptoms include bruises, nose bleeding, gum bleeding following a dental procedure, heavy menstrual bleeding, and gastrointestinal bleeding.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">von Willebrand Disease</NCI_PT>
        <ace_lexicon:CN_pl>Von_Willebrand_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Von_Willebrand_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Waardenburg_s_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Waardenburg_s_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare, autosomal dominant inherited syndrome caused by mutations in the PAX3, MITF, and SNAI2 genes. Signs and symptoms include hearing loss, dystopia canthorum (widely spaced inner corners of the eyes), and changes in the color of the skin, hair, and eyes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85222</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Waardenburg Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Waardenburg_s_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Waardenburg_s_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Walker-Warburg_Muscular_Dystrophy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Walker-Warburg_Muscular_Dystrophy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive inherited muscular dystrophy. It presents with generalized hypotonia, muscle weakness, mental retardation, developmental delays, and brain and eye abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99109</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Walker-Warburg Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Walker-Warburg_Muscular_Dystrophy</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Walker-Warburg_Muscular_Dystrophies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Wandering_Atrial_Pacemaker -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Wandering_Atrial_Pacemaker">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Supraventricular_Arrhythmia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An electrocardiographic finding of an impulse origination site other than the sino-atrial node. Variations within P waves and PR intervals occur and an irregular rate of impulse formation is observed.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C62240</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Wandering Atrial Pacemaker</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Wandering_Atrial_Pacemakers</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Wandering_Atrial_Pacemaker</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Watery_Stool -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Watery_Stool">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <ID rdf:datatype="&xsd;string">C87128</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Frequent, loose, and watery stools are noted in most infants, even if they are fed formula, until they are six to eight weeks old; after that, the stools become firmer and less frequent.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Liquid_Stool</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Watery Stool</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Watery_Stool</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Watery_Stools</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Weak_Breathing -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Weak_Breathing">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87129</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Shallow inhalations and exhalations that indicate respiratory distress.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Weak Breathing</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Weak_Breathings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Weak_Breathing</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Weight_Gain -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Weight_Gain">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An increase in overall body mass.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C62754</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Weight Gain</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Weight_Gain</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Weight_Gains</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Werdnig-Hoffmann_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Werdnig-Hoffmann_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Spinal_Muscular_Atrophy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98670</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The most severe form of spinal muscular atrophy. It is manifested in the first year of life with muscle weakness, poor muscle tone, and lack of motor development. The motor neuron death affects the major organ systems, particularly the respiratory system. Most patients die before the age of two secondary to pneumonia.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Werdnig-Hoffmann Disease</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Werdnig-Hoffmann_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Werdnig-Hoffmann_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Wheezing -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Wheezing">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A symptom and a finding during physical examination, characterized by a high-pitched, whistling sound during breathing. It results from the narrowing or obstruction of the respiratory airways. The most common causes of wheezing are asthma, chronic obstructive pulmonary disease, tracheobronchitis, and pulmonary edema.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C78718</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Wheezing</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Wheezing</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Wheezings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Williams_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Williams_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare syndrome caused by multiple gene deletions from a region of chromosome 7, including the deletion of CLIP2, ELN, GTF2I, GTF2IRD1 and LIMK1 genes. It is characterized by distinctive facial appearance (elfin facies), mild-to-moderate mental retardation, cheerfulness, cardiovascular abnormalities and infantile hypercalcemia.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85232</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Williams Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Williams_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Williams_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Withdrawal_Contraception -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Withdrawal_Contraception">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraception"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A birth control method adopted during sexual intercourse by withdrawing the penis from the vagina before ejaculation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92919</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Withdrawal Contraception</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Withdrawal_Contraception</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Withdrawal_Contraceptions</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Wolff-Parkinson-White_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Wolff-Parkinson-White_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiac_Conduction_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital electrical function abnormality in the heart. It is characterized by the presence of an accessory conductive pathway between the atria and the ventricles which causes the activation of the ventricles earlier than anticipated. Characteristic electrocardiographic findings are a short PR interval and a wide QRS complex with a delta wave.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35132</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Wolff-Parkinson-White Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Wolff-Parkinson-White_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Wolff-Parkinson-White_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Wolman_s_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Wolman_s_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A very rare, autosomal recessive inherited lysosomal storage disease caused by mutations in the LIPA gene. Signs and symptoms appear in infancy and include developmental delay, vomiting, abdominal distention, hepatosplenomegaly, jaundice, anemia, steatorrhea, and calcification of the adrenal glands.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C61271</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Wolman Disease</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Wolman_s_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Wolman_s_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Yawning -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Yawning">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An involuntary deep inhalation with the mouth open, often a sign of drowsiness or boredom.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87131</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Yawning</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Yawnings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Yawning</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Yellow_Fever_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Yellow_Fever_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A live, attenuated viral vaccine to prevent yellow fever, endemic to parts of Africa and South America.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96396</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Yellow Fever Vaccine</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Yellow_Fever_Vaccine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Yellow_Fever_Vaccines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Yellow_Fever_Virus_Infection -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Yellow_Fever_Virus_Infection">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Viral_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A viral infection caused by a flavivirus called yellow fever virus. It is transmitted to humans from infected mosquitoes. The signs and symptoms range from a mild febrile illness to liver damage with jaundice and hemorrhages.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35547</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Yellow Fever Virus Infection</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Yellow_Fever_Virus_Infections</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Yellow_Fever_Virus_Infection</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Yes -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Yes">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Indicator"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C49488</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The affirmative response to a question.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Yes</NCI_PT>
