        <ace_lexicon:CN_pl>Postpartum_Processes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Postpartum_Process</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pound -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pound">
