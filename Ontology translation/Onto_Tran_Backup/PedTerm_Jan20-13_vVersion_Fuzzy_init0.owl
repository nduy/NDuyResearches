        <NCI_Definition rdf:datatype="&xsd;string">A non-sustained irregular fetal heart rate in comparison to normal baseline values.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92879</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Short-Term Fetal Heart Rate Variability</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Short_Term_Variability</SYN>
