        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An uncommon congenital abnormality characterized by either lethal complete absence of the lungs or varying degrees of underdevelopment of the lung parenchyma. It may be associated with other congenital abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99028</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
