        <ID rdf:datatype="&xsd;string">C99070</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Deficiency of surfactant protein ABCA3. It leads to respiratory distress that is often fatal.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Surfactant Protein ABCA3 Deficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
