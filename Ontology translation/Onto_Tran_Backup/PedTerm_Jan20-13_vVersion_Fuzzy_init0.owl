        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Square Window</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">When testing the newborn infant for neuromuscular maturity, the &quot;square window&quot; test measures wrist flexibility and resistance to extensor stretching, The examiner straightens the infant&apos;s fingers and applies gentle pressure on the dorsum of the hand, close to the fingers, and then estimates the angle between the palm of the hand and the forearm.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Square_Windows</ace_lexicon:CN_pl>
