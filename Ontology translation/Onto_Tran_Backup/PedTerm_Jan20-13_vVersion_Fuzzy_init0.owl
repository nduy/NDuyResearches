        <ace_lexicon:CN_pl>Varicella_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Varicella_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vasa_Previa -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vasa_Previa">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Birth_Complication"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A serious condition in which blood vessels of the umbilical cord or the placenta cross the entrance to the birth canal, beneath the fetus; this can lead to rapid fetal blood loss during labor and delivery if the blood vessels tear as the cervix dilates and the membranes rupture.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87127</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vasa Previa</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Vasa_Previa</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vasa_Previas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vascular_Ring_of_Aorta -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vascular_Ring_of_Aorta">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Great_Vessel_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An unusual congenital abnormality in which the aorta or aortic branches encircle the trachea and esophagus. Signs and symptoms include difficulty swallowing and eating, persistent cough, noisy breathing, and acid reflex.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99106</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vascular Ring</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Vascular_Ring_of_Aorta</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vascular_Ring_of_Aortas</ace_lexicon:CN_pl>
    </owl:Class>
    


