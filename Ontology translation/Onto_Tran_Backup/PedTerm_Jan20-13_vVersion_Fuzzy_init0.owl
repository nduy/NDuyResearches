        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87096</ID>
        <NCI_Definition rdf:datatype="&xsd;string">During examination of the newborn infant, the examiner looks for symmetric movement of the lip corners. Movement of the lip corners is governed by the zygomatic major muscle.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Movement of Lip Corners</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
