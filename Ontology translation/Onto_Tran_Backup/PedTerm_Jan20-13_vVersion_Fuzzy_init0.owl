        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An infant born after completion of the normal gestational period.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C89333</ID>
        <NCI_PT rdf:datatype="&xsd;string">Full Term Neonate</NCI_PT>
