        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A method of achieving contraception with the aid of a surgical procedure that prevents fertilization of an egg by a sperm.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92892</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
