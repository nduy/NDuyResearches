        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The result of observation and overall assessment of a subject&apos;s outward aspect including appearance and movements; for example, in a human newborn general appearance includes skin color and tone, range of motion, and spontaneous movements.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>General_Appearances</ace_lexicon:CN_pl>
