        <NICHD_Definition rdf:datatype="&xsd;string">A contraceptive device, which is shaped like a coil, and is inserted into the uterus to prevent pregnancy.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A medical device that is inserted into the uterus to prevent pregnancy.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92758</ID>
