    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Surfactant_Apoprotein_B_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Surfactant_Apoprotein_B_Deficiency">
