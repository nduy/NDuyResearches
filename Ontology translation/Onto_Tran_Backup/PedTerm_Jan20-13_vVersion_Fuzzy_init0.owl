</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pregnancy Breast Soreness</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The tenderness of the breasts during pregnancy due to changes in the hormonal levels and increased breast tissue growth.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Breast_Soreness</ace_lexicon:CN_sg>
