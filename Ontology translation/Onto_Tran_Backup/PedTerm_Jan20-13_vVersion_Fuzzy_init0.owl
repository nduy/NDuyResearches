        <NCI_Definition rdf:datatype="&xsd;string">An association of congenital birth defects that includes vertebral abnormalities, anal atresia, cardiac abnormalities, tracheo-esophageal fistula, renal abnormalities, and limb abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99105</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
