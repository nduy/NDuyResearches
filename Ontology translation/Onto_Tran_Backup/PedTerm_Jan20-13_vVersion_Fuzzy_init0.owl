        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An emergency cesarean section that is carried out urgently in cases of fetal distress or severe maternal complication that is life threatening to either or both of them.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92762</ID>
        <NCI_PT rdf:datatype="&xsd;string">Crash Caesarean Section</NCI_PT>
