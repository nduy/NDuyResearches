    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Prader-Willi_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Prader-Willi_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A genetic syndrome caused by deletions or disruptions of chromosome 15. It is characterized by reduced fetal activity, mental retardation, hypotonia, short stature, and hypogonadism.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75463</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Prader-Willi Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Prader-Willi_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Prader-Willi_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


