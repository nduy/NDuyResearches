</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Smoking History</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Smoking_Histories</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Smoking_History</ace_lexicon:CN_sg>
    </owl:Class>
    


