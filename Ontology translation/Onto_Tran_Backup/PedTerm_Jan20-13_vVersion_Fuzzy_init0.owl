        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Bleeding from the lung parenchyma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C78578</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Hemorrhage</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pulmonary_Hemorrhages</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pulmonary_Hemorrhage</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Hypertension -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Hypertension">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertensive_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3120</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Increased pressure within the pulmonary circulation due to lung or heart disorder.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Hypertension</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pulmonary_Hypertension</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pulmonary_Hypertensions</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Trunk_Hypoplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Trunk_Hypoplasia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_Lung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C103226</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Trunk Hypoplasia</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Underdeveloped pulmonary arteries.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pulmonary_Trunk_Hypoplasia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pulmonary_Trunk_Hypoplasias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Valve_Atresia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Valve_Atresia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart defect characterized by complete atresia of the pulmonary valve. It is manifested during infancy with cyanosis, dyspnea, and tachypnea.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99031</ID>
        <SYN rdf:datatype="&xsd;string">Congenital Atresia of the Pulmonary Valve; Pulmonary Atresia</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Valve Atresia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pulmonary_Valve_Atresias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pulmonary_Valve_Atresia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Vein_Stenosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonary_Vein_Stenosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Venous_Stenosis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99036</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Obstruction of the pulmonary vein in one or multiple sites. The obstruction is the result of wall thickening and narrowing of the lumen of the vein.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Vein Stenosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pulmonary_Vein_Stenosis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pulmonary_Vein_Stenoses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonic_Valve_Stenosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pulmonic_Valve_Stenosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Valve_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C50715</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Narrowing of the opening between the pulmonary artery and the right ventricle, usually at the level of the valve leaflets.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Stenosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pulmonic_Valve_Stenosis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pulmonic_Valve_Stenoses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pulse_Oximetry -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pulse_Oximetry">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Oxygen_Saturation_Measurement"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A non-invasive method that provides estimates of arterial oxyhemoglobin saturation by utilizing selected wavelengths of light to determine the saturation of oxyhemoglobin.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C38085</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulse Oximetry</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pulse_Oximetry</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pulse_Oximetries</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pulse_Rate -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pulse_Rate">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Numeric_Value"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C49676</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulse Rate</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The rate of the pulse as observed in an artery, expressed as beats per minute. It can be measured at several anatomical sites, including the wrist, neck, temple, groin, behind the knees, or on top of the foot.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pulse_Rate</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pulse_Rates</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pupil_Reactions_Normal -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pupil_Reactions_Normal">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Clinical_Test_Result"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A finding indicating the quick and brisk constriction of the pupils in response to light.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99136</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Normal Pupillary Response</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pupil_Reactions_Normals</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pupil_Reactions_Normal</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pupils_Equal_Round_and_Reactive_to_Light_Result -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pupils_Equal_Round_and_Reactive_to_Light_Result">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Clinical_Test_Result"/>
        <ID rdf:datatype="&xsd;string">C87107</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Pupil_Equal_Round_and_Reacting_to_Light</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Pupils Equal Round and Reactive to Light Result</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">While performing an assessment of the eyes, the examiner notes whether the pupils are equal, round, and reactive to light. If all findings are normal, the abbreviation PERRL is noted in the examiner&apos;s account of the physical examination.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pupils_Equal_Round_and_Reactive_to_Light_Result</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pupils_Equal_Round_and_Reactive_to_Light_Results</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pupils_Equal_Round_and_Reactive_to_Light_and_Accommodation_Result -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pupils_Equal_Round_and_Reactive_to_Light_and_Accommodation_Result">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Clinical_Test_Result"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87108</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Pupils Equal Round and Reactive to Light and Accommodation Result</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">While performing an assessment of the eyes, the examiner notes whether the pupils are equal and round, reactive to light, and have the ability to accommodate. If all findings are normal, the abbreviation PERRLA is noted in the examiner&apos;s account of the physical examination.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pupils_Equal_Round_and_Reactive_to_Light_and_Accommodation_Result</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pupils_Equal_Round_and_Reactive_to_Light_and_Accommodation_Results</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pyelonephritis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pyelonephritis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Bacterial_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An acute or chronic inflammatory process affecting the kidney. It is caused by bacteria and in most cases it is the result of a urinary tract infection. Signs and symptoms include fever, chills, flank pain, painful and frequent urination, cloudy or bloody urine, and confusion.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34965</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pyelonephritis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pyelonephritis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pyelonephritises</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pyloric_Stenosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pyloric_Stenosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C34966</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Narrowing of the pyloric lumen caused either by hypertrophy of the surrounding muscles or tissue scarring due to a chronic peptic ulcer.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pyloric Stenosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pyloric_Stenoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pyloric_Stenosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pyruvate_Carboxylase_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pyruvate_Carboxylase_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive inherited metabolic disorder caused by mutations in the PC gene. It results in the accumulation of lactic acid and other toxic substances in the blood. Signs and symptoms appear early in life and include failure to thrive, mental and growth retardation, motor disturbances, seizures, and lactic acidosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85040</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pyruvate Carboxylase Deficiency</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Pyruvate Metabolism and Mitochondrial Respiratory Chain Disorder</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pyruvate_Carboxylase_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pyruvate_Carboxylase_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Quad_Screen -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Quad_Screen">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Screening_for_Genetic_Defect"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A screening measurement in which the maternal blood levels of alpha-fetoprotein, unconjugated estriol, human chorionic gonadotrophin and Inhibin A are calculated. These are then evaluated in relation to the mother&apos;s age, weight and fetal gestational age.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92865</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Quad Screen</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Quad_Screens</ace_lexicon:CN_pl>
