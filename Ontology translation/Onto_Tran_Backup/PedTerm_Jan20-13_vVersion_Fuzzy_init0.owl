        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital disorder characterized by blockage or absence of the intrahepatic or extrahepatic bile ducts.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Biliary Atresia</NCI_PT>
        <ID rdf:datatype="&xsd;string">C34421</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
