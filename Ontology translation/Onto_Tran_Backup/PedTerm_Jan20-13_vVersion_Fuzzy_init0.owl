        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An interruption or alteration in the sensory activity or functions of the nervous system.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C63711</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
