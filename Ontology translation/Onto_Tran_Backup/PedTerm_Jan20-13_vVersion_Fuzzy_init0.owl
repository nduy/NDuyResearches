    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Phobia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Phobia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anxiety_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An anxiety disorder characterized by an intense, irrational fear cued by the presence or anticipation of a specific object or situation. Exposure to the phobic stimulus immediately provokes an anxiety response. In adults, the specific phobia is recognized as excessive or unreasonable.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35284</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
