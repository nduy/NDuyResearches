        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A pathologic process that affects the skin and is confined to a specific area.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C39688</ID>
        <NCI_PT rdf:datatype="&xsd;string">Localized Skin Lesion</NCI_PT>
