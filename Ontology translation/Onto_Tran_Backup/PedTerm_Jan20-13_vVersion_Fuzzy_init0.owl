    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Larynx -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Larynx">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Respiratory_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98972</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Congenital atresia of the larynx. It is fatal unless tracheostomy is performed immediately after birth.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">Laryngeal atresia is a congenital failure of the laryngeal opening to develop, resulting in partial or total obstruction at or just above or below the glottis.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Larynx Atresia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_sg>Congenital_Atresia_of_Larynx</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Atresia_of_Larynxes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Mitral_Valve -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Mitral_Valve">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A cogenital defect where the valve (mitral) which connects the two chambers on the left side of the heart (atrium and ventricle)  is closed off. The blood is therefore unable to flow between the two heart chambers.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart defect characterized by the complete atresia of the mitral valve.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98992</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mitral Valve Atresia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Congenital_Atresia_of_Mitral_Valves</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Atresia_of_Mitral_Valve</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Trachea -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Trachea">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Respiratory_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare, fatal congenital malformation in which the trachea is severely underdeveloped.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35754</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Tracheal Atresia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Atresia_of_Tracheas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Atresia_of_Trachea</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Tricuspid_Valve -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Tricuspid_Valve">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart defect characterized by the complete lack of formation of the tricuspid valve. Cyanosis is the predominant clinical symptom.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85202</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Tricuspid Atresia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Atresia_of_Tricuspid_Valves</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Atresia_of_Tricuspid_Valve</ace_lexicon:CN_sg>
    </owl:Class>
    


