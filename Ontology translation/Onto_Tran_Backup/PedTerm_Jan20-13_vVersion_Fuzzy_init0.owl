        <ID rdf:datatype="&xsd;string">C3671</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Damage inflicted on the body as the direct or indirect result of an external force, with or without disruption of structural continuity.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Injury</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
