        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A benign tumor-like nodule composed of an overgrowth of mature cells and tissues which is present at birth.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A hamartomatous lesion which is present at birth.</NCI_Definition>
