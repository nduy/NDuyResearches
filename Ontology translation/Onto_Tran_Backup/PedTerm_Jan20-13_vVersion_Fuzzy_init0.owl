    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Increased_Muscle_Tone -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Increased_Muscle_Tone">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C79750</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Increased involuntary muscle tone caused by central nervous system disorders that affect the regions interfering with voluntary movement. It results in gait, movement, and speech disturbances. Representative examples of disorders causing spasticity include brain or spinal cord injury, and multiple sclerosis.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Spasticity</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Increased_Muscle_Tones</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Increased_Muscle_Tone</ace_lexicon:CN_sg>
    </owl:Class>
    


