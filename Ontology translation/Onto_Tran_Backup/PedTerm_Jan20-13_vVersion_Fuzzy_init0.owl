        <ace_lexicon:CN_pl>Dextro-Transposition_of_the_Great_Vesselses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels_with_Intact_Ventricular_Septum -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels_with_Intact_Ventricular_Septum">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart defect in which there is an abnormal arrangement of any of the primary blood vessels of the heart in conjunction with the notable absence of any pathologic opening between the cardiac ventricles.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101185</ID>
        <SYN rdf:datatype="&xsd;string">D-Transposition of the Great Vessels with Intact Ventricular Septum</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Dextro-Transposition of the Great Vessels with Intact Ventricular Septum</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Dextro-Transposition_of_the_Great_Vessels_with_Intact_Ventricular_Septum</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Dextro-Transposition_of_the_Great_Vessels_with_Intact_Ventricular_Septums</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels_with_Ventricular_Septal_Defect -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels_with_Ventricular_Septal_Defect">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart defect in which there is an abnormal arrangement of any of the primary blood vessels of the heart in conjunction with a pathologic opening between the cardiac ventricles.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101186</ID>
        <SYN rdf:datatype="&xsd;string">D-Transposition of the Great Vessels with Ventricular Septal Defect</SYN>
