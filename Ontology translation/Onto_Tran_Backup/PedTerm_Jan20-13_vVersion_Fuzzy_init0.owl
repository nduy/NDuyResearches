        <ace_lexicon:CN_sg>Fetal_Valproate_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Fetal_Valproate_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Warfarin_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Warfarin_Syndrome">
