        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C35435</ID>
        <NCI_PT rdf:datatype="&xsd;string">Enlarging Abdomen</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Increasing girth of the mid section of an individual.</NCI_Definition>
