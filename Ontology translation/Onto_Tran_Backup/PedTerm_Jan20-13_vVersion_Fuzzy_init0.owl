    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Device">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Device"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A device designed to prevent conception through local or systemic effect, such as a barrier contraceptive, an intrauterine device, or a means of preventing ovulation (e.g., birth control pill).</NCI_Definition>
