        <NCI_PT rdf:datatype="&xsd;string">Patent Urachus</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Patent_Urachus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Patent_Urachuses</ace_lexicon:CN_pl>
    </owl:Class>
    


