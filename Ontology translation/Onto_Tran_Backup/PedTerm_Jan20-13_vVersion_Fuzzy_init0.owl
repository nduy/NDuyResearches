    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sturge-Weber_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sturge-Weber_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital disorder characterized by the presence of a port-wine nevus birthmark on one or both sides of the face. Additional clinical manifestations may include seizures, leptomenigeal angiomas, glaucoma, progressive hemiparesis and cognitive deficits.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3391</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sturge-Weber Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Sturge-Weber_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Sturge-Weber_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


