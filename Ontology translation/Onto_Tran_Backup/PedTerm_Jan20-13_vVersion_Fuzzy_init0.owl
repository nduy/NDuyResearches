</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Syndrome_of_Inappropriate_Vasopressin_Secretions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Syndrome_of_Inappropriate_Vasopressin_Secretion</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Syndrome_of_Infant_of_Diabetic_Mother -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Syndrome_of_Infant_of_Diabetic_Mother">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">An infant that was born to a mother who persistently had high glucose blood levels during pregnancy. The infants of diabetic mothers are large for their gestational age and may develop hypoglycemic episodes soon after birth.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98955</ID>
        <SYN rdf:datatype="&xsd;string">IDM</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Infant of Diabetic Mother</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Syndrome_of_Infant_of_Diabetic_Mother</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Syndrome_of_Infant_of_Diabetic_Mothers</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Systemic_Arterial_Hypertensive_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Systemic_Arterial_Hypertensive_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertensive_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">Any condition resulting in systemically elevated blood pressure that is attributed to an arterial source.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C102954</ID>
        <SYN rdf:datatype="&xsd;string">Hypertensive Disorder, Systemic Arterial</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Systemic Arterial Hypertensive Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Systemic_Arterial_Hypertensive_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Systemic_Arterial_Hypertensive_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Systemic_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Systemic_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">A clinical course finding indicating that a disease presents with systemic manifestations.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">A disorder that affects in multiple tissue types or in multiple organ systemsis, or affects the body as a whole.</NICHD_Definition>
        <ID rdf:datatype="&xsd;string">C9229</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
