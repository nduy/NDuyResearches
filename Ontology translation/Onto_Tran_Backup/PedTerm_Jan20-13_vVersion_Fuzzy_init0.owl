    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Grasp_Reflex -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Grasp_Reflex">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infant_Reflex"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An involuntary, primal response in the neonate to grasp the fingers when their palm is touched. This reflex is present until six months of age.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81254</ID>
        <NCI_PT rdf:datatype="&xsd;string">Grasp Reflex</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Grasp_Reflex</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Grasp_Reflexes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Great_Vessel_Abnormality -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Great_Vessel_Abnormality">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Circulatory_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital vascular abnormality that affects the great vessels and/or aortic arch. Representative examples include double aortic arch, aortic coarctation, and absence of a pulmonary artery.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99137</ID>
        <NCI_PT rdf:datatype="&xsd;string">Great Vessels Abnormality</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Great_Vessel_Abnormality</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Great_Vessel_Abnormalities</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Group_B_Streptococcal_Infection -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Group_B_Streptococcal_Infection">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Bacterial_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87168</ID>
        <NCI_PT rdf:datatype="&xsd;string">Group B Streptococcal Infection</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Group B Streptococcus, also known as Streptococcus agalactiae, colonizes the vaginal and gastrointestinal tracts of up to 45% of healthy women and may infect neonates in utero or during delivery, causing neonatal sepsis in 1-2% of colonized neonates. GBS infection may also occur in nonpregnant (particularly elderly) adults with underlying medical conditions, presenting as urinary tract infection, pneumonia, or soft-tissue infection.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Group_B_Streptococcal_Infections</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Group_B_Streptococcal_Infection</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Group_B_Streptococcus_Screening -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Group_B_Streptococcus_Screening">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Screening_or_Clinical_Tests_during_Pregnancy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92805</ID>
        <NCI_PT rdf:datatype="&xsd;string">Group B Streptococcus Screening</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Screening with a swab from the vaginal and rectal areas in late pregnancy to test for the presence of Group B streptococcal infection.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Group_B_Streptococcus_Screening</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Group_B_Streptococcus_Screenings</ace_lexicon:CN_pl>
    </owl:Class>
    


