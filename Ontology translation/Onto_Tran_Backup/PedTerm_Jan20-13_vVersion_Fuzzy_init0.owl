        <ace_lexicon:CN_pl>Dextro-Transposition_of_the_Great_Vessels_with_Ventricular_Septal_Defects</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dextrocardia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextrocardia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality in which the heart is located in the right side of the chest. It is associated with other congenital heart defects.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84669</ID>
        <NCI_PT rdf:datatype="&xsd;string">Dextrocardia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Dextrocardia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Dextrocardias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dextrocardia_Normal_Situs -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextrocardia_Normal_Situs">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextrocardia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart defect in which the heart is located in the right side and the other organs are in their normal position.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101032</ID>
        <NCI_PT rdf:datatype="&xsd;string">Dextrocardia Situs Solitus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Dextrocardia_Normal_Situses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Dextrocardia_Normal_Situs</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#DiGeorge_Sequence -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#DiGeorge_Sequence">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital anomaly characterized by immunodeficiency, abnormal facies, congenital heart disease, hypocalcemia, and increased susceptibility to infections. Pathologic characteristics include conotruncal abnormalities and absence or hypoplasia of thymus and parathyroid glands. DiGeorge syndrome is associated with abnormalities of chromosome 22. Also known as DiGeorge anomaly.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2989</ID>
        <NCI_PT rdf:datatype="&xsd;string">DiGeorge Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>DiGeorge_Sequence</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>DiGeorge_Sequences</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Diabetes_Insipidus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Diabetes_Insipidus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder characterized by excretion of large amounts of urine, accompanied by excessive thirst. Causes include deficiency of antidiuretic hormone or failure of the kidneys to respond to antidiuretic hormone. It may also be drug-related.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C43263</ID>
        <NCI_PT rdf:datatype="&xsd;string">Diabetes Insipidus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Diabetes_Insipidus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Diabetes_Insipiduses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Diagnosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Diagnosis">
