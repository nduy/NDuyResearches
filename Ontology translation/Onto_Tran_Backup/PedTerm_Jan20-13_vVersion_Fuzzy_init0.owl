    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Late_Adolescence -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Late_Adolescence">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Adolescence"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage that begins at nineteen years of age and continues until twenty-one complete years of age. This phase includes the final stages of pubertal growth and development as well as the attainment of significant psycho-social milestones.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A transitional time in an individual&apos;s life between adolescence and early adulthood. This phase includes the final stages of pubertal growth and development as well as the attainment of significant psycho-social milestones.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C89344</ID>
        <NCI_PT rdf:datatype="&xsd;string">Late Adolescence</NCI_PT>
