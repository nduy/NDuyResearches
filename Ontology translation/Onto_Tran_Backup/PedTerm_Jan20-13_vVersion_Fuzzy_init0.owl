    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Delivery_of_Placenta -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Delivery_of_Placenta">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Postpartum_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92766</ID>
        <NCI_PT rdf:datatype="&xsd;string">Delivery of Placenta</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The natural process whereby the placenta detaches from the uterus. It occurs during the third stage of childbirth and shortly after delivery of the fetus.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Delivery_of_Placenta</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Delivery_of_Placentas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Demographics -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Demographics">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Property_or_Attribute"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C16495</ID>
        <NCI_PT rdf:datatype="&xsd;string">Demographics</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The statistical characterization of human populations or segments of human populations (e.g., characterization by age, sex, race, or income).</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Demographicses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Demographics</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Demyelinating_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Demyelinating_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Nervous_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A broad group of disorders that affect the myelin sheaths that cover the neurons. Myelin sheathes cover neuronal axons in the central and peripheral nervous system and function to increase travelling impulse speeds. Disruption of this sheath impairs neuronal transmission and can result in disorders such as multiple sclerosis and Guillain-Barre syndrome, among others.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34527</ID>
        <NCI_PT rdf:datatype="&xsd;string">Demyelinating Disorder</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Demyelinating_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Demyelinating_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Denver_Development_Screening_Test -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Denver_Development_Screening_Test">
