        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Prenatal</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The time period after impregnation and before birth.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Prenatals</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Prenatal</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Prenatal_Stage -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Prenatal_Stage">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Maternal_Life_Stage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <ID rdf:datatype="&xsd;string">C90339</ID>
