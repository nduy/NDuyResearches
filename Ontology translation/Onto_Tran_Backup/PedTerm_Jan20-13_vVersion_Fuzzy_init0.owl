    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Trimester -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Trimester">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Time_Period"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A period of three months; especially one of the three three-month periods into which human pregnancy is divided.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C69121</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
