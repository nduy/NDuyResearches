        <NCI_Definition rdf:datatype="&xsd;string">A cyanotic congenital cardiovascular abnormality characterized by the transposition of the aorta and the pulmonary artery.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99096</ID>
        <SYN rdf:datatype="&xsd;string">D-Transposition of the Great Vessels</SYN>
