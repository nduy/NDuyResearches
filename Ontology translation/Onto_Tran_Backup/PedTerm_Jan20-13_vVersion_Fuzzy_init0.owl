        <ID rdf:datatype="&xsd;string">C103188</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Damage to the phrenic nerve that was not present at birth.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Phrenic Nerve Injury, Acquired</SYN>
