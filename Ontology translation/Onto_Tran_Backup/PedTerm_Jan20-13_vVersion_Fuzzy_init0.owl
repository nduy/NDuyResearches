        <NCI_PT rdf:datatype="&xsd;string">Sinciput Presentation</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Sinciput</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Sinciputs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Single_Palmar_Crease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Single_Palmar_Crease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <NCI_Definition rdf:datatype="&xsd;string">A single transverse palmar crease is found in 5% of newborns and is frequently inherited as a familial trait. However, single palmar creases can be associated with Down&apos;s syndrome and other genetic disorders, or with fetal alcohol syndrome.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87120</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Single Palmar Crease</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Single_Transverse_Palmar_Crease</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Single_Palmar_Creases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Single_Palmar_Crease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Single_Ventricle -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Single_Ventricle">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A diverse group of congenital cardiovascular abnormalities that share one characteristic, the presence of a single functional cardiac ventricle.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99060</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Single Ventricle Defect</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Single_Ventricle</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Single_Ventricles</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sinus_Infection -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sinus_Infection">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infectious_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An acute or chronic infectious process affecting the mucous membranes of the paranasal sinuses.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35024</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sinusitis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Sinus_Infection</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Sinus_Infections</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Situs_Inversus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Situs_Inversus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Systemic_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital condition in which there is complete right-to-left reversal of the position of the major thoracic and abdominal organs (that is, they are arranged in a mirror image of the normal positioning).</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87121</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Situs Ambiguus; Situs Inversus Viscerum</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Situs Inversus</NCI_PT>
