    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nanogram_per_Deciliter -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nanogram_per_Deciliter">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Unit_of_Measure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A unit of mass concentration defined as the concentration of one nanogram of a substance per unit volume of the mixture equal to one deciliter. The concept also refers to the unit of mass density (volumic mass) defined as the density of substance which mass equal to one nanogram occupies the volume of one deciliter.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C67326</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Nanogram per Deciliter</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Nanogram_per_Deciliter</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Nanogram_per_Deciliters</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nasal_Congestion -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nasal_Congestion">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C78500</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Nasal Congestion</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The blockage of the nasal passage due to mucosal edema. It is usually the result of a viral infection or an allergic reaction.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Nasal_Congestions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Nasal_Congestion</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nasal_Flaring -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nasal_Flaring">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87099</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Enlargement of the nostrils during breathing; although there are many possible causes, it can be a sign of respiratory distress in young infants.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Nasal Flaring</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Nasal_Flarings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Nasal_Flaring</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nasal_Route_of_Administration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nasal_Route_of_Administration">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Route_of_Administration"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Administration of a drug by the way of the nose. This often results in systemic action of the agent due to absorption through the nasal mucosa. The richly supplied vascular nature of the nasal mucosa coupled with its high drug permeation makes the nasal route of administration attractive for many drugs, including proteins and peptides.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C38284</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Nasal Route of Administration</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Nasal_Route_of_Administration</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Nasal_Route_of_Administrations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Natural_Birth -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Natural_Birth">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Outcome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92932</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Natural Birth</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The process of giving birth vaginally without any surgical intervention.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Natural_Births</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Natural_Birth</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Necrotizing_Enterocolitis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Necrotizing_Enterocolitis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <NCI_Definition rdf:datatype="&xsd;string">A serious, life-threatening disorder characterized by necrotic changes affecting portions of the small and large intestine. It is usually seen in neonates, particularly premature infants. Signs and symptoms include abdominal distention and tenderness, intestinal bleeding and ileus. It may lead to cardiovascular collapse and shock.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84915</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Necrotizing Enterocolitis</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Necrotizing_Enterocolitis_In_Fetus_Or_Newborn</SYN>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Necrotizing_Enterocolitis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Necrotizing_Enterocolitises</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Negative_Pregnancy_Test -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Negative_Pregnancy_Test">
