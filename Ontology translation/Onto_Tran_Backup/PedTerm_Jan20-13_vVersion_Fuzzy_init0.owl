    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intravenous_Route_of_Administration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intravenous_Route_of_Administration">
