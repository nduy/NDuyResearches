    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hemoglobin_S_to_Total_Hemoglobin_Ratio_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hemoglobin_S_to_Total_Hemoglobin_Ratio_Measurement">
