        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Duodenal_Band</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Duodenal_Bands</ace_lexicon:CN_pl>
    </owl:Class>
    


