</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Shoulder</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The portion of the upper extremity between the shoulder and the elbow. For clinical purposes this term is also used to refer to the whole superior limb.</NCI_Definition>
