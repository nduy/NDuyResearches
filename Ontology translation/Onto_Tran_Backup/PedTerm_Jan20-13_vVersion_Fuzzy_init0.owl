    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Postpartum_Process">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Labor_and_Delivery_Process"/>
