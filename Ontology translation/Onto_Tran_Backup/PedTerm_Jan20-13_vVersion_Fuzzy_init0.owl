        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital birth defect characterized by incomplete development or absence of face structures, usually affecting one side of the face. The defects include partially formed or absent ear, nose, lip, mandible, and/or soft palate.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84740</ID>
        <NCI_PT rdf:datatype="&xsd;string">Goldenhar Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Goldenhar_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Goldenhar_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


