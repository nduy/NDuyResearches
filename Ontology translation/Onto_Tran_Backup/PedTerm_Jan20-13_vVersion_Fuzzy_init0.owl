    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Grade_3_Intraventricular_Nontraumatic_Hemorrhage_of_Fetus_and_Newborn -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Grade_3_Intraventricular_Nontraumatic_Hemorrhage_of_Fetus_and_Newborn">
