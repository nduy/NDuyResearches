</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Symptoms, physical examination results, and/or laboratory test results related to the connective and soft tissue.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Musculoskeletal_Finding</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Musculoskeletal_Findings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_System_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_System_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">Any deviation from the normal structure or function of the musculoskeletal or connective tissue that is manifested by a characteristic set of symptoms and signs.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C27574</ID>
        <NCI_PT rdf:datatype="&xsd;string">Connective and Soft Tissue Disorder</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Disorder of Musculoskeletal System</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Musculoskeletal_System_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Musculoskeletal_System_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myasthenia_Gravis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myasthenia_Gravis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autoimmune_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A chronic autoimmune neuromuscular disorder characterized by skeletal muscle weakness. It is caused by the blockage of the acetylcholine receptors at the neuromuscular junction.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C60989</ID>
        <NCI_PT rdf:datatype="&xsd;string">Myasthenia Gravis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Myasthenia_Gravises</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Myasthenia_Gravis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myelocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myelocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Spina_Bifida"/>
        <ID rdf:datatype="&xsd;string">C98874</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Herniation of spinal cord tissue and meninges through a defect in a region of the vertebral column. The protrusion of the tissue is flush with the level of the skin surface.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Myelocele</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Spinal Meningocele</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Myelocele</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Myeloceles</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myelomeningocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myelomeningocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Spina_Bifida"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in which the spinal cord and meninges protrude through a defect in the spinal column. The protrusion is above the skin surface.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101201</ID>
        <NCI_PT rdf:datatype="&xsd;string">Myelomeningocele</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
