</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Procedure (NRNT)</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Isovaleryl-CoA_Dehydrogenase_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Isovaleryl-CoA_Dehydrogenase_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


