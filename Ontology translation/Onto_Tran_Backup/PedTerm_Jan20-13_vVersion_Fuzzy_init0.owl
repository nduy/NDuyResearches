        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any system designed to expedite the sorting and delivery of mail by assigning a series of alphanumeric codes to each delivery area. Also used to refer to any individual delivery area code.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C25621</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
