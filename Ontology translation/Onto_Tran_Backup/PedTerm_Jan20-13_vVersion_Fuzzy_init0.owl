        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Posterior_Occiputs</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Posterior_Occiput</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Postnatal_Drug_Withdrawal -->

