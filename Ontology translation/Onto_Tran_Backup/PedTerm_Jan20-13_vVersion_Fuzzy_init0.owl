    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vaginal_Diaphragm -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vaginal_Diaphragm">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Device"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A contraceptive device made of soft flexible material, usually of thin rubber, that is designed to cover the cervix uteri prior to sexual intercourse to prevent the entry of spermatozoa.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A medical contraceptive device of soft flexible material, usually of thin rubber, that is designed to cover the cervix uteri prior to sexual intercourse to prevent the entry of spermatozoa. To enhance efficacy, a spermicidal agent is often placed within the device. Antimicrobial agent(s) can also be used to prevent sexually transmitted diseases. Efficacy of vaginal diaphragm against infections is very limited.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C42767</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vaginal Diaphragm</NCI_PT>
        <ace_lexicon:CN_sg>Vaginal_Diaphragm</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vaginal_Diaphragms</ace_lexicon:CN_pl>
    </owl:Class>
    


