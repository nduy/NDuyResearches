        <NCI_PT rdf:datatype="&xsd;string">Postpartum Recovery</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The healing and recuperation of the mother including physiological readjustment after pregnancy and delivery of the baby.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Post-Partum_Recovery</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Post-Partum_Recoveries</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Post-Traumatic_Stress_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Post-Traumatic_Stress_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anxiety_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An anxiety disorder precipitated by an experience of intense fear or horror while exposed to a traumatic (especially life-threatening) event. The disorder is characterized by intrusive recurring thoughts or images of the traumatic event; avoidance of anything associated with the event; a state of hyperarousal and diminished emotional responsiveness. These symptoms are present for at least one month and the disorder is usually long-term.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3389</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Post-Traumatic Stress Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Post-Traumatic_Stress_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Post-Traumatic_Stress_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Postal_Code -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Postal_Code">
