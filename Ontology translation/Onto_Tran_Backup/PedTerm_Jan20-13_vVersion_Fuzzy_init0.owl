    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Preconception_Stage">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Maternal_Life_Stage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
