    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Biophysical_Profile -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Biophysical_Profile">
