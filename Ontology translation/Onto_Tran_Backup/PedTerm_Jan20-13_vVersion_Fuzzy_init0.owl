    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Varicella-Zoster_Virus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Varicella-Zoster_Virus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Virus"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An icosahedral, enveloped virus containing a single molecule of linear double-stranded DNA of 125000 nucleotides that infects only humans. It is the causative agent of chickenpox and shingles.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C71091</ID>
        <NCI_PT rdf:datatype="&xsd;string">Human Herpesvirus 3</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Varicella-Zoster_Virus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Varicella-Zoster_Viruses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Varicella-Zoster_Virus_Infection -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Varicella-Zoster_Virus_Infection">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Viral_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A highly contagious viral infection caused by the varicella zoster virus. Clinically, it may be manifested as shingles (herpes zoster) or chicken pox.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96407</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
