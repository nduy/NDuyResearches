        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare disorder characterized by diffuse thickening of the endocardium. It presents with unexplained heart failure.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98922</ID>
        <NCI_PT rdf:datatype="&xsd;string">Endocardial Fibroelastosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
