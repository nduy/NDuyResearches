    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Peroxisomal_Function_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Peroxisomal_Function_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A group of congenital disorders of lipid metabolism, caused by loss of the normal peroxisomes. Signs and symptoms include developmental delays, mental retardation, facial abnormalities, hepatomegaly, and hypotonia.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85005</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Peroxisomal Function</SYN>
