</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Transient Leukemoid Reaction of Newborn</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Transient Leukemoid Reaction of the Newborn</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Leukemoid_Reaction_of_the_Newborn</ace_lexicon:CN_sg>
