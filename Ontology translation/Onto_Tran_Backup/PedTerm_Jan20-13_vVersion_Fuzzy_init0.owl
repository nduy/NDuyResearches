        <ace_lexicon:CN_sg>Endocardial_Fibroelastosis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Endocardial_Fibroelastoses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">Any deviation from the normal structure or function of the endocrine system that is manifested by a characteristic set of symptoms and signs.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3009</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Endocrine System</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Endocrine Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Endocrine_System_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Endocrine_System_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Endometriosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Endometriosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Female_Reproductive_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3014</ID>
        <NCI_PT rdf:datatype="&xsd;string">Endometriosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The growth of functional endometrial tissue in anatomic sites outside the uterine body. It most often occurs in the pelvic organs.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Endometriosis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Endometrioses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Enlarged_Abdomen -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Enlarged_Abdomen">
