        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital or acquired defect characterized by the presence of a hole in or adjacent to the iris.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98879</ID>
        <NCI_PT rdf:datatype="&xsd;string">Coloboma of the Iris</NCI_PT>
