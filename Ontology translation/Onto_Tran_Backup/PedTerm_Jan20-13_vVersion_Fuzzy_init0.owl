        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Administration of a drug within or into a vein or veins. Introduction of the drug directly into venous circulation results in 100% bioavailability due to an absence of the absorption phase, provides a precise and continuous mode of drug therapy, especially for drugs with a narrow therapeutic index.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C38276</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intravenous Route of Administration</NCI_PT>
