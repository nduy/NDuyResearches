        <ace_lexicon:CN_sg>Congenital_Diaphragmatic_Hernia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Diaphragmatic_Hernias</ace_lexicon:CN_pl>
    </owl:Class>
    


