        <NCI_Definition rdf:datatype="&xsd;string">Inflammation of the fetal sac membranes.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Chorioamnionitis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Chorioamnionitises</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chorionic_Villus_Sampling -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chorionic_Villus_Sampling">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Screening_for_Genetic_Defect"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92755</ID>
        <NCI_PT rdf:datatype="&xsd;string">Chorionic Villus Sampling</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The extraction of placenta tissue containing the chorionic villi from the maternal uterus in early pregnancy to screen for fetal genetic defects.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Chorionic_Villus_Samplings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Chorionic_Villus_Sampling</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chorioretinitis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chorioretinitis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Inflammatory_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An inflammatory process affecting a part of or the entire uvea. Causes include inflammatory agents (e.g., herpes simplex, herpes zoster, leptospirosis) and systemic diseases (e.g., inflammatory bowel disease, multiple sclerosis, systemic lupus erythematosus, ankylosing spondylitis). Patients present with pain and redness in the eye, light sensitivity, and blurred and decreased vision.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26909</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Uveitis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Chorioretinitis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Chorioretinitises</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Choroiditis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Choroiditis">
