        <ace_lexicon:CN_pl>Contrast_Agents</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Contrast_Agent</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Copper_Metabolism_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Copper_Metabolism_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive inherited disorder caused by mutations in the ATP7B gene. It is characterized by copper accumulation in the tissues, particularly brain and liver. It results in liver failure, neurologic, and psychotic manifestations.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84756</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Copper Metabolism</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Hepatolenticular Degeneration</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
