</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Partial or complete paralysis of the facial muscles of one side of an individual&apos;s face that is present at birth. It is caused by damage to the seventh cranial nerve.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Facial_Nerve_Palsy</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Facial_Nerve_Palsies</ace_lexicon:CN_pl>
    </owl:Class>
    


