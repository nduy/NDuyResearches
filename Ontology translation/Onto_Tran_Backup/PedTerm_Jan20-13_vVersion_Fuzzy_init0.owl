        <ace_lexicon:CN_sg>Surgical_Procedure</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Suspected_Necrotizing_Enterocolitis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Suspected_Necrotizing_Enterocolitis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Necrotizing_Enterocolitis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C101273</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Suspected Necrotizing Enterocolitis</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The diagnosis assigned when a health care practitioner feels strongly the patient has necrotizing enterocolitis, but lacks definitive proof.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Suspected_Necrotizing_Enterocolitises</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Suspected_Necrotizing_Enterocolitis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sweating -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sweating">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C36172</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Sweating</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The loss of a watery fluid, consisting mainly of sodium chloride and urea in solution, that is secreted by the sweat glands in the skin of mammals.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Sweating</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Sweatings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Syndactyly -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Syndactyly">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital condition characterized by webbing between the fingers and/or toes, joining the digits together. In rare cases, the joining of the fingers or toes may involve bony fusion between the digits. Common causes include Down Syndrome and hereditary syndactyly.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87125</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Syndactyly</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Syndactyly</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Syndactylies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Syndrome_of_Inappropriate_Vasopressin_Secretion -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Syndrome_of_Inappropriate_Vasopressin_Secretion">
