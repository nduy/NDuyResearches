        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare, non-progressive congenital disorder characterized by multiple joint contractures which are present at birth.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Arthrogryposis</NCI_PT>
