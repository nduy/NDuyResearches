        <ace_lexicon:CN_sg>Grade_IV_Vesicoureteral_Reflux</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Grade_I_Vesicoureteral_Reflux -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Grade_I_Vesicoureteral_Reflux">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vesicoureteric_Reflux"/>
        <ID rdf:datatype="&xsd;string">C98661</ID>
        <NCI_PT rdf:datatype="&xsd;string">Grade I Vesicoureteral Reflux</NCI_PT>
