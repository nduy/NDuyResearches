    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Low_Birth_Weight -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Low_Birth_Weight">
