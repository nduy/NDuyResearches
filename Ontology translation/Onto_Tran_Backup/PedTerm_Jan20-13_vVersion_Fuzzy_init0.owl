</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neck</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The region that connects the head to the rest of the body.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
