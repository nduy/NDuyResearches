    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Preterm_Premature_Rupture_of_Membrane -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Preterm_Premature_Rupture_of_Membrane">
