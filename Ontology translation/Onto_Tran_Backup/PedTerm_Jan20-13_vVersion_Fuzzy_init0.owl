        <ace_lexicon:CN_sg>Fundus_Coloboma</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fused_Eyelid -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fused_Eyelid">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Skin"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in which the margins of the upper and lower eyelids are fused together by bands of tissue.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87077</ID>
        <SYN rdf:datatype="&xsd;string">Congenital_Ankyloblepharon</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Fused Eyelid</NCI_PT>
