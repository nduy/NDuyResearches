    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Horseshoe_Kidney -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Horseshoe_Kidney">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Urinary_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in which the two kidneys fuse together during fetal development to create a horseshoe-shaped structure.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98947</ID>
        <NCI_PT rdf:datatype="&xsd;string">Horseshoe Kidney</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Horseshoe_Kidney</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Horseshoe_Kidneys</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Chorionic_Gonadotropin_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Chorionic_Gonadotropin_Measurement">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Test"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A laboratory test to detect the amount of human chorionic gonadotropin in a biospecimen.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75387</ID>
        <NCI_PT rdf:datatype="&xsd;string">Human Chorionic Gonadotropin Measurement</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Human_Chorionic_Gonadotropin_Measurement</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Human_Chorionic_Gonadotropin_Measurements</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papilloma_Virus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papilloma_Virus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Virus"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A strain of papillomavirus that can infect the skin and mucous membranes of humans.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C14226</ID>
        <NCI_PT rdf:datatype="&xsd;string">Human Papillomavirus</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Human_Papilloma_Viruses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Human_Papilloma_Virus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papillomavirus-16 -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papillomavirus-16">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papilloma_Virus"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A virus comprised of a protein coat (capsid) surrounding a circular, double-stranded DNA organized into coding and non-coding regions, which can induce skin and mucosal epithelial lesions. Human papillomavirus-16 (HPV16) has been directly linked to cervical cancer and is significantly associated with invasiveness. Progression from low- to high-grade neoplasia is often associated with the integration of the HPV16 genome into the host chromosome.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C14338</ID>
        <NCI_PT rdf:datatype="&xsd;string">Human Papillomavirus-16</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Human_Papillomavirus-16</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Human_Papillomavirus-16s</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papillomavirus-18 -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papillomavirus-18">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Human_Papilloma_Virus"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A virus comprised of a protein coat (capsid) surrounding a circular, double-stranded DNA organized into coding and non-coding regions, which can induce skin and mucosal epithelial lesions. Human papillomavirus-18 (HPV18) has been directly linked to cervical cancer and plays a role in the pathogenesis of the disease. The virus integrates its DNA at specific chromosomal locations, such as 8q24 and 12q15. The use of molecular markers for HPV18 infection may allow the identification of patients with early stage cervical cancer and those at high risk for disease recurrence.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C14377</ID>
        <NCI_PT rdf:datatype="&xsd;string">Human Papillomavirus-18</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Human_Papillomavirus-18</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Human_Papillomavirus-18s</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hydranencephaly -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hydranencephaly">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital brain disorder in which the cerebral hemispheres are absent and replaced by sacs that contain cerebrospinal fluid. Signs and symptoms include irritability, increased muscle tone, seizures, and hydrocephalus. The prognosis is poor.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98949</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hydranencephaly</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hydranencephaly</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hydranencephalies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hydrocephalus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hydrocephalus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Brain_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder characterized by an abnormal increase of cerebrospinal fluid in the ventricles of the brain.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3111</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hydrocephalus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hydrocephalus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hydrocephaluses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperammonemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperammonemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Electrolyte_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A laboratory test result indicating increased levels of ammonia in the blood.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98950</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hyperammonemia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hyperammonemias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hyperammonemia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperbilirubinemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperbilirubinemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <NCI_Definition rdf:datatype="&xsd;string">Abnormally high level of bilirubin in the blood. Excess bilirubin is associated with jaundice.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C27088</ID>
        <NCI_PT rdf:datatype="&xsd;string">Elevated Bilirubin</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Physiological Hyperbilirubinemia</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hyperbilirubinemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hyperbilirubinemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypercoagulability_State -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypercoagulability_State">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hematological_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition characterized by an abnormally high level of thrombi. Causes include thrombotic thrombocytopenic purpura, disseminated intravascular coagulation, bone marrow disorders, and antiphospholipid antibody syndrome.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84479</ID>
        <NCI_PT rdf:datatype="&xsd;string">Excessive Blood Clotting</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hypercoagulability_State</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hypercoagulability_States</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperemesis_Gravidarum -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperemesis_Gravidarum">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Complication"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87084</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hyperemesis Gravidarum</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Severe, intractable vomiting during pregnancy (usually the first trimester) accompanied by dehydration, weight loss, and electrolyte imbalances.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hyperemesis_Gravidarums</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hyperemesis_Gravidarum</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperextension_Deformity_of_Knee -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperextension_Deformity_of_Knee">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Deformity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormal alignment of the knee backwards that is due to a deformity in the knee joint.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C103184</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hyperextension of Knee Deformity</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hyperextension_Deformity_of_Knees</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hyperextension_Deformity_of_Knee</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperkalemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperkalemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Electrolyte_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C37968</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Higher than normal levels of potassium in the circulating blood; associated with kidney failure or sometimes with the use of diuretic drugs.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Hyperkalemia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hyperkalemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hyperkalemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypermagnesemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypermagnesemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Electrolyte_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C37969</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Higher than normal levels of magnesium in the circulating blood.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Hypermagnesemia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hypermagnesemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hypermagnesemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypernatremic_Dehydration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypernatremic_Dehydration">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dehydration"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C101229</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Dehydration resulting from abnormally high levels of sodium in the blood. Infants and individuals that are intubated are at highest risk.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Hypernatremic Dehydration</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hypernatremic_Dehydrations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hypernatremic_Dehydration</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperparathyroidism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperparathyroidism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C48259</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Hyperfunction of the parathyroid glands resulting in the overproduction of parathyroid hormone. It may be primary or secondary; primary hyperparathyroidism is caused by parathyroid adenoma, parathyroid hyperplasia, parathyroid carcinoma, and multiple endocrine neoplasia. It is associated with hypercalcemia and hypophosphatemia. Signs and symptoms include weakness, fatigue, nausea, vomiting, constipation, depression, bone pain, osteoporosis, cystic bone lesions, and kidney stones. Secondary hyperparathyroidism is caused by the chronic stimulation of the parathyroid glands in patients with chronic renal failure, rickets, and malabsorption syndromes.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Hyperparathyroidism</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hyperparathyroidism</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hyperparathyroidisms</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertensive_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertensive_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiovascular_Disorder"/>
        <NICHD_Definition rdf:datatype="&xsd;string"></NICHD_Definition>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <ID rdf:datatype="&xsd;string">C3117</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypertension</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Pathological increase in blood pressure; a repeatedly elevated blood pressure exceeding 140 over 90 mmHg.</NCI_Definition>
        <ace_lexicon:CN_pl>Hypertensive_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hypertensive_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperthermia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperthermia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition that manifests with abnormally high body temperature. In hyperthermic state, the hypothalamic set-point is normal but body temperature increases and overrides the ability to lose heat, resulting from exogenous heat exposure or endogenous heat production, e.g. in heat stroke, malignant hyperthermia, endocrine hyperthermia, or neuroleptic malignant syndrome. The concept does not refer to hyperpyrexia, the state when the hypothalamic set-point is reset at a higher temperature and is physiologically regulated.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50589</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hyperthermia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hyperthermia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hyperthermias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperthyroidism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyperthyroidism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3123</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hyperthyroidism</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Overactivity of the thyroid gland resulting in overproduction of thyroid hormone and increased metabolic rate. Causes include diffuse hyperplasia of the thyroid gland (Graves&apos; disease), single nodule in the thyroid gland, and thyroiditis. The symptoms are related to the increased metabolic rate and include weight loss, fatigue, heat intolerance, excessive sweating, diarrhea, tachycardia, insomnia, muscle weakness, and tremor.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hyperthyroidisms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hyperthyroidism</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertonia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertonia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition of increased muscle tone manifested by increased resistance of the muscle to passive stretching.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87085</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypertonia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hypertonia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hypertonias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertrophic_Pyloric_Stenosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypertrophic_Pyloric_Stenosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pyloric_Stenosis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormality characterized by thickening of the muscle in the wall of the pylorus. It results in the narrowing of the pyloric channel. The overlying mucosa may appear hypertrophic as well. Clinical signs and symptoms appear early in life and include projectile vomiting and dehydration.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98952</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypertrophic Pyloric Stenosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hypertrophic_Pyloric_Stenoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hypertrophic_Pyloric_Stenosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypnobirthing -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypnobirthing">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Assisted_Labor"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An unique natural method of childbirth that is supported by a relaxing self-hypnosis method.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92810</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypnobirthing</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hypnobirthings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hypnobirthing</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypocalcemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypocalcemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Electrolyte_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C37973</ID>
        <NICHD_Definition rdf:datatype="&xsd;string">Hypocalcaemia is an electrolyte disturbance in which the serum calcium levels in the blood are low (less than 2.1 mmol/L).</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Hypocalcemia</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Lower than normal levels of calcium in the circulating blood.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Hypocalcemias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hypocalcemia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypomagnesemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypomagnesemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Electrolyte_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C37975</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypomagnesemia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">Hypomagnesemia is an electrolyte disturbance in which there is an abnormally low level of magnesium in the blood (less than 0.7 mmol/L)</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">Lower than normal levels of magnesium in the circulating blood.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Hypomagnesemias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hypomagnesemia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hyponatremia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hyponatremia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Electrolyte_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C37976</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hyponatremia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">Hyponatremia is an electrolyte disturbance in which the sodium concentration in the serum is lower than normal. Sodium homeostasis is vital to the normal physiologic function of cells. Hyponatremia is defined as a serum level of less than 135 mEq/L and is considered severe when the serum level is below 125 mEq/L.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">Lower than normal levels of sodium in the circulating blood.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Hyponatremias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hyponatremia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypoparathyroidism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypoparathyroidism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An endocrine disorder characterized by decreased production of parathyroid hormone by the parathyroid glands. It is usually caused by damage of the parathyroid glands during head and neck surgery. Signs and symptoms include muscle cramps, abdominal pain, dry skin, brittle nails, cataracts, tetany, and convulsions.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C78350</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypoparathyroidism</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hypoparathyroidisms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hypoparathyroidism</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypophosphatasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypophosphatasia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Electrolyte_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare, serious metabolic disorder caused by mutations in the gene encoding tissue non-specific alkaline phosphatase (TNSALP) activity. It is characterized by low activity of TNSALP in the serum. The signs and symptoms vary significantly and include death in utero, failure to thrive, premature loss of deciduous teeth, early loss of the adult dentition, hypercalcemia, osteomalacia, skeletal defects, renal stones, and movement disorders.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26798</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypophosphatasia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hypophosphatasia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hypophosphatasias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypoplasia_of_the_Optic_Nerve -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypoplasia_of_the_Optic_Nerve">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality characterized by the underdevelopment of the optic nerve.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98999</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Optic Nerve Hypoplasia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hypoplasia_of_the_Optic_Nerve</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hypoplasia_of_the_Optic_Nerves</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hypoplastic_Left_Heart_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hypoplastic_Left_Heart_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital cardiovascular disorder characterized by severe underdevelopment of the left side of the heart. Signs and symptoms include tachypnea, cyanosis, dyspnea, and lethargy.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98894</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypoplastic Left Heart Syndrome</NCI_PT>
