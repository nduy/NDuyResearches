        <ace_lexicon:CN_pl>Persistent_Fetal_Bradycardias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Persistent_Fetal_Bradycardia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Fetal_Tachycardia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Fetal_Tachycardia">
