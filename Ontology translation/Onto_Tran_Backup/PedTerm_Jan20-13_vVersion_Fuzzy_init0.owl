    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Duodenal_Web -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Duodenal_Web">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98918</ID>
        <NCI_PT rdf:datatype="&xsd;string">Duodenal Web</NCI_PT>
