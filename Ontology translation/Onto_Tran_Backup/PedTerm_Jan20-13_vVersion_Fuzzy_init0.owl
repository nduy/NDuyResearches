    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Crowning">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_of_Impending_Birth"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92763</ID>
        <NCI_PT rdf:datatype="&xsd;string">Crowning during Childbirth</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The characteristic sign of impending birth during the second stage of labor. The presenting part of the head of fetus is visible and firmly rimmed by the maternal vaginal wall.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
