        <NCI_Definition rdf:datatype="&xsd;string">The determination of the amount of hormone present in a sample.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hormone_Measurement</ace_lexicon:CN_sg>
