    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Duplication_of_Esophagus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality characterized by the presence of a duplicated segment of the esophagus. The duplicated segment may by tubular or cystic.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98924</ID>
        <NCI_PT rdf:datatype="&xsd;string">Esophageal Duplication</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Duplication_of_Esophaguses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Duplication_of_Esophagus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Duplication_of_Intestine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Duplication_of_Intestine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality characterized by the presence of a duplicated segment of the intestine. The duplicated segment is cystic.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98960</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intestinal Duplication</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Duplication_of_Intestine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Duplication_of_Intestines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Facial_Nerve_Palsy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Facial_Nerve_Palsy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C101198</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Facial Nerve Palsy</NCI_PT>
