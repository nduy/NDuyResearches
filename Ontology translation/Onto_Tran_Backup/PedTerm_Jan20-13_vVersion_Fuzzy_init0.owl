        <NCI_Definition rdf:datatype="&xsd;string">Prevention of contraception by not engaging in sexual intercourse.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Sexual Abstinence</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Sexual_Abstinences</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Sexual_Abstinence</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sexual_Differentiation_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sexual_Differentiation_Disorder">
