        <ace_lexicon:CN_sg>TPN_Acquired_Cholestasis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>TPN_Acquired_Cholestases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tachyarrhythmia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tachyarrhythmia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiac_Arrhythmia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C38029</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">Tachyarrhythmia is any disturbance of the heart rhythm in which the heart rate is abnormally increased.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Tachycardia</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Tachycardia; an abnormally rapid heartbeat, usually applied to a heart rate above 100 per minute.</NCI_Definition>
        <ace_lexicon:CN_pl>Tachyarrhythmias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Tachyarrhythmia</ace_lexicon:CN_sg>
    </owl:Class>
    


