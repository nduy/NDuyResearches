        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98888</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Cataract that is present at birth.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Cataract</NCI_PT>
