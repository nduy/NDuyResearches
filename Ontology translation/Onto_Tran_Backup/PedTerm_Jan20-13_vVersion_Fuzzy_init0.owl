        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99013</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Necrosis and softening of the white matter around the ventricles in the brain. It is usually seen in preterm infants and caused by lack of blood flow and oxygenation in the periventricular brain parenchyma.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
