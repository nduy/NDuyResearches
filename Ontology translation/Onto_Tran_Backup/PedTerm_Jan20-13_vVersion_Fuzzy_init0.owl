</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Partial or complete obstruction of the duodenal lumen due to the presence of a membranous web.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Duodenal_Webs</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Duodenal_Web</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Duration_of_Contraction -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Duration_of_Contraction">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Quantitative_Concept"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92769</ID>
