    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Bone_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Bone_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A group of disorders that affect the bones secondary to increased levels of minerals or deficient levels of minerals such as calcium, magnesium, phosphorus, and vitamin D. Representative examples are osteomalacia, osteoporosis, and Paget disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97045</ID>
        <NCI_PT rdf:datatype="&xsd;string">Metabolic Bone Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Metabolic_Bone_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Metabolic_Bone_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Systemic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital (due to inherited enzyme abnormality) or acquired (due to failure of a metabolic important organ) disorder resulting from an abnormal metabolic process.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3235</ID>
        <NCI_PT rdf:datatype="&xsd;string">Metabolic Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Metabolic_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Metabolic_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Disease_of_Collagen -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Disease_of_Collagen">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Connective_Tissue_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A group of connective tissue disorder caused by mutations in the COL1A1 gene mapped to chromosome 17q21. It includes the Ehlers-Danlos syndrome, osteogenesis imperfecta, and osteoporosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75471</ID>
        <NCI_PT rdf:datatype="&xsd;string">COL1A1 Associated Connective Tissue Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Metabolic_Disease_of_Collagens</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Metabolic_Disease_of_Collagen</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Myopathy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Myopathy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A group of rare inherited disorders characterized by a deficiency of enzymes that are involved in metabolic pathways that affect muscles. The disorders are characterized by muscle dysfunction.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98985</ID>
        <NCI_PT rdf:datatype="&xsd;string">Metabolic Myopathy</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Metabolic_Myopathies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Metabolic_Myopathy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Methemoglobin_Reductase_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Methemoglobin_Reductase_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C101043</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Less than the necessary amount of the enzyme that converts methemoglobin into hemoglobin.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Methemoglobin Reductase Deficiency</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Methemoglobin_Reductase_Deficiencies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Methemoglobin_Reductase_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Methylcrotonyl-CoA_Carboxylase_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Methylcrotonyl-CoA_Carboxylase_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">3-Methylcrotonyl-CoA Carboxylase Deficiency</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">An autosomal recessive inherited disorder caused by mutations in the MCCC1 or MCCC2 genes. It is characterized by a deficiency in an enzyme that is involved in the metabolism of proteins that contain leucine. Signs and symptoms range from mild to severe and include feeding difficulties, vomiting, diarrhea, developmental delays, lethargy, seizures and coma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98674</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Methylcrotonyl-CoA_Carboxylase_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Methylcrotonyl-CoA_Carboxylase_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Methylmalonic_Acidemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Methylmalonic_Acidemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive inherited disorder caused by mutations of the MUT, MMAA, MMAB, MMADHC, and MCEE genes. It is characterized by abnormalities in the metabolism of lipids and proteins. Signs and symptoms usually appear early in life and vary from mild to life threatening. They include vomiting, dehydration, hypotonia, developmental delays, hepatomegaly, lethargy, intellectual disabilities, and chronic kidney disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98986</ID>
        <NCI_PT rdf:datatype="&xsd;string">Methylmalonic Acidemia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Methylmalonic_Acidemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Methylmalonic_Acidemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Microcephalus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Microcephalus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Brain_Development_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital or acquired developmental disorder in which the circumference of the head is smaller than normal for the person&apos;s age and sex. It is the result of brain developmental delay.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85874</ID>
        <NCI_PT rdf:datatype="&xsd;string">Microcephaly</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Microcephalus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Microcephaluses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Microcolon -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Microcolon">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality characterized by the presence of an abnormally small colon. It is the result of intestinal underutilization during fetal development.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98987</ID>
        <NCI_PT rdf:datatype="&xsd;string">Microcolon</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Microcolon</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Microcolons</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Microcystic_Renal_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Microcystic_Renal_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fibrocystic_Kidney_Disease"/>
        <NCI_Definition rdf:datatype="&xsd;string">A usually autosomal dominant and less frequently autosomal recessive genetic disorder characterized by the presence of numerous cysts in the kidneys leading to end-stage renal failure. The autosomal dominant trait is associated with abnormalities on the short arm of chromosome 16. Symptoms in patients with the autosomal dominant trait usually appear at middle age and include abdominal pain, hematuria, and high blood pressure. Patients may develop brain aneurysms and liver cysts. Patients with the autosomal recessive trait present with progressive renal failure early in life and symptoms resulting from hepatic fibrosis. The autosomal recessive trait is associated with abnormalities of chromosome 6. Polycystic kidney disease may also result as a side effect in patients on renal dialysis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75464</ID>
        <SYN rdf:datatype="&xsd;string">Multicystic Kidney</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Polycystic Kidney Disease</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Microcystic_Renal_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Microcystic_Renal_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Micrognathism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Micrognathism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality of the jaws (particularly the mandible) in which they are unusually small. This condition is not always pathological and may correct itself as the patient matures; however, it may also present as a birth defect in multiple syndromes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87094</ID>
        <SYN rdf:datatype="&xsd;string">Congenital_Micrognathism</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Micrognathism</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Micrognathisms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Micrognathism</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Microgyria -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Microgyria">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality characterized by the presence of abnormally small convolutions in the brain. It results in mental retardation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98988</ID>
        <NCI_PT rdf:datatype="&xsd;string">Microgyria</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Microgyria</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Microgyrias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Microinternational_Unit_per_Milliliter -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Microinternational_Unit_per_Milliliter">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Unit_of_Measure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C67405</ID>
        <NCI_PT rdf:datatype="&xsd;string">Microinternational Unit per Milliliter</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Unit of arbitrary substance concentration (biologic activity concentration) defined as the concentration of one millionth of international unit per one milliliter of system volume.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Microinternational_Unit_per_Milliliter</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Microinternational_Unit_per_Milliliters</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Microphthalmos -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Microphthalmos">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_Visual_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality characterized by the presence of an abnormally small eye globe.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98989</ID>
        <NCI_PT rdf:datatype="&xsd;string">Microphthalmos</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Microphthalmos</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Microphthalmoses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Middle_Childhood -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Middle_Childhood">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Child_Life_Stage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage that begins at six years of age and continues until eleven complete years of age.</NICHD_Definition>
        <ID rdf:datatype="&xsd;string">C89347</ID>
        <NCI_PT rdf:datatype="&xsd;string">Middle Childhood</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The time period in a child&apos;s life that is generally defined as between 5 and 10 years of life.</NCI_Definition>
        <ace_lexicon:CN_pl>Middle_Childhoods</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Middle_Childhood</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Midline_Longitudinal_Incision -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Midline_Longitudinal_Incision">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Surgical_Incision"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A surgical incision line that extends in a midline longitudinal axis of the uterus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92830</ID>
        <NCI_PT rdf:datatype="&xsd;string">Midline Longitudinal Uterine Incision</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Midline_Longitudinal_Incision</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Midline_Longitudinal_Incisions</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Migration_Defects -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Migration_Defects">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A diverse group of congenital brain developmental disorders characterized by defects in neuronal migration in the brain during early fetal development. The neuronal migration defects result in brain abnormalities that are usually manifested with mental retardation and epilepsy.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98990</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neuronal Migration Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Migration_Defectses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Migration_Defects</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mild_Uterine_Contractions -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mild_Uterine_Contractions">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Uterine_Contraction"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An uterine contraction that is barely felt.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92831</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mild Uterine Contraction</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Mild_Uterine_Contractionses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Mild_Uterine_Contractions</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Milligram_per_Deciliter -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Milligram_per_Deciliter">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Unit_of_Measure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A unit of mass concentration defined as the concentration of one milligram of a substance in unit volume of the mixture equal to one cubic deciliter or 100 cubic centimeters. It is also a unit of mass density (volumic mass) defined as the density of substance which mass equal to one milligram occupies the volume one cubic deciliter or 100 cubic centimeters.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C67015</ID>
        <NCI_PT rdf:datatype="&xsd;string">Milligram per Deciliter</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Milligram_per_Deciliters</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Milligram_per_Deciliter</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Millimole_per_Liter -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Millimole_per_Liter">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Unit_of_Measure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A unit of concentration (molarity unit) equal to one thousandth of a mole (10E-3 mole) of solute per one liter of solution.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C64387</ID>
