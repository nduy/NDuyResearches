        <ace_lexicon:CN_pl>Increased_Bone_Densities</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Increased_Frequency_of_Urination -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Increased_Frequency_of_Urination">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Early_Pregnancy_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C26906</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Urinary Frequency</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Urination at short intervals; it may result from increased urine formation, decreased bladder capacity, or lower urinary tract irritation.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Increased_Frequency_of_Urinations</ace_lexicon:CN_pl>
