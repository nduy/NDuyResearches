    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Alcohol_Spectrum_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Alcohol_Spectrum_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetus_or_Newborn_Affected_by_Maternal_Transmission_of_Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A group of disorders caused by a prenatal exposure to maternal consumption of alcohol leading to a range of behavioral, cognitive and neurological deficits in the offspring. It is characterized by physical growth problems, distinct facies, and varying psycho-neurological issues.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92780</ID>
        <NCI_PT rdf:datatype="&xsd;string">Fetal Alcohol Spectrum Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Fetal_Alcohol_Spectrum_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Fetal_Alcohol_Spectrum_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Alcohol_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Alcohol_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Alcohol_Spectrum_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome that can develop in infants whose mothers consumed alcohol during pregnancy. Manifestations of this syndrome include low birth weight, failure to thrive, developmental defects, organ dysfunction, mental deficiencies, behavioral problems and poor motor coordination.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84713</ID>
        <NCI_PT rdf:datatype="&xsd;string">Fetal Alcohol Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Fetal_Alcohol_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Fetal_Alcohol_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


