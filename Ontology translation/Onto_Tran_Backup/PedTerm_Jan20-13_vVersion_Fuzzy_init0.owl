</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The determination of the amount of alpha-fetoprotein present in a sample.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Alpha-fetoprotein_Measurements</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Alpha-fetoprotein_Measurement</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Alveolar_Capillary_Dysplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Alveolar_Capillary_Dysplasia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_Lung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare lethal congenital abnormality that refers to the abnormal development of the capillaries around the alveoli in the lung parenchyma. It manifests as respiratory distress and persistent pulmonary hypertension in infancy.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Alveolar Capillary Dysplasia</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98809</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Alveolar_Capillary_Dysplasias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Alveolar_Capillary_Dysplasia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ambiguous_Genitalia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ambiguous_Genitalia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Reproductive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality in which the infant&apos;s external genitalia do not have the typical appearance of a male&apos;s or female&apos;s genitalia.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Ambiguous Genitalia</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98810</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ambiguous_Genitalia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ambiguous_Genitalias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Amelia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Amelia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital malformation characterized by the complete absence of all limbs.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Amelia</NCI_PT>
        <ID rdf:datatype="&xsd;string">C34370</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Amelia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Amelias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Amino_Acid_Metabolism_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Amino_Acid_Metabolism_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <NCI_PT rdf:datatype="&xsd;string">Amino Acid Metabolism Disorder</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">An inherited disorder that affects the metabolism of the amino acids. Representative examples include alkaptonuria, homocystinuria, tyrosinemia, and phenylketonuria.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97090</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Amino Acid Metabolism</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Amino_Acid_Metabolism_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Amino_Acid_Metabolism_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Amniocentesis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Amniocentesis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Screening_for_Genetic_Defect"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A prenatal diagnostic procedure in which a small sample of amniotic fluid is removed from the uterus by a needle inserted into the abdomen. This procedure is used to detect various genetic abnormalities in the fetus and/or the sex of the fetus.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Amniocentesis</NCI_PT>
        <ID rdf:datatype="&xsd;string">C52009</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Amniocenteses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Amniocentesis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Amnioinfusion -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Amnioinfusion">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Obstetric_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Amnioinfusion</NCI_PT>
        <ID rdf:datatype="&xsd;string">C92729</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The procedure of instilling saline or other fluids into the amniotic cavity using an intrauterine catheter.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Amnioinfusions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Amnioinfusion</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Amniotic_Band_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Amniotic_Band_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality"/>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital disorder which is caused by entrapment of anatomic parts of the fetus in fibrous amniotic bands during pregnancy. It may result in the formation of constriction rings around the digits and upper and lower extremities, swelling of the extremities and congenital amputations.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Amniotic Band Syndrome</NCI_PT>
        <ID rdf:datatype="&xsd;string">C84552</ID>
        <SYN rdf:datatype="&xsd;string">Deformity due to Amniotic Band</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Amniotic_Band_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Amniotic_Band_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Amniotic_Fluid -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Amniotic_Fluid">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Biological_Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Amniotic Fluid</NCI_PT>
        <ID rdf:datatype="&xsd;string">C13188</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The fluid within the amniotic cavity which surrounds and protects the developing embryo. It is initially produced by the amnion and then later by the lungs and kidneys. The amount at term normally varies from 500 to 2000 ml.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Amniotic_Fluids</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Amniotic_Fluid</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anasarca -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anasarca">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Edema"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition that is characterized by the presence of generalized edema. Causes include congestive heart failure, liver failure, renal failure, and severe malnutrition.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Anasarca</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98811</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Anasarca</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Anasarcas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Androgen_Resistance_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Androgen_Resistance_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder of sexual development in persons with 46XY karyotype, characterized by an abnormality of the genes encoding androgen receptors. It results in a female sex appearance or the development of both male and female characteristics.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Androgen Insensitivity Syndrome</NCI_PT>
        <ID rdf:datatype="&xsd;string">C27226</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Androgen_Resistance_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Androgen_Resistance_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hematological_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A reduction in the number of red blood cells per cu mm, the amount of hemoglobin in 100 ml of blood, and the volume of packed red blood cells per 100 ml of blood. Clinically, anemia represents a reduction in the oxygen-transporting capacity of a designated volume of blood, resulting from an imbalance between blood loss (through hemorrhage or hemolysis) and blood production. Signs and symptoms of anemia may include pallor of the skin and mucous membranes, shortness of breath, palpitations of the heart, soft systolic murmurs, lethargy, and fatigability.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Anemia</NCI_PT>
        <ID rdf:datatype="&xsd;string">C2869</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Anemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Anemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anemia_due_to_Membrane_Defect -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anemia_due_to_Membrane_Defect">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hemolytic_Anemia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A group of inherited hemolytic anemias caused by erythrocyte membrane defects. This includes hereditary pyropoikilocytosis, hereditary spherocytosis and hereditary elliptocytosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101218</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hemolytic Anemia due to Membrane Defect</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Anemia_due_to_Membrane_Defects</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Anemia_due_to_Membrane_Defect</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anemia_of_Prematurity -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anemia_of_Prematurity">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Hematological_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A blood disorder characterized by low hemoglobin levels in premature neonates that usually spontaneously resolves within 3-6 months post birth. A combination of factors including the transition from the liver to the bone marrow for erythropoiesis in a neonate, blood loss experienced during delivery, the shortened life span of fetal blood cells, and an acclimation to a relatively hyperoxic environment outside the womb can predispose a neonate to this condition.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Anemia of Prematurity</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97167</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Anemia_of_Prematurity</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Anemia_of_Prematurities</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anencephalus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anencephalus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare neural tube defect during pregnancy, resulting in the absence of a large portion of the brain and skull in the fetus.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Anencephaly</NCI_PT>
        <ID rdf:datatype="&xsd;string">C84560</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Anencephaluses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Anencephalus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anesthesia_Procedure -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anesthesia_Procedure">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Intervention_or_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Anesthesia Procedure</NCI_PT>
        <ID rdf:datatype="&xsd;string">C15181</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Treatment with a pharmacological substance that produces a loss of feeling.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Anesthesia_Procedure</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Anesthesia_Procedures</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Aneurysm -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Aneurysm">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiovascular_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Aneurysm</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Bulging or ballooning in an area of an artery secondary to arterial wall weakening.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26693</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Aneurysm</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Aneurysms</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Angelman_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Angelman_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A genetic syndrome characterized by mental retardation, speech impairment, microcephaly, ataxia, and seizures. The majority of cases result from deletions on the long arm of chromosome 15. A minority of cases result from mutations in the UBE3A gene.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Angelman Syndrome</NCI_PT>
        <ID rdf:datatype="&xsd;string">C75462</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Angelman_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Angelman_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Angular_Pregnancy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Angular_Pregnancy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Ectopic_Pregnancy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A type of pregnancy which starts with the embryo in the interstitial section of the fallopian tube, which then grows into the uterine cavity.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Angular Pregnancy</NCI_PT>
        <ID rdf:datatype="&xsd;string">C92730</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Angular_Pregnancies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Angular_Pregnancy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Annular_Pancreas -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Annular_Pancreas">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality in which the duodenum is surrounded by a ring of pancreatic tissue. It may result in constriction of the duodenum and feeding intolerance.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Annular Pancreas</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98813</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Annular_Pancreases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Annular_Pancreas</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anophthalmos -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anophthalmos">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_Visual_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality characterized by the complete absence of ocular tissue in the orbit.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Anophthalmos</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98814</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Anophthalmoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Anophthalmos</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Anorexia_Nervosa -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Anorexia_Nervosa">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Eating_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder most often seen in adolescent females characterized by a refusal to maintain a minimally normal body weight, an intense fear of gaining weight, a disturbance in body image, and, in postmenarcheal females, the development of amenorrhea.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Anorexia Nervosa</NCI_PT>
        <ID rdf:datatype="&xsd;string">C34387</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Anorexia_Nervosa</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Anorexia_Nervosas</ace_lexicon:CN_pl>
    </owl:Class>
    


