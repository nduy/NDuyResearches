        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Mitochondrial_Trifunctional_Protein_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Mitochondrial_Trifunctional_Protein_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


