    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sensorineural_Hearing_Loss -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sensorineural_Hearing_Loss">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hearing_Loss"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C26739</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Hearing loss caused by a problem in the inner ear or auditory nerve. A sensorineural loss often affects a person&apos;s ability to hear some frequencies more than others. This means that sounds may be appear distorted, even with the use of a hearing aid. Sensorineural losses can range from mild to profound.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Sensorineural Deafness</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Sensorineural_Hearing_Loss</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Sensorineural_Hearing_Losses</ace_lexicon:CN_pl>
    </owl:Class>
    


