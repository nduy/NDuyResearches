        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A pathological increase in the effort and frequency or breathing movements during the perinatal period.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C103190</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
