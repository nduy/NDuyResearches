        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Presentation"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A fetal position during delivery in which the alignment of the spine of the fetus is not parallel to the mother&apos;s spine.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92898</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
