        <NCI_PT rdf:datatype="&xsd;string">Regularity of Uterine Contraction</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The nature and pattern of occurrence for the uterine contractions during labor.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
