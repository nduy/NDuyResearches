        <ace_lexicon:CN_sg>False_Labor</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fatigue -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fatigue">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Early_Pregnancy_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
