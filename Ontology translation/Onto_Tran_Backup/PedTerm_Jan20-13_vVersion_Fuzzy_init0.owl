        <NCI_Definition rdf:datatype="&xsd;string">The delivery of an infant through a surgical abdominal incision. Surgery is performed when there may be complications associated with a vaginal birth and increased risk to the mother or fetus.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Caesarian_Section</ace_lexicon:CN_sg>
