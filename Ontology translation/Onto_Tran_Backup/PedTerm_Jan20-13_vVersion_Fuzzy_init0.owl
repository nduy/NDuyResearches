    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Surgical_Procedure -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Surgical_Procedure">
