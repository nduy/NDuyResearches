        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A collection of information about a patient&apos;s doctor.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81273</ID>
