    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Solitary_Multilocular_Renal_Cyst -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Solitary_Multilocular_Renal_Cyst">
