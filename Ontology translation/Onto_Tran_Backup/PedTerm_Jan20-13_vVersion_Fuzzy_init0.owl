</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Pyruvate Dehydrogenase Complex Deficiency</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Leigh_s_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Leigh_s_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


