    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ataxic_Cerebral_Palsy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ataxic_Cerebral_Palsy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cerebral_Palsy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Ataxic Cerebral Palsy</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97168</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The least common subtype of cerebral palsy, in which the individual displays hypotonia, a loss of motor coordination, and an intention tremor. Individuals with ataxic cerebral palsy walk very unsteadily, with a wide-based gait.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ataxic_Cerebral_Palsy</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ataxic_Cerebral_Palsies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Athetoid_Cerebral_Palsy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Athetoid_Cerebral_Palsy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cerebral_Palsy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A subtype of cerebral palsy characterized by involuntary, purposeless writhing movements which affect the hands, feet, arms, and legs; the face and tongue may be affected as well, leading to involuntary grimacing, drooling, dysarthria and difficulty eating.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Athetoid Cerebral Palsy</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97169</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Athetoid_Cerebral_Palsies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Athetoid_Cerebral_Palsy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Atresia_of_Large_Intestine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Atresia_of_Large_Intestine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A malformation characterized by the absence of a normal opening in a part of the large intestine.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98827</ID>
        <NCI_PT rdf:datatype="&xsd;string">Large Intestine Atresia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Atresia_of_Large_Intestine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Atresia_of_Large_Intestines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Atresia_of_Small_Intestine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Atresia_of_Small_Intestine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <NICHD_Definition rdf:datatype="&xsd;string"></NICHD_Definition>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">A malformation characterized by the absence of a normal opening in a part of the small intestine.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98828</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Small Intestine Atresia</NCI_PT>
        <ace_lexicon:CN_sg>Atresia_of_Small_Intestine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Atresia_of_Small_Intestines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Atrial_Fibrillation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Atrial_Fibrillation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Supraventricular_Arrhythmia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An arrhythmia characterized by uncoordinated atrial myocardium activation due to multiple reentry circuits with consequent deterioration of atrial mechanical function. Instead of intermittently contracting, the atria quiver continuously in a chaotic pattern, causing a totally irregular, often tachycardia ventricular rate. On the ECG it is described by the replacement of consistent P waves by rapid oscillations or fibrillatory waves that vary in size, shape, and timing, associated with an irregular, frequently rapid ventricular response when atrioventricular conduction is intact.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Atrial Fibrillation</NCI_PT>
        <ID rdf:datatype="&xsd;string">C50466</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Atrial_Fibrillation</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Atrial_Fibrillations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Atrial_Flutter -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Atrial_Flutter">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Supraventricular_Arrhythmia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An arrhythmia characterized by organized rhythmic contraction of the atria which is generally at a rate of 200-300 beats per minute. Atrial Flutter is characterized by a sawtooth pattern of regular atrial activation called flutter waves on the electrocardiogram, particularly visible in leads II, III, aVF and v1.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Atrial Flutter</NCI_PT>
        <ID rdf:datatype="&xsd;string">C51224</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Atrial_Flutter</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Atrial_Flutters</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Atrial_Septal_Defect -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Atrial_Septal_Defect">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiac_Septal_Defects"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Atrial Septal Defect</NCI_PT>
        <ID rdf:datatype="&xsd;string">C84473</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The presence of a defect (opening) in the septum that separates the two atria of the heart. The ASD can be congenital or acquired.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Atrial_Septal_Defects</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Atrial_Septal_Defect</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attending_Health_Care_Provider -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attending_Health_Care_Provider">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Person"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Attending Health Care Provider</NCI_PT>
        <ID rdf:datatype="&xsd;string">C81231</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The individual assigned to be the primary care manager overseeing a patient&apos;s medical care during an episode of hospitalization.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Attending_Health_Care_Provider</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Attending_Health_Care_Providers</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attention_Deficit_Hyperactivity_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attention_Deficit_Hyperactivity_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Behavioral_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder characterized by a marked pattern of inattention and/or hyperactivity-impulsivity that is inconsistent with developmental level and clearly interferes with functioning in at least two settings (e.g. at home and at school). At least some of the symptoms must be present before the age of 7 years.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Attention Deficit Hyperactivity Disorder</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97160</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Attention_Deficit_Hyperactivity_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Attention_Deficit_Hyperactivity_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Bacterial_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Bacterial_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any vaccine created by reducing the virulence of bacteria but still keeping the bacteria viable (live). In the production of an attenuated vaccine, the infectious agent is altered so that it becomes harmless or less virulent. This is in contrast to those vaccines produced by &quot;killing&quot; the pathogen (inactivated vaccine).</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Attenuated Bacteria Vaccine</NCI_PT>
        <ID rdf:datatype="&xsd;string">C62761</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Attenuated_Live_Bacterial_Vaccine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Attenuated_Live_Bacterial_Vaccines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any vaccine created by reducing the virulence of the infectious agent but still keeping the agent viable (live). In the production of an attenuated vaccine, the infectious agent is altered so that it becomes harmless or less virulent. This is in contrast to those vaccines produced by killing the pathogen (inactivated vaccine).</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Attenuated Live Vaccine</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97116</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Attenuated_Live_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Attenuated_Live_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Attenuated Live Virus Vaccine</NCI_PT>
        <ID rdf:datatype="&xsd;string">C1920</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Live vaccines prepared from microorganisms which have undergone physical adaptation (e.g., by radiation or temperature conditioning) or serial passage in laboratory animal hosts or infected tissue/cell cultures, in order to produce avirulent mutant strains capable of inducing protective immunity. Live-attenuated vaccines are used when a CD8+ T Cell (cellular cytotoxicity) response is desired.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Attenuated_Live_Virus_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Attenuated_Live_Virus_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Audiometric_Test -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Audiometric_Test">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Newborn_Examination"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Audiometric Test</NCI_PT>
        <ID rdf:datatype="&xsd;string">C38036</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Testing conducted utilizing a manual or microprocessor audiometer to test for hearing loss.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Audiometric_Tests</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Audiometric_Test</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Auscultation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Auscultation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Diagnostic_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Auscultation</NCI_PT>
        <ID rdf:datatype="&xsd;string">C85573</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Listening with a device, such as a stethoscope, to anatomical locations that produce audible sounds like the heart, lungs and abdomen.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Auscultations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Auscultation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Autism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Autism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autism_Spectrum_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder characterized by marked impairments in social interaction and communication accompanied by a pattern of repetitive, stereotyped behaviors and activities. Developmental delays in social interaction and language surface prior to age 3 years.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Autism</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97161</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Autism</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Autisms</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Autism_Spectrum_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Autism_Spectrum_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pervasive_Developmental_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A spectrum of developmental disorders that includes autism, Asperger syndrome, and Rett syndrome. Signs and symptoms include poor communication skills, defective social interactions, and repetitive behaviors.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Autism Spectrum Disorder</NCI_PT>
        <ID rdf:datatype="&xsd;string">C88412</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Autism_Spectrum_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Autism_Spectrum_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Autoimmune_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Autoimmune_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Immunolymphatic_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder resulting from loss of function or tissue destruction of an organ or multiple organs, arising from humoral or cellular immune responses of the individual to his own tissue constituents. It may be systemic (e.g., systemic lupus erythematosus), or organ specific, (e.g., thyroiditis).</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Autoimmune Disease</NCI_PT>
        <ID rdf:datatype="&xsd;string">C2889</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Autoimmune_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Autoimmune_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Dominant_Hereditary_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Dominant_Hereditary_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An inherited disorder that manifests when one copy of a mutated gene is present.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Autosomal Dominant Inherited Disorder</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98829</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Autosomal_Dominant_Hereditary_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Autosomal_Dominant_Hereditary_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An inherited disorder manifested only when two copies of a mutated gene are present.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Autosomal Recessive Inherited Disorder</NCI_PT>
        <ID rdf:datatype="&xsd;string">C85866</ID>
