        <ace_lexicon:CN_pl>Fetal_Warfarin_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Fetal_Warfarin_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


