    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Injury_of_Musculoskeletal_System -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Injury_of_Musculoskeletal_System">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Traumatic_Injury"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98904</ID>
        <NCI_PT rdf:datatype="&xsd;string">Connective and Soft Tissue Injury</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Damage inflicted on the bones and/or soft tissues as the direct or indirect result of an external force, with or without disruption of structural continuity.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Injury_of_Musculoskeletal_Systems</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Injury_of_Musculoskeletal_System</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Inspection_of_palm_crease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Inspection_of_palm_crease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Newborn_Examination"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C89514</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Palmar Crease Examination</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">When examining the infant&apos;s palm for abnormalities, the examiner may note a single transverse palmar crease, which is found in 5% of newborns and is frequently inherited as a familial trait. However, single palmar creases can be associated with Down&apos;s syndrome and other genetic disorders, or with fetal alcohol syndrome.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Inspection_of_palm_creases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Inspection_of_palm_crease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Integumentary_System_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Integumentary_System_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage that begins at birth and continues until twelve complete months of age.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">Any deviation from the normal structure or function of the skin or subcutaneous tissue that is manifested by a characteristic set of symptoms and signs.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3371</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Skin Disorder</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Skin_Disorder; Disorder of Skin</SYN>
        <ace_lexicon:CN_sg>Integumentary_System_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Integumentary_System_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Integumentary_System_Finding -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Integumentary_System_Finding">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Finding"/>
        <ID rdf:datatype="&xsd;string">C36281</ID>
        <NCI_PT rdf:datatype="&xsd;string">Integumentary System Finding</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Skin Finding</SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Symptoms, physical examination results, and/or laboratory test results related to the integumentary system.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Integumentary_System_Finding</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Integumentary_System_Findings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intellectual_Disabilities -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intellectual_Disabilities">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Brain_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A broad category of disorders characterized by an impairment to the intelligence an individual possesses. These impairments can result from trauma, birth or disease and are not restricted to any particular age group.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97250</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intellectual Disability</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Intellectual_Disabilities</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Intellectual_Disabilitieses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intensified_Contraction -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intensified_Contraction">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Uterine_Contraction"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A powerful, temporary tensing of the uterine muscles that is stronger than previously felt movements.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92815</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intense Uterine Contraction</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intensified_Contractions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intensified_Contraction</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intercostal_Retractions -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intercostal_Retractions">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <ID rdf:datatype="&xsd;string">C87087</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intercostal Retractions</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Intercostal_Recession</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The marked inward movement of the muscles between the ribs during inhalation; they indicate that there is reduced pressure in the chest cavity and can be a sign of breathing difficulties.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Intercostal_Retractions</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Intercostal_Retractionses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intermittent_Deceleration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intermittent_Deceleration">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Heart_Rate_Acceleration"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An infrequently repeated decrease in the fetal heart rate that occurs in conjunction with a uterine contraction.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92816</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intermittent Fetal Heart Rate Deceleration</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intermittent_Decelerations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intermittent_Deceleration</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Internal_Fetal_Rotation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Internal_Fetal_Rotation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Finding_during_Childbirth_Labor"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A finding during labor, in which the occiput rotates anteriorly and the head of the fetus assumes an oblique orientation while the fetus descends through the maternal pelvis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92817</ID>
        <NCI_PT rdf:datatype="&xsd;string">Internal Fetal Rotation</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Internal_Fetal_Rotations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Internal_Fetal_Rotation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Interrupted_Aortic_Arch -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Interrupted_Aortic_Arch">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Great_Vessel_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital cardiovascular disorder characterized by the presence of a gap between the ascending and descending portions of the thoracic aorta. This disorder is often associated with ventricular septal defect, ductus arteriosus, or truncus arteriosus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98958</ID>
        <NCI_PT rdf:datatype="&xsd;string">Interrupted Aortic Arch</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Interrupted_Aortic_Arches</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Interrupted_Aortic_Arch</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Interstitial_Emphysema_of_Lung -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Interstitial_Emphysema_of_Lung">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Lung_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C34571</ID>
        <NCI_PT rdf:datatype="&xsd;string">Interstitial Emphysema</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Pathologic accumulation of air in the interstitium of the lungs. It is caused by the rupture of alveoli and terminal bronchioles. It is most often seen in premature infants that need mechanical ventilation for respiratory distress syndrome.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Interstitial_Emphysema_of_Lungs</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Interstitial_Emphysema_of_Lung</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Interstitial_Lung_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Interstitial_Lung_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Chronic_Lung_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C26869</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Chronic progressive interstitial lung disorder characterized by the replacement of the lung tissue by connective tissue, leading to progressive dyspnea, respiratory failure, or right heart failure. Causes include chronic inflammatory processes, exposure to environmental irritants, radiation therapy, autoimmune disorders, certain drugs, or it may be idiopathic (no identifiable cause).</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Fibrosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Interstitial_Lung_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Interstitial_Lung_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intervention_or_Procedure -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intervention_or_Procedure">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Healthcare_Activity"/>
        <NCI_Definition rdf:datatype="&xsd;string">An activity that produces an effect, or that is intended to alter the course of a disease in a patient or population. This is a general term that encompasses the medical, social, behavioral, and environmental acts that can have preventive, therapeutic, or palliative effects.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C25218</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intervention or Procedure</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Procedure</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Intervention_or_Procedure</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Intervention_or_Procedures</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intestinal_Malrotation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intestinal_Malrotation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in which the intestine is abnormally rotated (twisted). It may result in intestinal obstruction.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98961</ID>
        <SYN rdf:datatype="&xsd;string">Congenital Malrotation of Intestine</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Intestinal Malrotation</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intestinal_Malrotations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intestinal_Malrotation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intestinal_Obstruction -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intestinal_Obstruction">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Blockage of the normal flow of the intestinal contents within the bowel.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Bowel Obstruction</NCI_PT>
        <ID rdf:datatype="&xsd;string">C9175</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intestinal_Obstructions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intestinal_Obstruction</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intestinal_Volvulus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intestinal_Volvulus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98963</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intestinal Volvulus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Twisting of a loop of bowel that results in intestinal obstruction.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intestinal_Volvuluses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intestinal_Volvulus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intra_Uterine_Device -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intra_Uterine_Device">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Device"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A device usually made of plastic or metal, inserted into the uterus to prevent conception. IUCD can be a coil, loop, triangle, or T in shape; its material can be impregnated with a pharmaceutical agent. The primary action of all IUCDs is the induction of a foreign-body reaction within the endometrium. This sterile inflammatory process is toxic to gametes, primarily spermatozoa, and effectively prevents viable sperm from passing into the fallopian tubes. The copper-bearing device has an independent toxic effect on spermatozoa. The progestin-releasing devices produce changes in endometrial architecture and function that reduce the potential for implantation of a fertilized egg. The progestin effect on the cervical mucus also reduces the penetrability of sperm.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C42771</ID>
        <NICHD_Definition rdf:datatype="&xsd;string">Intra Uterine Contraceptive Device is a form of birth control that involves an object placed in the uterus to prevent fertilization of the egg by sperm.IUCD can be a coil, loop, triangle, or T in shape; its material can be impregnated with a pharmaceutical agent.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Intrauterine Device</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Intra_Uterine_Devices</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intra_Uterine_Device</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Intracranial_Aneurysm -->

