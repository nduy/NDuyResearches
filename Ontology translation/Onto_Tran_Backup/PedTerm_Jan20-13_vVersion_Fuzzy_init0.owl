    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#TPN_Acquired_Cholestasis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#TPN_Acquired_Cholestasis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cholestasis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98619</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Cholestasis that results from prolonged total parenteral nutrition. It is caused by diminished bile flow from the liver into the duodenum. It may result in cirrhosis and liver failure. Preterm infants are most susceptible to liver damage.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Total Parenteral Nutrition - Associated Cholestasis</NCI_PT>
