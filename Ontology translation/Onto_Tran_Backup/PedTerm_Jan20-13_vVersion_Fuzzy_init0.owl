        <NCI_PT rdf:datatype="&xsd;string">Device</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association1>
        <ace_lexicon:CN_sg>Device</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Devices</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dextro-Transposition_of_the_Great_Vessels">
