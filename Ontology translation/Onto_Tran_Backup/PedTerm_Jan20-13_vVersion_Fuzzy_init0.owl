        <ace_lexicon:CN_sg>Multiple_Hemangiomas</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Multiple_Pregnancy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Multiple_Pregnancy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A gestation with more than one fertilized egg implanted as a viable fetus in the uterus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92931</ID>
        <NCI_PT rdf:datatype="&xsd;string">Multiple Pregnancy</NCI_PT>
