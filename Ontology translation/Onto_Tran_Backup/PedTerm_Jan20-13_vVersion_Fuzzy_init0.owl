        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Leukemoid_Reactions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Leukemoid_Reaction</ace_lexicon:CN_sg>
    </owl:Class>
    


