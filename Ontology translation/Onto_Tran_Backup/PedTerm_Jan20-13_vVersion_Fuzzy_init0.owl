        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Albinism</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Albinisms</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Alcohol_Related_Birth_Defects -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Alcohol_Related_Birth_Defects">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Alcohol_Spectrum_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A physical or cognitive mental abnormality caused by maternal alcohol consumption and its toxic effect on the developing embryo during pregnancy.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Alcohol Related Birth Defect</NCI_PT>
        <ID rdf:datatype="&xsd;string">C92727</ID>
