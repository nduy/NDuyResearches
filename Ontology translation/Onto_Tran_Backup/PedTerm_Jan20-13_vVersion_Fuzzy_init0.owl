    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Cleft_Lip -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Cleft_Lip">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality consisting of one or more clefts (splits) in the upper lip, which may be accompanied by a cleft palate; it is the result of the failure of the embryonic parts of the lip to fuse.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87175</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cleft Lip</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Cleft_Lip</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Cleft_Lips</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Cleft_Palate -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Cleft_Palate">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality consisting of a fissure in the midline of the hard and/or soft palate; it is the result of the failure of the two sides of the palate to fuse during embryonic development.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87069</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cleft Palate</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Cleft_Palates</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Cleft_Palate</ace_lexicon:CN_sg>
    </owl:Class>
    


