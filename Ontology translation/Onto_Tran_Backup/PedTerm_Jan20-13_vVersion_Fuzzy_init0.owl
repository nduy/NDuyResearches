        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A white cheese-like protective material that covers the skin of a fetus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34328</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vernix Caseosa</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vernix_Caseosas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vernix_Caseosa</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vertebral_Abnormalities_Anal_Atresia_Cardiac_Abnormalities_Tracheo-Esophageal_Fistula_Renal_Anomalies_Limb_Defects_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vertebral_Abnormalities_Anal_Atresia_Cardiac_Abnormalities_Tracheo-Esophageal_Fistula_Renal_Anomalies_Limb_Defects_Syndrome">
