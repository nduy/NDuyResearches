        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The shaking movement of the whole body or just a certain part of it, often caused by problems of the neurons responsible for muscle action.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Tremor</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
