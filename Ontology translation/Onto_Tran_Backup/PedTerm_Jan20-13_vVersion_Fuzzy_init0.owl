        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C102971</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cardiac Resuscitation</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Measures performed to restore cardiac function.</NCI_Definition>
