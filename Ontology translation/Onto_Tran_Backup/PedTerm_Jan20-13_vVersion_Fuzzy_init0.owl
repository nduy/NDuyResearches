        <ace_lexicon:CN_sg>Transient_Neonatal_Thrombocytopenia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Transitional_Phase_of_Labor -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Transitional_Phase_of_Labor">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#First_Stage_of_Labor"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92942</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The period during the first stage of labor and childbirth that involves strong uterine contractions and maximal cervical dilatation.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Transition Phase of Labor</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
