</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Postal Code</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Postal_Codes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Postal_Code</ace_lexicon:CN_sg>
    </owl:Class>
    


