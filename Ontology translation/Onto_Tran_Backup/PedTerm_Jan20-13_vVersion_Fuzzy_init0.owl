        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A hereditary or acquired blood disorder characterized by the presence of smaller than normal, sphere-shaped erythrocytes. It results in hemolytic anemia and splenomegaly.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85074</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
