    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Endocardial_Fibroelastosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocardial_Fibroelastosis">
