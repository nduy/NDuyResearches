        <ace_lexicon:CN_sg>Butyryl-CoA_Dehydrogenase_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Caesarean_Hysterectomy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Caesarean_Hysterectomy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hysterectomy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92753</ID>
