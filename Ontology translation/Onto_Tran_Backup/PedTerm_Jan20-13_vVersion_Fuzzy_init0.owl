    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Arteriovenous_Malformation_of_Liver -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Arteriovenous_Malformation_of_Liver">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Circulatory_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormal connection between arteries and veins characterized by the absence of intervening capillaries in the liver.</NCI_Definition>
