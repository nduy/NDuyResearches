        <ace_lexicon:CN_pl>Phocomelias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Phosphoenolpyruvate_Carboxykinase_GTP_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Phosphoenolpyruvate_Carboxykinase_GTP_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A very rare, autosomal recessive inherited disorder caused by deficiency of the enzyme phosphoenolpyruvate carboxykinase, which is involved in gluconeogenesis. It presents with hypoglycemia, failure to thrive, metabolic acidosis, muscle weakness, and hepatomegaly.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99015</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Phosphoenolpyruvate Carboxykinase Deficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Phosphoenolpyruvate_Carboxykinase_GTP_Deficiencies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Phosphoenolpyruvate_Carboxykinase_GTP_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Physical_Examination -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Physical_Examination">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Evaluation_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A systemic evaluation of the body and it&apos;s functions using visual inspection, palpation, percussion and auscultation. The purpose is to determine the presence or absence of physical signs of disease or abnormality for an individual&apos;s health assessment.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C20989</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Physical Examination</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Physical_Examinations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Physical_Examination</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Physical_Maturity_Assessment -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Physical_Maturity_Assessment">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Newborn_Examination"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An examination of the following neonatal attributes: 1) skin texture; 2) lanugo; 3) plantar creases; 4) breast; 5) eyes and ears; 6) genitals, male; and 7) genitals, female. It is a subscore of the Dubowitz/Ballard Examination for Gestational Age.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C89518</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Physical Maturity Assessment</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Physical_Maturity_Assessments</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Physical_Maturity_Assessment</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Physical_Symmetry -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Physical_Symmetry">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Characteristic"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A physical attribute of visual balance and proportion between opposing structures.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81316</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
