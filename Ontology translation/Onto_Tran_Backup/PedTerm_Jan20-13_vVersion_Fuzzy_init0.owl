</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Movement_of_Lip_Corners</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Movement_of_Lip_Cornerses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mucocutaneous_Candidiasis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mucocutaneous_Candidiasis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infectious_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A fungal infection of the skin, nails, oral and vaginal mucosal sites caused by species of the genus Candida. It manifests with white discoloration of the tongue and swelling, redness, and tenderness of the nails.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35576</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mucocutaneous Candidiasis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Mucocutaneous_Candidiasis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Mucocutaneous_Candidiases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mucopolysaccharidosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mucopolysaccharidosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Carbohydrate_Metabolism_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A group of autosomal recessive or X-linked inherited lysosomal storage disorders affecting the metabolism of mucopolysaccharides, resulting in the accumulation of mucopolysaccharides in the body. Signs and symptoms include organomegaly, mental retardation, abnormal skeletal development, heart disorders, hearing loss, and central nervous system deficiencies.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C61259</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mucopolysaccharidosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Mucopolysaccharidoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Mucopolysaccharidosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mucous_Connective_Tissue -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mucous_Connective_Tissue">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Biological_Substance"/>
        <NCI_Definition rdf:datatype="&xsd;string">A gelatinous type of connective tissue that is found in the umbilical cord.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34213</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mucous Connective Tissue</NCI_PT>
