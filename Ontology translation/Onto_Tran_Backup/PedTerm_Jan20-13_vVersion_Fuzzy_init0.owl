    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Cafe_Au_Lait_Spot -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Cafe_Au_Lait_Spot">
