        <ace_lexicon:CN_sg>Surfactant_Apoprotein_ABCA3_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Surfactant_Apoprotein_A_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Surfactant_Apoprotein_A_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Surfactant_Apoprotein_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99072</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Deficiency of surfactant protein A. When present in normal amounts, this protein protects the lungs against a variety of bacteria, viruses, and fungi.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Surfactant Protein A Deficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Surfactant_Apoprotein_A_Deficiencies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Surfactant_Apoprotein_A_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


