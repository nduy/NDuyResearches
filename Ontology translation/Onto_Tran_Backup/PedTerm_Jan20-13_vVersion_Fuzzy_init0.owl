        <ace_lexicon:CN_pl>Injury_of_Heads</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Injury_of_Integument -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Injury_of_Integument">
