        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A sporadic or inherited disorder characterized by the focal or diffuse proliferation of the cells of the islets of Langerhans in the pancreas. It results in hyperinsulinemia and hypoglycemia.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C4375</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
