    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Cytochrome-C_Oxidase_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Cytochrome-C_Oxidase_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A very rare inherited metabolic disorder characterized by deficiency of the enzyme cytochrome-C oxidase. It may be manifested as an isolated myopathy or a systemic disorder. Signs and symptoms include myotonia, dysfunction of the heart, kidney, and brain, and lactic acidosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98910</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cytochrome-C Oxidase Deficiency</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Cytochrome-C_Oxidase_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Cytochrome-C_Oxidase_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dandy-Walker_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dandy-Walker_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital brain malformation disorder characterized by agenesis or hypoplasia of the cerebellar vermis, cystic dilatation of the fourth ventricle, and enlargement of the posterior fossa.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75012</ID>
        <NCI_PT rdf:datatype="&xsd;string">Dandy-Walker Malformation</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Dandy-Walker_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Dandy-Walker_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


