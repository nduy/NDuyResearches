        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98893</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Diaphragmatic Hernia</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Diaphragmatic hernia that is present at birth.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
