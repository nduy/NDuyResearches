    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Deflexed_Attitude -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Deflexed_Attitude">
