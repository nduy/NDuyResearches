</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Cystic_Hygroma</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Cystic_Hygromas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Cystic_Periventricular_Leukomalacia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Cystic_Periventricular_Leukomalacia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Periventricular_Leukomalacia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99112</ID>
