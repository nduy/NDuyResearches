        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pregnancy Time Period</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The duration of pregnancy from conception to childbirth.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pregnancy_Time_Periods</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pregnancy_Time_Period</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Prekallikrein_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Prekallikrein_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Coagulation_Factor_Deficiency_Syndrome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition characterized by the congenital or acquired deficiency of prekallikrein. This deficiency is usually not associated with bleeding. The congenital deficiency is very rare. Acquired deficiency may occur in diffuse intravascular coagulation, infections, and sickle cell disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99022</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Prekallikrein Deficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Prekallikrein_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Prekallikrein_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Premature_Closure_of_the_Ductus_Arteriosus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Premature_Closure_of_the_Ductus_Arteriosus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Great_Vessel_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99024</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Closure of the ductus arteriosus in utero. It results in pulmonary hypertension and right ventricular hypertrophy.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Premature Closure of the Ductus Arteriosus</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Premature_Closure_of_the_Ductus_Arteriosuses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Premature_Closure_of_the_Ductus_Arteriosus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Premature_Labor -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Premature_Labor">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Complication"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C50917</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Ouster of a viable infant before the normal end of gestation, commonly defined as interruption of pregnancy between the twentieth-thirty seventh completed weeks after the onset of the last menstrual cycle.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Premature Labor</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Premature_Labors</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Premature_Labor</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Premature_Rupture_of_Membranes -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Premature_Rupture_of_Membranes">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Complication"/>
        <ID rdf:datatype="&xsd;string">C87113</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">PROM</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Premature Rupture of Membrane</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The condition when a patient who is beyond 37 weeks gestation presents with rupture of membranes prior to the onset of labor. Rupture of membranes is diagnosed by speculum vaginal examination of the cervix and vaginal cavity, which will show pooling of fluid in the vagina or leakage of fluid from the cervix. Preterm PROM (known as PPROM) refers to a patient who has not yet reached 37 weeks gestation and presents with rupture of membranes.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Premature_Rupture_of_Membraneses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Premature_Rupture_of_Membranes</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Prenatal -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Prenatal">
