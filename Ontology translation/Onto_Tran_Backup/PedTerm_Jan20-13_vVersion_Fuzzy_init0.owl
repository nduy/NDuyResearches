        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The length of time from the beginning to the end of a single uterine contraction during the labor and childbirth process.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Duration_of_Contraction</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Duration_of_Contractions</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dwarfism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dwarfism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C34554</ID>
        <NCI_PT rdf:datatype="&xsd;string">Dwarfism</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Short stature that usually results from genetic mutations. Other causes include hormonal deficiencies and poor nutrition.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Dwarfisms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Dwarfism</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dyscalculia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dyscalculia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Learning_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A wide group of related learning disorders characterized by difficulties with mathematics and manipulating numbers; the difficulty with math may be caused or exacerbated by visuo-spatial or language processing difficulties.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97165</ID>
        <NCI_PT rdf:datatype="&xsd;string">Dyscalculia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Dyscalculia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Dyscalculias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dyslexia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dyslexia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Learning_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A learning disorder characterized by an impairment in processing written words. Reading difficulties can include distortions, omissions or substitutions of characters. Oral and silent reading difficulties can include faulty and slow comprehension.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96410</ID>
        <NCI_PT rdf:datatype="&xsd;string">Dyslexia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Dyslexia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Dyslexias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ear_Dimple -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ear_Dimple">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <NCI_Definition rdf:datatype="&xsd;string">A pit or dimple in front of the ear of a newborn is a common finding; rarely, such a dimple may get infected, which will be manifested with redness and swelling and will require medical attention.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87071</ID>
        <NCI_PT rdf:datatype="&xsd;string">Ear Dimple</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Ear_Pit</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ear_Dimple</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ear_Dimples</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Early_Adolescence -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Early_Adolescence">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Adolescence"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage that begins at twelve years of age and continues until eighteen complete years of age. This phase marks the start of physical, physiological and psychological changes that characterize pubertal growth and development.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A transitional time in an individual&apos;s life between childhood and adolescence. This phase marks the start of physical, physiological and psychological changes that characterize pubertal growth and development.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C89331</ID>
        <NCI_PT rdf:datatype="&xsd;string">Early Adolescence</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Early_Adolescences</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Early_Adolescence</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Early_Childhood -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Early_Childhood">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Child_Life_Stage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage that begins at two years of age and continues until five complete years of age.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A time period in a child&apos;s life that is accepted to be approximately between 1 and 5 years of age.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C89346</ID>
        <NCI_PT rdf:datatype="&xsd;string">Early Childhood</NCI_PT>
