        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99068</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Deficiency of surfactant protein B. It presents with severe respiratory distress-like illness and responds poorly to exogenous administration of surfactant.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Surfactant Protein B Deficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Surfactant_Apoprotein_B_Deficiencies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Surfactant_Apoprotein_B_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Surfactant_Apoprotein_C_Deficiency -->

