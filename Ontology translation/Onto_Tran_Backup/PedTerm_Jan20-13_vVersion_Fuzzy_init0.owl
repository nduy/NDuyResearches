</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Placental Duncan Mechanism</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The expulsion of the placenta with presentation of the maternal rough side first, rather than the usual fetal side of the placenta.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Duncan_Mechanisms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Duncan_Mechanism</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Duodenal_Band -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Duodenal_Band">
