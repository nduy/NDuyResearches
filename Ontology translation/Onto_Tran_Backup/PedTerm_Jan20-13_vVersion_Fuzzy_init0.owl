    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Diaphragmatic_Hernia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Diaphragmatic_Hernia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hernia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital or acquired weakness or opening in the diaphragm which allows abdominal contents to protrude into the chest cavity; congenital diaphragmatic hernias are caused when the embryonic diaphragm fails to fuse.</NCI_Definition>
