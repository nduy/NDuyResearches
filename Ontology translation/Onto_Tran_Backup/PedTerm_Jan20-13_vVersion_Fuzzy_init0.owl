    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Valproate_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Valproate_Syndrome">
