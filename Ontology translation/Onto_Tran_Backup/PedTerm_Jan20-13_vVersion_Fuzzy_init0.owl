        <ace_lexicon:CN_pl>Signs_or_Symptomses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sinciput -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sinciput">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Position"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A fetal position during delivery in which the frontal part of the skull including forehead and the top of the head is first to descend into the birth canal.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92882</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
