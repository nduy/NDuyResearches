    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Cerebellar_Hypoplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Cerebellar_Hypoplasia">
