    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Biliary_Atresia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Biliary_Atresia">
