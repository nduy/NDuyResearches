        <ID rdf:datatype="&xsd;string">C101338</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The formation of a thrombus in the artery as a direct result of an activity associated with vascular access.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Acquired_Secondary_Arterial_Thrombosis_due_to_Catheter_Complications</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Acquired_Secondary_Arterial_Thrombosis_due_to_Catheter_Complication</ace_lexicon:CN_sg>
