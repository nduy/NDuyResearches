        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Device"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A contraceptive device in the shape of a ring composed of active and/or inert ingredient(s), intended for administration in or around the vagina, to prevent conception.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A ring composed of active and/or inert ingredient(s), intended for administration in or around the vagina.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C91199</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
