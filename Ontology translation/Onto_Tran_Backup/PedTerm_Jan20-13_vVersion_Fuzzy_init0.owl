    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Van_Der_Woude_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Van_Der_Woude_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal dominant syndrome caused by mutations in the IRF6 gene. It is characterized by a cleft palate and/or pits on the lower lip. Other signs and symptoms include absent teeth, palate and tongue deformities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C74986</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
