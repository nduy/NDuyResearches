        <ace_lexicon:CN_pl>Depressions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Depression</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dermoid_Cyst -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dermoid_Cyst">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cyst"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A mature teratoma characterized by the presence of a cyst which is lined by mature tissue resembling the epidermis and the epidermal appendages. It occurs in the ovary, testis, and extragonadal sites including central nervous system and skin.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C9011</ID>
        <NCI_PT rdf:datatype="&xsd;string">Dermoid Cyst</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Dermoid_Cyst</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Dermoid_Cysts</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Development_of_Corpus_Luteum -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Development_of_Corpus_Luteum">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Reproductive_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92923</ID>
        <NCI_PT rdf:datatype="&xsd;string">Development of Corpus Luteum</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The process by which the ovarian follicle becomes the corpus luteum. It occurs after ovulation.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Development_of_Corpus_Luteums</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Development_of_Corpus_Luteum</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Coordination_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Coordination_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neurodevelopmental_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder characterized by an impairment in the development of an individual&apos;s motor coordination skills; this impairment in motor development is not due to a medical condition.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92561</ID>
        <NCI_PT rdf:datatype="&xsd;string">Developmental Coordination Disorder</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Developmental Dyspraxia</SYN>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Developmental_Coordination_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Developmental_Coordination_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pediatric_Disease_or_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder diagnosed in childhood that is marked by either physical or mental impairment or both, which in turn affects the child from achieving age related developmental milestones.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C89330</ID>
        <NCI_PT rdf:datatype="&xsd;string">Developmental Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Developmental_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Developmental_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Milestones -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Milestones">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Observational_Result"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <ID rdf:datatype="&xsd;string">C90342</ID>
        <NCI_PT rdf:datatype="&xsd;string">Developmental Milestone</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Physical or behavioral signs of maturation or skills gained by a developing child, which should be achieved by a given age that provide important information regarding the child&apos;s development. The milestones are different for each age range. Failure to achieve a particular milestone by a given age is indicative of developmental delay.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Developmental_Milestoneses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Developmental_Milestones</ace_lexicon:CN_sg>
    </owl:Class>
    


