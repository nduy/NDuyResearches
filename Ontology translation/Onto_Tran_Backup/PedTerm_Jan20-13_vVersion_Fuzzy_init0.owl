        <ace_lexicon:CN_sg>Tremor</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tricuspid_Valve_Regurgitation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tricuspid_Valve_Regurgitation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Valve_Regurgitation"/>
