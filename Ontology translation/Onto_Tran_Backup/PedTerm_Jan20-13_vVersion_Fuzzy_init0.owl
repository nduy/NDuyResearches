</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Fused_Eyelids</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Fused_Eyelid</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#G-6-PD_Variant_Enzyme_Deficiency_Anemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#G-6-PD_Variant_Enzyme_Deficiency_Anemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
        <NCI_Definition rdf:datatype="&xsd;string">An X-linked recessive inherited disorder caused by mutations in the G6PD gene. It is characterized by the absence or presence of very low levels of glucose-6-phosphate dehydrogenase. Patients develop hemolytic anemia usually in response to infection or exposure to drugs.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98933</ID>
        <SYN rdf:datatype="&xsd;string">G6PD</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Glucose-6-Phosphate Dehydrogenase Deficiency</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>G-6-PD_Variant_Enzyme_Deficiency_Anemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>G-6-PD_Variant_Enzyme_Deficiency_Anemias</ace_lexicon:CN_pl>
    </owl:Class>
    


