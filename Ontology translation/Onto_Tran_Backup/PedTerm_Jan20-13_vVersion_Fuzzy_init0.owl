        <ace_lexicon:CN_sg>Phenylketonuria</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Phocomelia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Phocomelia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital malformation in which the upper portion of a limb is either shortened or absent.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34928</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
