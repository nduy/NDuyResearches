        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">A diagnostic or treatment procedure performed by manual and/or instrumental means, often involving an incision and the removal or replacement of a diseased organ or tissue; of or relating to or involving or used in surgery or requiring or amenable to treatment by surgery.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C15329</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Surgical Procedure</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
