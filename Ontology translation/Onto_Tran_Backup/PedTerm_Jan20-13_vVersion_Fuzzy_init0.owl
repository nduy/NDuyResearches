    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Thanatophoric_Dysplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Thanatophoric_Dysplasia">
