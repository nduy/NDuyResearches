    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Carnitine_Palmitoyltransferase_I_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Carnitine_Palmitoyltransferase_I_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive inherited disorder caused by mutations in the CPT1A gene. It is characterized by the presence of defective carnitine palmitoyltransferase 1A which is involved in fatty acid oxidation. Signs and symptoms may be exacerbated during fasting and include hypoketotic hypoglycemia, increased levels of carnitine in the blood, hepatomegaly, seizures, and coma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98871</ID>
        <NCI_PT rdf:datatype="&xsd;string">Carnitine Palmitoyltransferase I Deficiency</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Carnitine_Palmitoyltransferase_I_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Carnitine_Palmitoyltransferase_I_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Carpenter__s_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Carpenter__s_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly"/>
        <SYN rdf:datatype="&xsd;string">Acrocephalopolysyndactyly Type II</SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An extremely rare autosomal recessive inherited syndrome characterized by premature closure of cranial sutures leading to cone-shaped head, fusion of the digits, and the presence of more digits than normal. It may be associated with heart defects, single horseshoe-shaped kidney, short stature, undescended testes, and mild mental retardation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98873</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Type II Acrocephalopolysyndactyly</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Carpenter__s_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Carpenter__s_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Cataract -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Cataract">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vision_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C26713</ID>
