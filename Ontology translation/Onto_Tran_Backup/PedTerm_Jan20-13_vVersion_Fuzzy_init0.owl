    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Shoulder_Presentation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Shoulder_Presentation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Malpresentation_of_Fetus"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
