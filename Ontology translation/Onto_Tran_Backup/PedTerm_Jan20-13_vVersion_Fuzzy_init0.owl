        <ace_lexicon:CN_sg>Discordant_Ventriculoarterial_Connection</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder">
        <NCI_Definition rdf:datatype="&xsd;string">Any abnormal condition of the body or mind that causes discomfort, dysfunction, or distress to the person affected or those in contact with the person. The term is often used broadly to include injuries, disabilities, syndromes, symptoms, deviant behaviors, and atypical variations of structure and function.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2991</ID>
        <SYN rdf:datatype="&xsd;string">Disease</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Disease or Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_sg>Disease_or_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Disease_or_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Dislocation_of_Hip_Joint -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Dislocation_of_Hip_Joint">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital or traumatic abnormality in which the femoral head slips out of the acetabulum.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34698</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hip Dislocation</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Dislocation_of_Hip_Joint</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Dislocation_of_Hip_Joints</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Disseminated_Intravascular_Coagulation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Disseminated_Intravascular_Coagulation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Coagulation_Defect"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A pathological process where the blood starts to coagulate throughout the whole body. This depletes the body of its platelets and coagulation factors, and there is an increased risk of hemorrhage.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2992</ID>
        <NCI_PT rdf:datatype="&xsd;string">Disseminated Intravascular Coagulation</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Disseminated_Intravascular_Coagulations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Disseminated_Intravascular_Coagulation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Doctor_s_Information -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Doctor_s_Information">
