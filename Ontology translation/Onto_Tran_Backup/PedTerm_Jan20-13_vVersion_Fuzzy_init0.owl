        <ace_lexicon:CN_sg>Chondrodysplasia_Punctata_Stippled_Epiphyses_Group</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chondroectodermal_Dysplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chondroectodermal_Dysplasia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive syndrome caused by mutations in the EVC gene. It is characterized by dwarfism, small chest, ectodermal dysplasia, and postaxial polydactyly. There is an increased frequency of congenital heart malformations.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84684</ID>
        <NCI_PT rdf:datatype="&xsd;string">Ellis-Van Creveld Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Chondroectodermal_Dysplasias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Chondroectodermal_Dysplasia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chorioamnionitis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chorioamnionitis">
