        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Agenesis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Absence_of_Lung</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Absence_of_Lungs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Absence_of_Penis -->

