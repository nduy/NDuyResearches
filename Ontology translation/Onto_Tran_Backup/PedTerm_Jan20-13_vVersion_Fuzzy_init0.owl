    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Child_Life_Stage">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Life_Stage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A time period that begins at the beginning of the human embryonic stage and continues until the end of adolescence.</NICHD_Definition>
