        <NCI_PT rdf:datatype="&xsd;string">Pappalysin-1</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Pappalysin-1 (1627 aa, ~181 kDa) is encoded by the human PAPPA gene. This protein is involved in the modulation of proteolysis.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pregnancy_Associated_Plasma_Protein_A</ace_lexicon:CN_sg>
