        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Denver_Development_Screening_Test</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Denver_Development_Screening_Tests</ace_lexicon:CN_pl>
    </owl:Class>
    


