    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Perforation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Perforation">
