        <NCI_PT rdf:datatype="&xsd;string">Cardiotocography</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Electronic fetal monitoring; continuous cardiotocography (CTG); intrapartum CTG</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The monitoring of both maternal uterine contractions and fetal heart rate during the process of labor and delivery.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intrapartum_Cardiotocographies</ace_lexicon:CN_pl>
