        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An intentional cut made to an individual&apos;s body with the intent of performing a diagnostic or therapeutic intervention.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C15384</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Surgical Incision</NCI_PT>
