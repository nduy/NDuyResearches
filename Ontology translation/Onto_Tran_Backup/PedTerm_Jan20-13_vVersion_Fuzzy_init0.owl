        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Mucus_Plug</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Mucus_Plugs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mui -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mui">
