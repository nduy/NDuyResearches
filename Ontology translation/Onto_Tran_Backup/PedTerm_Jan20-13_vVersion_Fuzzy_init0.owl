        <ace_lexicon:CN_pl>Peroxisomal_Function_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Cloaca -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Cloaca">
