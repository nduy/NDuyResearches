    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Incontinentia_Pigmenti_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Incontinentia_Pigmenti_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Skin"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare disorder caused by mutations in the IKBKG gene. It is characterized by skin abnormalities, alopecia, dystrophic nails, and abnormal tooth shape. The skin changes evolve from an initial blistering rash, to wart-like lesions, and eventually to hypopigmentation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84787</ID>
        <NCI_PT rdf:datatype="&xsd;string">Incontinentia Pigmenti</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Incontinentia_Pigmenti_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Incontinentia_Pigmenti_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


