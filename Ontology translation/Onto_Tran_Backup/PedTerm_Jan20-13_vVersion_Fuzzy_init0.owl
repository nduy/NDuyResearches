    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Measles -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Measles">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Childhood_Viral_Disease"/>
        <NCI_Definition rdf:datatype="&xsd;string">A highly contagious viral infection caused by the measles virus. Symptoms appear 8-12 days after exposure and include a rash, cough, fever and muscle pains that can last 4-7 days. Measles vaccines are available to provide prophylaxis, usually combined with mumps and rubella vaccines (MMR).</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96406</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <SYN rdf:datatype="&xsd;string">Rubeola</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Rubeola Infection</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Measleses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Measles</ace_lexicon:CN_sg>
    </owl:Class>
    


