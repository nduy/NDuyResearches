        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An inflammatory process that affects the choroid.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35111</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Posterior Uveitis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Choroiditises</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Choroiditis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chromosome_Abnormality -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chromosome_Abnormality">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An irregularity in the number or structure of chromosomes, usually in the form of a gain (duplication), loss (deletion), exchange (translocation), or alteration in sequence (inversion) of genetic material.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2950</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cytogenetic Abnormality</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Chromosome_Abnormality</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Chromosome_Abnormalities</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chronic_Lung_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chronic_Lung_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Lung_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic disorder of the lungs. Representative examples include chronic obstructive A persistent non-neoplastic disorder of the lungs. Representative examples include: chronic obstructive pulmonary disease, chronic bronchitis, emphysema, pulmonary fibrosis, pneumoconiosis, asbestosis, atelectasis, radiation induced pneumonitis, and radiation fibrosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98541</ID>
        <NCI_PT rdf:datatype="&xsd;string">Chronic Lung Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">Chronic lung disease (CLD) is a general term for long-term respiratory problems in premature babies. It is also known as bronchopulmonary dysplasia (BPD).Chronic lung disease is a condition in which damaged tissue in a newborn baby&apos;s lungs causes breathing and health problems. The lungs trap air or collapse, fill with fluid, and produce extra mucus.</NICHD_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Chronic_Lung_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Chronic_Lung_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chylothorax -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chylothorax">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pleural_Effusion"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A milky pleural effusion resulting from accumulation of lymph fluid in the pleural cavity. Causes include malignancies (usually lymphoma), trauma to the thoracic duct, tuberculosis, sarcoidosis, and congenital causes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C79546</ID>
        <NCI_PT rdf:datatype="&xsd;string">Chylothorax</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Chylothorax</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Chylothoraxes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Circumcision -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Circumcision">
