        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The formation of a thrombus in the vein as a direct result of an activity associated with vascular access.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Venous Thrombosis due to Vascular Access Complication</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
