        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic or neoplastic disorder that affects the gastrointestinal tract, anus, liver, biliary system, and pancreas.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2990</ID>
        <SYN rdf:datatype="&xsd;string">Digestive_System_Disorder; Disorder of Digestive System</SYN>
