        <ID rdf:datatype="&xsd;string">C50843</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The backflow of blood from the right ventricle into the right atrium, owning to imperfect functioning/insufficiency of the tricuspid valve.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Tricuspid Regurgitation</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
