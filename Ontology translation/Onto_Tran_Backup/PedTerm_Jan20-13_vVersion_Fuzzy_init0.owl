        <ace_lexicon:CN_sg>Transverse_Fetal_Presentation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Transverse_Occiput -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Transverse_Occiput">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Position"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A fetal position during delivery in which the face is towards one of the mother&apos;s thighs while descending into the birth canal.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92899</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
