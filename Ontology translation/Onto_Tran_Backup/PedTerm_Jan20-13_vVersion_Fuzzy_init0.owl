    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Placenta_Previa -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Placenta_Previa">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Complication"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition in which the placenta is implanted in the lower part of the uterus. --2003</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26858</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
