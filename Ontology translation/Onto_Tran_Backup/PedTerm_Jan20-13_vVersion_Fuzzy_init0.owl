        <ace_lexicon:CN_pl>Persistent_Cloacas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Fetal_Bradycardia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Fetal_Bradycardia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Bradycardia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A decrease in the fetal heart beat rate below 110 per minute or below the normal baseline value expected for the particular fetal age for a period of more than 10 minutes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92842</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
