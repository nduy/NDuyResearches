    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Severe_Bronchopulmonary_Dysplasia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Bronchopulmonary_Dysplasia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Bronchopulmonary dysplasia that results in severe respiratory complications. The infants with severe symptoms are usually premature, have low birth weight, and the oxygen and ventilation support requirements are increased.</NCI_Definition>
