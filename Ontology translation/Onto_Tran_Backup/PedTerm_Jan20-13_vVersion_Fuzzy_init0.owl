        <NCI_PT rdf:datatype="&xsd;string">Varicella Zoster Infection</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Varicella-Zoster_Virus_Infections</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Varicella-Zoster_Virus_Infection</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Varicella_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Varicella_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine"/>
        <NCI_Definition rdf:datatype="&xsd;string">A live attenuated virus vaccine used to prevent chickenpox and shingles, which is caused by varicella-zoster virus (VZV).</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96395</ID>
        <SYN rdf:datatype="&xsd;string">Chickenpox Vaccine; Shingles Vaccine</SYN>
