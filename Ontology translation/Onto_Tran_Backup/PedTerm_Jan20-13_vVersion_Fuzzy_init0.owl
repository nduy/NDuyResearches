    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Coloboma_Heart_Malformation_Choanal_Atresia_Retardation_of_Growth_and_Development_Genital_Abnormalities_and_Ear_Malformations_HARGE_Association -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Coloboma_Heart_Malformation_Choanal_Atresia_Retardation_of_Growth_and_Development_Genital_Abnormalities_and_Ear_Malformations_HARGE_Association">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal dominant syndrome usually caused by mutations in the CHD7 gene. The term CHARGE is an acronym for the following unusual congenital abnormalities that are associated with this syndrome: coloboma of the eye, heart defects, choanal atresia, growth and developmental retardation, genital, and ear abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75100</ID>
        <NCI_PT rdf:datatype="&xsd;string">CHARGE Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Coloboma_Heart_Malformation_Choanal_Atresia_Retardation_of_Growth_and_Development_Genital_Abnormalities_and_Ear_Malformations_HARGE_Associations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Coloboma_Heart_Malformation_Choanal_Atresia_Retardation_of_Growth_and_Development_Genital_Abnormalities_and_Ear_Malformations_HARGE_Association</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Coloboma_of_Eyelid -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Coloboma_of_Eyelid">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fundus_Coloboma"/>
