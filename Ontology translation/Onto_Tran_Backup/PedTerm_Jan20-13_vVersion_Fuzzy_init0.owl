        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Antithrombin_III_Deficiencies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Antithrombin_III_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


