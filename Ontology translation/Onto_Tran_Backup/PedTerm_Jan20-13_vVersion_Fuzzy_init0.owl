    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chiari_Malformation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chiari_Malformation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare genetic brain malformation characterized by displacement of the brain stem and cerebellum through the foramen magnum. It may result in hydrocephalus.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Arnold-Chiari Malformation</NCI_PT>
        <ID rdf:datatype="&xsd;string">C84570</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Chiari_Malformation</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Chiari_Malformations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chicken_Pox -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chicken_Pox">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Childhood_Viral_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A contagious childhood disorder caused by the varicella zoster virus. It is transmitted via respiratory secretions and contact with chickenpox blister contents. It presents with a vesicular skin rush, usually associated with fever, headache, and myalgias. The pruritic fluid-filled vesicles occur 10-21 days after exposure and last for 3-4 days. An additional 3-4 days of malaise follows before the affected individual feels better. An individual is contagious 1-2 days prior to the appearance of the blisters until all blisters are crusted over. Generally, healthy individuals recover without complications.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97132</ID>
        <NCI_PT rdf:datatype="&xsd;string">Chicken Pox Infection</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Chicken_Poxes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Chicken_Pox</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Chickenpox_Immunization -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chickenpox_Immunization">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Immunization"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92915</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The administration of a live attenuated viral vaccine to prevent herpes zoster infection.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Varicella Zoster Virus Immunization</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Chickenpox_Immunizations</ace_lexicon:CN_pl>
