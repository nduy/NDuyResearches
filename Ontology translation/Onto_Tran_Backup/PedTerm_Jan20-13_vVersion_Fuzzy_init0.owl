    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Central_Hypoventilation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Central_Hypoventilation">
