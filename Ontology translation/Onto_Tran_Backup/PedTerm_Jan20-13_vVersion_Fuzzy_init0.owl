</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Diastematomyelia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Diastematomyelias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Digestive_System_Finding -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Digestive_System_Finding">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C36279</ID>
