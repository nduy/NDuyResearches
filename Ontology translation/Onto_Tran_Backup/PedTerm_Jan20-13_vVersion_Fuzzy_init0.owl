    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Multiple_Hemangiomas">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hemangioma"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A benign diffuse vascular neoplasm usually occurring in young adults. It is characterized by the formation of capillary-sized and cavernous vascular spaces. Patients present with diffuse persistent swelling.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Angiomatosis</NCI_PT>
        <ID rdf:datatype="&xsd;string">C27503</ID>
