        <NCI_Definition rdf:datatype="&xsd;string">A gliding joint between the distal ends of the tibia and fibula and the proximal end of the talus.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Ankle Joint</NCI_PT>
        <ID rdf:datatype="&xsd;string">C32078</ID>
