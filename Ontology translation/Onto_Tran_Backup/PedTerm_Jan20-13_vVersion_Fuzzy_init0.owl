        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare, genetically heterogenous syndrome, characterized by cryptophthalmos, craniofacial abnormalities, urogenital abnormalities, and syndactyly.</NCI_Definition>
