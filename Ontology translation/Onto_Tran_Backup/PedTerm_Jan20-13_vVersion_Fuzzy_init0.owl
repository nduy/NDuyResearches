    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Arrhythmia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ventricular_Arrhythmia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiac_Arrhythmia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An electrocardiographic finding of an atypical cardiac rhythm resulting from a pathologic process in the cardiac ventricles.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26924</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Ventricular Arrhythmia</NCI_PT>
