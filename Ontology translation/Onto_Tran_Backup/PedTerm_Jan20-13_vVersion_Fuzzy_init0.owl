    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Impending_Labor -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Impending_Labor">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Reproductive_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92813</ID>
        <NCI_PT rdf:datatype="&xsd;string">Impending Labor</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The period of time prior to the beginning of childbirth labor; common signs and symptoms include nesting, anxiety, excitement, loss of mucous plug, increased urinary frequency and loose bowel movements.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Impending_Labor</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Impending_Labors</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Imperforate_Anus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Imperforate_Anus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Digestive_System"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital birth defect characterized by the absence of a normal anal opening. It may be associated with other congenital abnormalities.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Anal Atresia</SYN>
        <ID rdf:datatype="&xsd;string">C84784</ID>
        <NCI_PT rdf:datatype="&xsd;string">Imperforate Anus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Imperforate_Anuses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Imperforate_Anus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#In-utero_Drug_Withdrawal -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#In-utero_Drug_Withdrawal">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A substance-abuse withdrawal syndrome in a fetus following maternal discontinuation or reduction of use of one or more addictive substance(s) that have caused fetal physiological dependence. Signs and symptoms are characteristic of withdrawal syndromes and may affect fetal growth.</NICHD_Definition>
        <ID rdf:datatype="&xsd;string">C103183</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Drug withdrawal symptoms in a fetus following maternal discontinuation or reduction of use of one or more addictive substance(s) that have caused fetal physiological dependence.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">In utero Drug Withdrawal</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_sg>In-utero_Drug_Withdrawal</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>In-utero_Drug_Withdrawals</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#In_Utero_Bowel_Perforation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#In_Utero_Bowel_Perforation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Perforation_of_Intestine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Bowel perforation in utero, caused by bowel obstruction. It results in meconium peritonitis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99121</ID>
        <NCI_PT rdf:datatype="&xsd;string">In Utero Bowel Perforation</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">In utero bowel perforation is a rupture of the bowel prior to birth, resulting in fetal stool (meconium) escaping into the surrounding space (peritoneum) leading to inflammation (peritonitis). It results in meconium peritonitis.</NICHD_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>In_Utero_Bowel_Perforations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>In_Utero_Bowel_Perforation</ace_lexicon:CN_sg>
    </owl:Class>
    


