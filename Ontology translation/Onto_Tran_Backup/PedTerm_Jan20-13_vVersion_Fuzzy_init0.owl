        <ID rdf:datatype="&xsd;string">C81278</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hemoglobin C to Total Hemoglobin Ratio Measurement</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The determination of the ratio of Hemoglobin C compared to total Hemoglobin present in a sample. The measurement may be expressed as a ratio or percentage.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
