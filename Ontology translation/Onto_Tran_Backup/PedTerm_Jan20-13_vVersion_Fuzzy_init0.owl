        <ID rdf:datatype="&xsd;string">C101194</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Cataract in both eyes that are present at birth.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Cataract, Congenital, Bilateral</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Bilateral Cataracts</NCI_PT>
