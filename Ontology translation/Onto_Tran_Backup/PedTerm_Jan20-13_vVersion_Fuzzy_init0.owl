        <ID rdf:datatype="&xsd;string">C98890</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Cerebellar Hypoplasia</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Hypoplasia of the cerebellum that is associated with inherited metabolic disorders and neurodegenerative disorders. Signs and symptoms include mental and developmental delays, walking and balance difficulties, floppy muscle tone, and seizures.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Cerebellar_Hypoplasias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Cerebellar_Hypoplasia</ace_lexicon:CN_sg>
    </owl:Class>
    


