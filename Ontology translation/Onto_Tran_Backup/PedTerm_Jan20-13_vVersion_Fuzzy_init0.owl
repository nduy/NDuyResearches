        <NCI_Definition rdf:datatype="&xsd;string">A congenital disorder characterized by abnormalities in the development of the sexual characteristics.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C103186</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Sexual Differentiation</SYN>
