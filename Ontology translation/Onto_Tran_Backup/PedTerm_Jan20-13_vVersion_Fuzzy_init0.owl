        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hemoglobinopathy"/>
        <NCI_Definition rdf:datatype="&xsd;string">A blood disorder characterized by the appearance of sickle-shaped red blood cells and anemia.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34383</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sickle Cell Disease</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Sickling_Disorder_due_to_Hemoglobin_S; Hereditary Hemoglobinopathy Disorder Homozygous for Hemoglobin S</SYN>
