        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A drug implant that acts as a birth control device and which is inserted under the skin for drug delivery into the body.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92759</ID>
        <NCI_PT rdf:datatype="&xsd;string">Contraceptive Implant</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Contraceptive_Implants</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Contraceptive_Implant</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Patch -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Patch">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Device"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A a medicated adhesive patch that is placed on the skin to deliver estrogen and progestin hormones for release and absorption through the skin and into the body to prevent pregnancy.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A dermal patch that contains estrogen and progestin hormones for release and absorption through the skin and into the body to prevent pregnancy.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92760</ID>
        <NCI_PT rdf:datatype="&xsd;string">Contraceptive Patch</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Contraceptive_Patches</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Contraceptive_Patch</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Sponge -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Sponge">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraceptive_Device"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A contraceptive device, made of plastic, contains an antispermicidal agent, designed to be placed into the vaginal canal to prevent live sperm from entering the uterus.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A sponge impregnated with an antispermicidal agent; it is designed to be placed into the vaginal canal to prevent live sperm from entering the uterus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C69055</ID>
        <NCI_PT rdf:datatype="&xsd;string">Contraceptive Sponge</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Contraceptive_Sponges</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Contraceptive_Sponge</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Contraction_Frequency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraction_Frequency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Quantitative_Concept"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92905</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The number of uterine contractions recorded over a period of time, usually in minutes; measured from the start of one contraction to the start of the next.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Uterine Contraction Frequency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Contraction_Frequencies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Contraction_Frequency</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Contraction_Intensity -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Contraction_Intensity">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Quantitative_Concept"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92906</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The duration of an uterine contraction expressed as mmHg.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Uterine Contraction Intensity</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Contraction_Intensities</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Contraction_Intensity</ace_lexicon:CN_sg>
    </owl:Class>
    


