        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage, during prenatal development, that typically begins at the beginning of nine weeks after fertilization (full formation of the embryo) and continues until birth.</NICHD_Definition>
