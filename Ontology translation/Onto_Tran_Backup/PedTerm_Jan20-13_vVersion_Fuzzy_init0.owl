        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">One of two possible results of a pass/fail assessment; when the result satisfies a condition.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Pass</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Passes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pass</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Passing_of_Mucus_Plug -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Passing_of_Mucus_Plug">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Intrapartum_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A discharge of the mucus plug from the cervical os during cervical dilation in preparation for the labor and delivery of the baby.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92840</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Passing of Mucus Plug</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Passing_of_Mucus_Plugs</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Passing_of_Mucus_Plug</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Patent_Ductus_Arteriosus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Patent_Ductus_Arteriosus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital defect characterized by the failure of the ductus arteriosus to close soon after birth. As a consequence, blood from the aorta mixes with blood from the pulmonary artery. If untreated, it may lead to congestive heart failure.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84492</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Patent Ductus Arteriosus</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Patent_Ductus_Arteriosuses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Patent_Ductus_Arteriosus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Patent_Urachus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Patent_Urachus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Urinary_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality that results from the failure of the lumen of urachus to be obliterated. It presents with leakage of urine from the bladder through the umbilicus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99005</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
