    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Enlarged_Uterus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An increase in the overall dimensions or volume of the uterus compared to normal.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92773</ID>
        <NCI_PT rdf:datatype="&xsd;string">Enlarged Uterus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
