        <ace_lexicon:CN_sg>Bottle_Feeding</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Bottle_Feedings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Brachial_Plexus_Injury -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Brachial_Plexus_Injury">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Traumatic_Injury"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Brachial Plexus Injury</NCI_PT>
        <ID rdf:datatype="&xsd;string">C103231</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Damage to the nerves in the brachial plexus network. These nerves originate in the spinal column and innervate the shoulder, arm and hand. Often, damage is sustained from overstretching or motor vehicle accidents.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Brachial_Plexus_Injuries</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Brachial_Plexus_Injury</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Brachial_Plexus_Palsy_due_to_Birth_Trauma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Brachial_Plexus_Palsy_due_to_Birth_Trauma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Birth_Trauma_of_Fetus"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Birth injury to the brachial plexus. It results in paralysis of the muscles of the shoulder, arm, and hand. It manifests as lack of mobility in the arm, usually in the first week of life. In the majority of cases there is spontaneous recovery.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Brachial Plexus Palsy due to Birth Trauma</NCI_PT>
        <ID rdf:datatype="&xsd;string">C102990</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Brachial_Plexus_Palsy_due_to_Birth_Trauma</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Brachial_Plexus_Palsy_due_to_Birth_Traumas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Bradley_Method -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Bradley_Method">
