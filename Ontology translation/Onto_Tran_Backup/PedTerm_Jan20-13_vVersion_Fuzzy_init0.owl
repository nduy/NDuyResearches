        <ace_lexicon:CN_sg>Meningococcal_Conjugate_Vaccine_MCV-4</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Meningococcal_Conjugate_Vaccine_MCV-4s</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Meningococcal_Polysaccharide_Vaccine_MPSV-4 -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Meningococcal_Polysaccharide_Vaccine_MPSV-4">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Polysaccharide_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A polysaccharide vaccine used to prevent contraction of meningococcal meningitis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96519</ID>
        <NCI_PT rdf:datatype="&xsd;string">Meningococcal Polysaccharide Vaccine MPSV4</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Meningococcal_Polysaccharide_Vaccine_MPSV-4</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Meningococcal_Polysaccharide_Vaccine_MPSV-4s</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Menkes_Kinky-Hair_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Menkes_Kinky-Hair_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An X-linked disorder caused by mutations in the ATP7A gene resulting in the abnormal transport and metabolism of copper. It affects primarily male infants. It is characterized by hypotonia, seizures, failure to thrive, and peculiar colorless or steel-colored brittle hair.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75486</ID>
        <NCI_PT rdf:datatype="&xsd;string">Menkes Disease</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Menkes_Kinky-Hair_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Menkes_Kinky-Hair_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Menopause -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Menopause">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Organismal_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3231</ID>
        <NCI_PT rdf:datatype="&xsd;string">Menopause</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The permanent cessation of menses, usually defined by 6 to 12 months of amenorrhea in a woman over 45 years of age.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Menopauses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Menopause</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mental_Development_Index -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mental_Development_Index">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Child_Development_Status"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A sequential arrangement of information pertaining to the evolution of an individual&apos;s cognitive development.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81263</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mental Development Index</NCI_PT>
