        <NCI_Definition rdf:datatype="&xsd;string">The formation of tissue in the lumen of the ileum that results in partial obstruction.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ileal_Web</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ileal_Webs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Image_Identifier -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Image_Identifier">
