    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Colostrum -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Colostrum">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Biological_Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A thick, protein-rich substance secreted by the breasts during the second half of pregnancy and for a few days after birth before the breast milk comes in. It contains antibodies which serve to give the baby protection from disease and also has a laxative effect on the colon which helps to expel the plug of meconium and facilitate the establishment of normal bowel movements.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C32348</ID>
        <NCI_PT rdf:datatype="&xsd;string">Human Colostrum</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Colostrum</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Colostrums</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Atrioventricular_Canal -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Atrioventricular_Canal">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiac_Septal_Defects"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart malformation characterized by abnormalities in the anatomic structures that relate to the endocardial cushions. These abnormalities can include defects in the lower part of the atrial septum and the ventricular septum and lack of separation of the mitral and tricuspid valves.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Atrioventricular Septal Defect</NCI_PT>
        <ID rdf:datatype="&xsd;string">C101029</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Common_Atrioventricular_Canals</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Common_Atrioventricular_Canal</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Truncus_Arteriosus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Truncus_Arteriosus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital cardiovascular disorder characterized by the failure of the embryologic structure truncus arteriosus to divide into the aorta and pulmonary trunk. It results in the presence of a single vessel instead of two vessels leading out of the heart. Clinical signs and symptoms include cyanosis that is present at birth, poor growth, dyspnea, tachypnea, arrhythmia, cardiomegaly, and heart failure. If it is not surgically repaired, it leads to death.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98880</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Persistent Truncus Arteriosus</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Common_Truncus_Arteriosuses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Common_Truncus_Arteriosus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Ventricle -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Ventricle">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An umbrella term used to describe several very different complex congenital heart defects that share the same problem: the heart has only one functional ventricle (anatomically right or left or indeterminate) supplying the systemic circulation. These defects include tricuspid atresia, hypoplastic left or right heart syndrome, double outlet right ventricle, double inlet left ventricle, and other forms of single ventricle defects.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99542</ID>
        <NCI_PT rdf:datatype="&xsd;string">Common Ventricle Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Common_Ventricles</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Common_Ventricle</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Atrioventricular_Block -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Atrioventricular_Block">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiac_Arrhythmia"/>
        <NCI_PT rdf:datatype="&xsd;string">AV Block Third Degree</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">An electrocardiographic finding of complete blockage of electrical impulse conduction from the atria to the ventricles.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50501</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Non-Congenital Complete Atrioventricular Block</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Complete_Atrioventricular_Blocks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Complete_Atrioventricular_Block</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Atrioventricular_Canal_Defect_Balanced -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Atrioventricular_Canal_Defect_Balanced">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Atrioventricular_Canal"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Atrioventricular septal defect in which the atrioventricular junction is shared evenly between the left ventricle and right ventricle.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101030</ID>
        <NCI_PT rdf:datatype="&xsd;string">Complete Atrioventricular Canal Defect Balanced</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Complete_Atrioventricular_Canal_Defect_Balanced</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Complete_Atrioventricular_Canal_Defect_Balanceds</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Atrioventricular_Canal_Defect_Unbalanced -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Atrioventricular_Canal_Defect_Unbalanced">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Common_Atrioventricular_Canal"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Atrioventricular septal defect in which there is usually a single dominant ventricle and a hypoplastic ventricle.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101031</ID>
        <NCI_PT rdf:datatype="&xsd;string">Complete Atrioventricular Canal Defect Unbalanced</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Complete_Atrioventricular_Canal_Defect_Unbalanced</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Complete_Atrioventricular_Canal_Defect_Unbalanceds</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Trisomy_13_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Trisomy_13_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Chromosome_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome characterized by the presence of three complete copies of genetic material for chromosome 13, instead of the normal two. It leads to a variety of abnormalities that include mental retardation, microcephaly, low-set ears, eye structural defects, polydactyly, and limb abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101223</ID>
        <NCI_PT rdf:datatype="&xsd;string">Complete Trisomy 13 Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Complete_Trisomy_13_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Complete_Trisomy_13_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Trisomy_18_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Trisomy_18_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Chromosome_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A constellation of symptoms that occur as a result of the presence of a complete third copy of the 18th chromosome. Characteristics include profound mental retardation and severe malformations. Individuals with this syndrome rarely live past one year.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101362</ID>
        <NCI_PT rdf:datatype="&xsd;string">Complete Trisomy 18 Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Complete_Trisomy_18_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Complete_Trisomy_18_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Trisomy_21_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Complete_Trisomy_21_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Chromosome_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome characterized by the presence of three complete copies of genetic material for chromosome 21, instead of the normal two. It leads to a variety of abnormalities that include mental retardation, macroglossia, microgenia, epicanthic eyelids, and a single transverse palmar crease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101222</ID>
        <NCI_PT rdf:datatype="&xsd;string">Complete Trisomy 21 Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Complete_Trisomy_21_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Complete_Trisomy_21_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


