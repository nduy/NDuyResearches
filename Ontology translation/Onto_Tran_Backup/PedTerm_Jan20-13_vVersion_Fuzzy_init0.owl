</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Oral Cavity</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The cavity located at the upper end of the alimentary canal, behind the teeth and gums that is bounded on the outside by the lips, above by the hard and soft palates and below by the tongue.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Oral_Cavities</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Oral_Cavity</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Khop_goi -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Khop_goi">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Phan_co_the"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A joint connecting the lower part of the femur with the upper part of the tibia. The lower part of the femur and the upper part of the tibia are attached to each other by ligaments. Other structures of the knee joint include the upper part of the fibula, located below and parallel to the tibia, and the patella which moves as the knee bends.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C32898</ID>
        <NCI_PT rdf:datatype="&xsd;string">Knee Joint</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Knee_Joint</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Knee_Joints</ace_lexicon:CN_pl>
    </owl:Class>
    


