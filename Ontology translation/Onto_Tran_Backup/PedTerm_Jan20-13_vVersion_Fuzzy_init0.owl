    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Thalassemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Thalassemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hemoglobinopathy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An inherited blood disorder characterized by a decreased synthesis of one of the polypeptide chains that form hemoglobin. Anemia results from this abnormal hemoglobin formation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35069</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
