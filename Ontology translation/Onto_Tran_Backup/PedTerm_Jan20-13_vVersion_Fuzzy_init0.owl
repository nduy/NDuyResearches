        <ace_lexicon:CN_sg>Myelomeningocele</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myocardial_Infarction -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myocardial_Infarction">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C27996</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Gross necrosis of the myocardium, as a result of interruption of the blood supply to the area, as in coronary thrombosis.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Myocardial Infarction</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Myocardial_Infarction</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Myocardial_Infarctions</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myoclonic_Jerk -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myoclonic_Jerk">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A sudden, involuntary contraction of a muscle or group of muscles; these movements may develop as a symptom of a number of neurological diseases including epilepsy, Parkinson&apos;s disease, Alzheimer&apos;s disease, or Creutzfeldt-Jacob disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34832</ID>
        <NCI_PT rdf:datatype="&xsd;string">Myoclonic Jerk</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Myoclonic_Jerks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Myoclonic_Jerk</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myoclonic_Seizure -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myoclonic_Seizure">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Seizure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An epilepsy characterized by myoclonic jerks, generalized tonic-clonic seizures, and sometimes absence seizures. It appears during adolescence.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84796</ID>
        <NCI_PT rdf:datatype="&xsd;string">Juvenile Myoclonic Epilepsy</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Myoclonic_Seizure</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Myoclonic_Seizures</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myopathy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myopathy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic disorder that affects the muscles. Representative examples include muscular dystrophy, metabolic myopathies, muscular atrophies, and dermatomyositis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101216</ID>
        <NCI_PT rdf:datatype="&xsd;string">Myopathy</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Myopathies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Myopathy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myotonic_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myotonic_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An inherited or acquired, localized or generalized disorder affecting the muscles. It may be associated with abnormalities in the chloride or sodium channels of the muscles. It is characterized by delayed muscle relaxation following stimulation or contraction. Representative examples include myotonia congenita and myotonic dystrophy.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84913</ID>
        <NCI_PT rdf:datatype="&xsd;string">Myotonic Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Myotonic_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Myotonic_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Myotonic_Dystrophy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Myotonic_Dystrophy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Myotonic_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">An inherited progressive disorder affecting the muscles. It is characterized by muscle wasting and hypotonia, cataracts, heart conduction defects and endocrinopathies.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84914</ID>
        <SYN rdf:datatype="&xsd;string">Congenital Myotonic Dystrophy</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Myotonic Dystrophy</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Myotonic_Dystrophies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Myotonic_Dystrophy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#NADH_Dehydrogenase_Ubiquinon_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#NADH_Dehydrogenase_Ubiquinon_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare metabolic disorder characterized by the deficiency of mitochondrial NADH dehydrogenase component of complex I. Signs and symptoms include cardiomyopathy, encephalopathy, enlarged head, and progressive leukodystrophy.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98994</ID>
        <NCI_PT rdf:datatype="&xsd;string">NADH Dehydrogenase Deficiency</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>NADH_Dehydrogenase_Ubiquinon_Deficiencies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>NADH_Dehydrogenase_Ubiquinon_Deficiency</ace_lexicon:CN_sg>
    </owl:Class>
    


