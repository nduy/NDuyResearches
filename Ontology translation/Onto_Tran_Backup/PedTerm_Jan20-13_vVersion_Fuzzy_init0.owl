        <ace_lexicon:CN_pl>Van_Der_Woude_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Van_Der_Woude_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


