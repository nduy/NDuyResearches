        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Bradley_Methods</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Bradley_Method</ace_lexicon:CN_sg>
    </owl:Class>
    


