    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vein_of_Galen_Malformation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vein_of_Galen_Malformation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Circulatory_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An arteriovenous malformation in the vein of Galen that is located at the base of the brain. The malformation may result in developmental delays, hydrocephalus, seizures, and congestive heart failure.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98642</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vein of Galen Malformation</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vein_of_Galen_Malformations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vein_of_Galen_Malformation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Venous_Stenosis -->

