        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital cardiopulmonary defect characterized by abnormal right-sided pulmonary venous drainage and right lung malformations.</NCI_Definition>
