        <ace_lexicon:CN_sg>Positive_Pregnancy_Test</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Post-Partum_Recovery -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Post-Partum_Recovery">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Postpartum_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
