        <ID rdf:datatype="&xsd;string">C101042</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Less than necessary amount of the enzyme steroid 21-monooxygenase; which is necessary to synthesize cortisol.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Steroid 21-Monooxygenase Deficiency</NCI_PT>
