    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Gram -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Gram">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Unit_of_Measure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C48155</ID>
