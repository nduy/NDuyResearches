        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A finding indicating narrowing of a vein in one or multiple areas.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98643</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
