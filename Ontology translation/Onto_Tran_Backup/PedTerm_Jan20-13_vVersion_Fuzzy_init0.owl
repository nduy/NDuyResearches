    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hysterotomy_Abortion -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hysterotomy_Abortion">
