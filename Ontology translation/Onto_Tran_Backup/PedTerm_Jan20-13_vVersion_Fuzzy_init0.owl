    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Increased_Bone_Density">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A finding indicating an increased density of minerals in the bones. Causes include osteopetrosis and Paget disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99124</ID>
        <NCI_PT rdf:datatype="&xsd;string">Increased Bone Density</NCI_PT>
