        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hemangioma</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hemangiomas</ace_lexicon:CN_pl>
    </owl:Class>
    


