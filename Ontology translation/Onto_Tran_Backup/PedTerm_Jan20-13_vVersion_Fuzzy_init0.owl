        <ID rdf:datatype="&xsd;string">C90491</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Findings observed at the end of a pregnancy.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pregnancy Outcome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pregnancy_Outcomes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pregnancy_Outcome</ace_lexicon:CN_sg>
    </owl:Class>
    


