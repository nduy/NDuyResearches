    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mullerian_Inhibiting_Factor_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mullerian_Inhibiting_Factor_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gonadal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A deficiency of the Mullerian inhibiting substance, which is secreted by the Sertoli cells during embryogenesis. It can result in unilateral or bilateral cryptorchidism, testicular regression syndrome and sterility.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101215</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mullerian Inhibiting Substance Deficiency</NCI_PT>
