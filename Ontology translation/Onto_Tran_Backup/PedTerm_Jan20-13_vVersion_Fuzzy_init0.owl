    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Antithrombin_III_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Antithrombin_III_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Coagulation_Defect"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare disorder characterized by the presence of low levels of antithrombin III which prohibits the formation of blood clots. It may be inherited, usually in an autosomal dominant pattern, or acquired. It may lead to venous thrombosis and pulmonary embolism.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Antithrombin III Deficiency</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98815</ID>
