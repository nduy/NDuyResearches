    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Isovaleryl-CoA_Dehydrogenase_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Recessive_Hereditary_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive inherited disorder caused by mutations in the IVD gene. It is characterized by abnormalities in the metabolism of leucine. Signs and symptoms vary from very mild to life threatening and include vomiting, seizures, lethargy, and coma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98964</ID>
        <NCI_PT rdf:datatype="&xsd;string">Isovaleric Acidemia</NCI_PT>
