        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Sphingomyelin/Cholesterol_Lipidosis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Sphingomyelin/Cholesterol_Lipidosis</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Spina_Bifida -->

