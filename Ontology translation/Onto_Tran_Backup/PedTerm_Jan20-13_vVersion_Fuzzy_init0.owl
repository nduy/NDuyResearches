        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92818</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intrapartum</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The period of time during labor and delivery.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intrapartums</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intrapartum</ace_lexicon:CN_sg>
    </owl:Class>
    


