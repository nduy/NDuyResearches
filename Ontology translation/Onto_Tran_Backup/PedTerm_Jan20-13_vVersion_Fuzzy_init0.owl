    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Caesarian_Section -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Caesarian_Section">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Delivery_Procedure"/>
        <SYN rdf:datatype="&xsd;string">C-Section</SYN>
