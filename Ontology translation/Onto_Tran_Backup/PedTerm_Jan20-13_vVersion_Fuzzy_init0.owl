        <ace_lexicon:CN_pl>Sexually_Transmitted_Disease_Screenings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Shock -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Shock">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiovascular_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A life-threatening condition that requires immediate medical intervention. It is characterized by reduced blood flow that may result in damage of multiple organs. Types of shock include cardiogenic, hemorrhagic, septic, anaphylactic, and traumatic shock.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35016</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Shock</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Shocks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Shock</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Shone_s_Syndrome_Greater_than_3_Sites -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Shone_s_Syndrome_Greater_than_3_Sites">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Circulatory_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital cardiovascular abnormality characterized by the presence of subvalvar left ventricular outflow tract obstruction, coarctation of the aorta, and mitral stenosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99058</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Shone Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Shone_s_Syndrome_Greater_than_3_Sites</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Shone_s_Syndrome_Greater_than_3_Siteses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Short-Term_Variability -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Short-Term_Variability">
