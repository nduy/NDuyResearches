        <ace_lexicon:CN_pl>Ischiums</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Ischium</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ultrasound_Imaging -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ultrasound_Imaging">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Diagnostic_Procedure"/>
        <NCI_Definition rdf:datatype="&xsd;string">A technique in which high-frequency sound waves are bounced off internal organs and the echo pattern is converted into a 2 dimensional picture of the structures beneath the transducer.</NCI_Definition>
