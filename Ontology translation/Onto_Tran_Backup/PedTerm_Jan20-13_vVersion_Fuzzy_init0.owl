        <ace_lexicon:CN_sg>Vertex_Presentation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Very_Long_Chain_Acyl-CoA_Dehydrogenase_Deficiency -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Very_Long_Chain_Acyl-CoA_Dehydrogenase_Deficiency">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Specific_Enzyme_Deficiency"/>
        <NCI_PT rdf:datatype="&xsd;string">Acyl-CoA Dehydrogenase, Very Long-Chain Deficiency</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">An autosomal recessive inherited disorder characterized by a deficiency of the enzyme very long-chain acyl-coenzyme A dehydrogenase that metabolizes long-chain fatty acids. Signs and symptoms may appear in infancy, early childhood, or later in life. Clinical manifestations in infancy include cardiomyopathy, arrhythmias, hypotonia, and hepatomegaly. Early childhood manifestations include hypoglycemia and hepatomegaly. Later-onset manifestations include muscle pain, cramps, and rhabdomyolysis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98647</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">VLCAD; Very Long Chain Acyl-Coenzyme A Dehydrogenase Deficiency</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Very_Long_Chain_Acyl-CoA_Dehydrogenase_Deficiency</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Very_Long_Chain_Acyl-CoA_Dehydrogenase_Deficiencies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vesicoureteric_Reflux -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vesicoureteric_Reflux">
