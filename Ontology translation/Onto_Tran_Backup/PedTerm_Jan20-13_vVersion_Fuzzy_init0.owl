    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#H1N1_Influenza -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#H1N1_Influenza">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Influenza"/>
        <NCI_Definition rdf:datatype="&xsd;string">An acute viral respiratory infection caused by a strain of influenza virus which is endemic in swine (pigs). Rarely reported in humans prior to 2009, the disease is caused by a mutated strain of swine influenza A (H1N1) virus. It is highly contagious and spreads mainly through coughing and sneezing. Signs and symptoms include fever, chills, coughing, sore throat headache, muscle ache, and generalized weakness. Antiviral medications are most effective in the first two days of the illness.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C80444</ID>
        <NCI_PT rdf:datatype="&xsd;string">H1N1 Influenza</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <SYN rdf:datatype="&xsd;string">Swine flu</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>H1N1_Influenzas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>H1N1_Influenza</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#HELLP_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#HELLP_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Preeclampsia"/>
        <NCI_Definition rdf:datatype="&xsd;string">A life-threatening complication of pregnancy usually occurring in women with preeclampsia or eclampsia. It is characterized by hemolytic anemia, elevated liver enzymes, and low platelet count. Signs and symptoms include headaches, nausea, vomiting, blurred vision, and upper abdominal pain. It may lead to diffuse intravascular coagulation and acute renal failure.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84750</ID>
        <NCI_PT rdf:datatype="&xsd;string">HELLP Syndrome</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Hemolysis-Elevated_Liver_Enzymes-Low_Platelet_Count_Syndrome</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>HELLP_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>HELLP_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#HIV_Screening -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#HIV_Screening">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Screening_or_Clinical_Tests_during_Pregnancy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92859</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Prenatal HIV Screening</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Testing of a pregnant mother for antibodies to the human immunodeficiency virus (HIV) in early pregnancy. Results permit management to reduce the chances of maternal transmission of HIV to the fetus.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>HIV_Screenings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>HIV_Screening</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Haemophilus_Influenzae_B_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Haemophilus_Influenzae_B_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Conjugate_Vaccine"/>
        <NCI_Definition rdf:datatype="&xsd;string">A vaccine against serotype b of the Gram-negative bacterium H. influenzae (Hib). Hib vaccines contain polysaccharide-protein conjugate antigens that produce greater host immune responses than first-generation purified polysaccharide vaccine. These vaccines may differ with regard to use of protein carriers, polysaccharides, diluents, and preservatives.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C1126</ID>
        <NCI_PT rdf:datatype="&xsd;string">Haemophilus Influenzae B Vaccine</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Hib Vaccine; PRP vaccine</SYN>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Haemophilus_Influenzae_B_Vaccine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Haemophilus_Influenzae_B_Vaccines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ham -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ham">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Phan_co_the"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A small fold of tissue that limits the movements of an organ or body part; for example, the lingual frenulum connects the tongue to the floor of the mouth and restrains its movement.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87076</ID>
        <NCI_PT rdf:datatype="&xsd;string">Frenulum</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Frenulums</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Frenulum</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Harlequin_Ichthyosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Harlequin_Ichthyosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Skin"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A very rare and usually lethal autosomal recessive inherited disorder of the skin caused by mutations in the ABCA12 gene. It is characterized by the presence of hard and thick skin. There are diamond-like plates formed in the skin which are separated by fissures.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98934</ID>
        <NCI_PT rdf:datatype="&xsd;string">Harlequin Ichthyosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Harlequin_Ichthyoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Harlequin_Ichthyosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Head_Circumference -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Head_Circumference">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Length"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A circumferential measurement of the head at the widest point, which is traditionally above the eyebrows.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81255</ID>
        <NCI_PT rdf:datatype="&xsd;string">Head Circumference</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Head_Circumference</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Head_Circumferences</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Head_Circumference_at_Initial_Disposition -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Head_Circumference_at_Initial_Disposition">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Head_Circumference"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Birth Head Circumference</NCI_PT>
        <ID rdf:datatype="&xsd;string">C101221</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The measurement around a neonate&apos;s head at birth.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Head_Circumference_at_Initial_Dispositions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Head_Circumference_at_Initial_Disposition</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Health -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Health">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Qualitative_Concept"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C25178</ID>
        <NCI_PT rdf:datatype="&xsd;string">Health</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Refers to a person&apos;s state of physical, mental and social well-being; usually it refers specifically to the state of being in good health, a state of complete physical, mental and social well-being, and does not consist only of the absence of disease or infirmity. In any organism health constitutes a form of homeostasis with inputs and outputs of energy and mass in approximate equilibrium allowing for growth and continued survival. In humans, a subjective feeling of well-being coming from somatic and cognitive perceptions is considered an essential component of health.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Healths</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Health</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Healthcare_Activity -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Healthcare_Activity">
        <ID rdf:datatype="&xsd;string">C16205</ID>
        <NCI_PT rdf:datatype="&xsd;string">Healthcare Activity</NCI_PT>
        <Subset_Association rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The actions of prevention, treatment, and management of illness and the preservation of mental and physical well-being through the services offered by the medical and allied health professions.</NCI_Definition>
        <ace_lexicon:CN_sg>Healthcare_Activity</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Healthcare_Activities</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hearing_Loss -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hearing_Loss">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Sensory_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A partial or complete loss of hearing in one or both ears. It is classified as conductive, sensory, or central.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35731</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hearing Loss</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Hearing_Losses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Hearing_Loss</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiovascular_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any deviation from the normal structure or function of the cardiac system that is manifested by a characteristic set of symptoms and signs.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3079</ID>
        <NCI_PT rdf:datatype="&xsd;string">Heart Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Heart_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Heart_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Murmur -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Murmur">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cardiovascular_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A periodic humming or blowing sound heard on auscultation of the heart that can indicate the presence of cardiac disease; murmurs are the result of vibrations caused by the turbulent flow of blood in the heart or great vessels. Murmurs are characterized according to the area of generation (mitral, aortic, tricuspid, or pulmonary) and according to the period of the cycle (systolic or diastolic).</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84480</ID>
        <NCI_PT rdf:datatype="&xsd;string">Heart Murmur</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Heart_Murmur</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Heart_Murmurs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Rate -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Rate">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Numeric_Value"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C49677</ID>
        <NCI_PT rdf:datatype="&xsd;string">Heart Rate</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The number of heartbeats per unit of time, usually expressed as beats per minute.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Heart_Rates</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Heart_Rate</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Rate_Score -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Rate_Score">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Numeric_Value"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A component of the APGAR score, it is the numerical value assigned to an assessment of the circulatory status of a neonate. 0 = no pulse; 1 = rate less than 100 beats per minute; 2 = rate greater than 100 beats per minute.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81309</ID>
        <NCI_PT rdf:datatype="&xsd;string">Heart Rate Score</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Heart_Rate_Scores</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Heart_Rate_Score</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Rhythm -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Rhythm">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Characteristic"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87081</ID>
        <NCI_PT rdf:datatype="&xsd;string">Heart Rhythm</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The recurrent, measured movements (rhythm) of a beating heart.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Heart_Rhythms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Heart_Rhythm</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Valve_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Valve_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Disease"/>
        <NCI_Definition rdf:datatype="&xsd;string">Any heart disorder characterized by a defect in valve structure or function.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C45525</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Heart Valve</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Valvular Heart Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Heart_Valve_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Heart_Valve_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Valve_Regurgitation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Valve_Regurgitation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Heart_Valve_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C50796</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Dysfunction of one of the cardiac valves, with incomplete valve closure resulting in valvular regurgitation.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Valvular Insufficiency</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Heart_Valve_Regurgitations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Heart_Valve_Regurgitation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Heel_to_Ear_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Heel_to_Ear_Measurement">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Newborn_Examination"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C89513</ID>
        <NCI_PT rdf:datatype="&xsd;string">Heel to Ear Measurement</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Useful in assessing neonatal neuromuscular development, this is obtained when the infant is placed in a supine position and the infant&apos;s feet are grasped pulled toward the ipsilateral ears. The examiner measures the angle made by the arc from the table to the infant&apos;s heels; increased angle for age suggests hypotonia, and decreased angle for age suggests hypertonia.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Heel_to_Ear_Measurement</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Heel_to_Ear_Measurements</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hemangioendothelioma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hemangioendothelioma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A vascular proliferation characterized by the presence of prominent endothelial cells and the formation of vascular channels. Hemangioendotheliomas may display borderline or low grade characteristics.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3084</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hemangioendothelioma</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hemangioendothelioma</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hemangioendotheliomas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hemangioma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hemangioma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A benign localized vascular neoplasm usually occurring in infancy and childhood. It is characterized by the formation of capillary-sized or cavernous vascular channels. The majority of cases are congenital.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3085</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hemangioma</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
