    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#General_Appearance -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#General_Appearance">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Characteristic"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87079</ID>
        <NCI_PT rdf:datatype="&xsd;string">General Appearance</NCI_PT>
