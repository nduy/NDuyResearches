        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A finding that indicates abnormal liver function.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50634</ID>
        <NCI_PT rdf:datatype="&xsd;string">Liver Dysfunction</NCI_PT>
