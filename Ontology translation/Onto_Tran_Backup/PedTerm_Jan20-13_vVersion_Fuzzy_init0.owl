    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Cyanotic_Limbs -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Cyanotic_Limbs">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cyanosis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
