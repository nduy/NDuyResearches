    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Adrenal_Hyperplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Adrenal_Hyperplasia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality"/>
        <NCI_Definition rdf:datatype="&xsd;string">A genetic disorder characterized by defects in the synthesis of cortisol and/or aldosterone, resulting in hyperplasia of the adrenal cortical cells.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Adrenogenital Disorder</SYN>
        <ID rdf:datatype="&xsd;string">C34360</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Adrenal Gland Hyperplasia</NCI_PT>
