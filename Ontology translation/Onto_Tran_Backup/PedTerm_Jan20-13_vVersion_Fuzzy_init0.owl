    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Phenylketonuria -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Phenylketonuria">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Amino_Acid_Metabolism_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder characterized by the body&apos;s inability to break down and utilize the essential amino acid phenylalanine.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81315</ID>
        <SYN rdf:datatype="&xsd;string">Classical_Phenylketonuria; PKU</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Phenylketonuria</NCI_PT>
