    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mumps -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mumps">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Childhood_Viral_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A contagious viral infection caused by the mumps virus. Symptoms include swollen and tender parotid glands, fever, muscle aches and fatigue. Due to vaccination programs, mumps has become a rare disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C29888</ID>
        <NCI_PT rdf:datatype="&xsd;string">Mumps</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Mumpses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Mumps</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Muscle_Tone_Score -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Muscle_Tone_Score">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Numeric_Value"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A component of the APGAR score, it is the numerical value assigned to an assessment of the residual muscle tension of a neonate. 0 = flaccid; 1 = flexion of extremities; 2 = active motion.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81312</ID>
        <NCI_PT rdf:datatype="&xsd;string">Muscle Tone Score</NCI_PT>
