    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Associated_Plasma_Protein_A">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Blood_Test_for_Protein_Level"/>
