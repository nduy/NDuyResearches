        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The stage in the life of a female during which she is attempting to get pregnant.</NCI_Definition>
