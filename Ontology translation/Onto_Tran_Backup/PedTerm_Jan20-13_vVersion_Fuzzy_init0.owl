    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Acquired_Unilateral_Cataract -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Acquired_Unilateral_Cataract">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Acquired_Cataract"/>
        <NCI_Definition rdf:datatype="&xsd;string">A cataract in one eye that results from the aging process, an injury, or as a manifestation of a systemic disorder.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Acquired Unilateral Cataract</NCI_PT>
        <ID rdf:datatype="&xsd;string">C101192</ID>
        <SYN rdf:datatype="&xsd;string">Cataract, Acquired, Unilateral</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Acquired_Unilateral_Cataract</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Acquired_Unilateral_Cataracts</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Autosomal_Dominant_Hereditary_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">A genetic disorder characterized by craniosynostosis and fusion of the fingers and toes.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Acrocephalosyndactyly</NCI_PT>
        <ID rdf:datatype="&xsd;string">C34348</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Acrocephalosyndactylies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Acrocephalosyndactyly</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly_Type_I -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly_Type_I">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An autosomal dominant inherited type of acrocephalosyndactyly caused by mutations in the FGFR2 gene. It is characterized by early closure of the sutures between the skull bones, bulging eyes, low-set ears, fusion of the second, third, and forth fingers, and fusion of the toes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99099</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Type I Acrocephalosyndactyly</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Acrocephalosyndactyly_Type_Is</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Acrocephalosyndactyly_Type_I</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly_Type_V -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly_Type_V">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Acrocephalosyndactyly"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An autosomal dominant inherited type of acrocephalosyndactyly caused by mutations in the FGFR1 or FGFR2 genes. It is characterized by early closure of the sutures between the skull bones, bulging and wide-set eyes, broad thumbs, big toes, and partial syndactyly in the hands and toes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99100</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Type V Acrocephalosyndactyly</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Acrocephalosyndactyly_Type_V</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Acrocephalosyndactyly_Type_Vs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Active_Phase_of_Labor -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Active_Phase_of_Labor">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#First_Stage_of_Labor"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Active Phase of Labor</NCI_PT>
        <ID rdf:datatype="&xsd;string">C92943</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The period during the first stage of labor and childbirth involved with cervical dilatation, effacement, and fetal station.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Active_Phase_of_Labor</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Active_Phase_of_Labors</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Acute_Respiratory_Failure -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Acute_Respiratory_Failure">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_Failure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Acute Respiratory Failure</NCI_PT>
        <ID rdf:datatype="&xsd;string">C27043</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Life-threatening respiratory failure that develops rapidly. Causes include injury, sepsis, drug overdose, and pancreatitis. It manifests with dyspnea and cyanosis and may lead to cardiovascular shock.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Acute_Respiratory_Failures</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Acute_Respiratory_Failure</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Acute_Stress_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Acute_Stress_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anxiety_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Acute Stress Disorder</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">An anxiety disorder precipitated by an experience of intense fear or horror while exposed to a traumatic (especially life-threatening) event. The disorder is characterized by dissociative symptoms; vivid recollections of the traumatic event; avoidance of stimuli associated with the traumatic event; and a constant state of hyperarousal for no more than one month.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92621</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
