        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99071</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Deficiency of surfactant protein D. When present in normal amounts, this protein offers protection against pulmonary infection and inflammation.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
