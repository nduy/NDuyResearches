        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A type of cerebral palsy characterized by spasticity and hypertonia of the lower extremities bilaterally, particularly the legs, hips, and pelvis; this is the most common (70%) form of cerebral palsy.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34781</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Spastic Diplegia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Spastic_Diplegia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Spastic_Diplegias</ace_lexicon:CN_pl>
    </owl:Class>
    


