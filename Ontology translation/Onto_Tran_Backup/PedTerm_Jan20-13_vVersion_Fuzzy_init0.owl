        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome characterized by abnormal secretion of antidiuretic hormone in conjunction with neoplastic growth occurring anywhere in the body.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3988</ID>
        <NCI_PT rdf:datatype="&xsd;string">Inappropriate Antidiuretic Hormone Secretion Syndrome</NCI_PT>
