</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Adrenal_Hyperplasias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Adrenal_Hyperplasia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Anomaly_of_Pulmonary_Veins -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Anomaly_of_Pulmonary_Veins">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Great_Vessel_Abnormality"/>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital heart disorder in which all four pulmonary veins are not connected to the left atrium and drain into the systemic veins or the right atrium instead. Infants present with cyanosis, lethargy, tachypnea, respiratory infections, and poor growth.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98585</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Total Anomalous Pulmonary Venous Return</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Total Anomalous Pulmonary Venous Return</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Anomaly_of_Pulmonary_Veinses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Anomaly_of_Pulmonary_Veins</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Aortic_Valve -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Atresia_of_Aortic_Valve">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital heart defect characterized by the complete failure of the aortic valve to open. It is manifested during infancy with cyanosis, dyspnea, and rapidly progressing heart failure.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Aortic Valve Atresia</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98818</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Atresia_of_Aortic_Valves</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Atresia_of_Aortic_Valve</ace_lexicon:CN_sg>
    </owl:Class>
    


