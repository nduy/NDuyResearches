        <SYN rdf:datatype="&xsd;string">AROM</SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An external intervention during labor and delivery to break the bag of membranes or the amniotic sac to facilitate childbirth.</NCI_Definition>
