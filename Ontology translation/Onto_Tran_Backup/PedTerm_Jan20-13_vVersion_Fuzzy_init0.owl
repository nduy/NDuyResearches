        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Full_Term_Neonate</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Full_Term_Neonates</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Functional_Intestinal_Obstruction -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Functional_Intestinal_Obstruction">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Intestinal_Obstruction"/>
        <ID rdf:datatype="&xsd;string">C101033</ID>
        <NCI_PT rdf:datatype="&xsd;string">Functional Bowel Obstruction</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Intestinal Obstruction, Functional</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The blockage of bowel contents from evacuation; the causes are attributable to non-structural impediments, such as chemical imbalances or the side effects of medications, narcotics in particular.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Functional_Intestinal_Obstruction</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Functional_Intestinal_Obstructions</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Fundus_Coloboma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Fundus_Coloboma">
