        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Perforation_of_Intestine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rupture in the ileal wall due to traumatic or a pathologic processes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C78355</ID>
