        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A finding which indicates an individual is not pregnant.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35450</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Negative Pregnancy Test</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Negative_Pregnancy_Test</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Negative_Pregnancy_Tests</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neisseria_meningitidis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neisseria_meningitidis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Bacteria"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A species of aerobic, Gram-negative, diplococci shaped bacteria assigned to the phylum Proteobacteria. This species is catalase and oxidase positive, non-hemolytic, non-pigmented, does not reduce nitrate or nitrite, does not synthesize polysaccharides, grows on blood, chocolate, or Muller-Hinton agar, and produces acid from glucose and maltose but not fructose, sucrose, mannose, or lactose. N. meningitidis, known commonly as meningococcus, is the causative agent of cerebrospinal meningitis, but is also associated with other human infections, but can be commensal in the oropharynx and nasopharynx of carriers.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C86605</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neisseria meningitidis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neisseria_meningitidis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neisseria_meningitidises</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Abstinence_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Abstinence_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Drug_Withdrawal_Syndrome_in_Newborn"/>
        <NCI_Definition rdf:datatype="&xsd;string">A constellation of signs and symptoms observable in a neonate that are consistent with maternal narcotic abuse or withdrawal while pregnant.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87101</ID>
        <SYN rdf:datatype="&xsd;string">NAS</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Abstinence Syndrome</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Abstinence_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Abstinence_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Abstinence_Syndrome_Assessment -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Abstinence_Syndrome_Assessment">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Newborn_Examination"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C89515</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Abstinence Syndrome Assessment</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The measurement of the degree to which a neonate is experiencing symptoms of withdrawal due to maternal substance abuse; the score can be used to determine subsequent treatment of the infant.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Abstinence_Syndrome_Assessments</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Abstinence_Syndrome_Assessment</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Acrocyanosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Acrocyanosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cyanosis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99253</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Acrocyanosis</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Transient cyanotic discoloration of the hands and feet, especially fingers and toes, in a newborn.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Acrocyanoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Acrocyanosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Adrenoleukodystrophy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Adrenoleukodystrophy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare metabolic disorder that affects neonates. It is characterized by damage of the white matter in the brain and degeneration of the adrenal glands. It manifests with hyperactivity, paralysis, muscular weakness, crossed eyes, hearing loss, seizures, and coma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99251</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Adrenoleukodystrophy</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Adrenoleukodystrophies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Adrenoleukodystrophy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Aspiration_of_Amniotic_Fluid -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Aspiration_of_Amniotic_Fluid">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C101028</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Inhalation of fluid from the amniotic sac into the lungs by the neonate.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Aspiration of Amniotic Fluid</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Aspiration_of_Amniotic_Fluids</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Aspiration_of_Amniotic_Fluid</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Diabetes_Mellitus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Diabetes_Mellitus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99248</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Diabetes Mellitus</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Transient or permanent diabetes mellitus that affects neonates. It is caused by the inability of the pancreas to secrete sufficient insulin in response to elevated levels of glucose in the blood. The transient diabetes mellitus lasts for weeks or months and may return in adolescence or in adulthood. The permanent diabetes mellitus does not disappear and is caused by mutations in the KCNJ11, GCK, and IPF1 genes.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Diabetes_Mellitus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Diabetes_Mellituses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pediatric_Disease_or_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic or neoplastic disorder which occurrs during the neonatal period.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98996</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Disorder</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Hepatitis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Hepatitis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Gastrointestinal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C84446</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Hepatitis developing during the neonatal period.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Hepatitis</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Hepatitises</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Hepatitis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Hyperbilirubinemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Hyperbilirubinemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99235</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Increased levels of bilirubin in the blood during the neonatal period. In the majority of cases it is seen in the first week of life and usually there is no underlying disease, however, it may also occur in hemolytic diseases, infections, metabolic disorders, and liver abnormalities.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Hyperbilirubinemia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Hyperbilirubinemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Hyperbilirubinemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Hypoglycemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Hypoglycemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99237</ID>
        <NICHD_Definition rdf:datatype="&xsd;string">Hypoglycemia is a condition that occurs during the neonatal period, when there is abnormally diminished content of glucose in the blood (below 70 mg/dL ).</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">Hypoglycemia that occurs during the neonatal period. Causes include inadequate hepatic glycogen stores, inadequate lipid stores, or inadequate amino acid muscle stores. Signs and symptoms include tachypnea, respiratory distress, tachycardia or bradycardia, lethargy, and seizures.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Hypoglycemia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_sg>Neonatal_Hypoglycemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Hypoglycemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Infectious_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Infectious_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infectious_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An infectious disorder that occurs during the neonatal period. Representative examples include streptococcal infection, E.coli infection, and bacterial meningitis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99231</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Infectious Disorder</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Infectious_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Infectious_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Jaundice -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Jaundice">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Jaundice"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99246</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Jaundice that appears during the neonatal period. In the majority of cases, it appears in the first week of life and is classified as physiologic due to accelerated destruction of erythrocytes and liver immaturity. In a minority of cases it is classified as non-physiologic, appearing in the first twenty four hours after birth, and is associated with underlying diseases including hemolytic disorders, polycythemia, and cephalohematoma.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Jaundice</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Jaundice</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Jaundices</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Jaundice_due_to_Delayed_Conjugation_from_Breast_Milk_Inhibitors -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Jaundice_due_to_Delayed_Conjugation_from_Breast_Milk_Inhibitors">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Jaundice"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Breast Milk Jaundice</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98846</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Jaundice in an otherwise healthy breast-fed newborn. It appears four to seven days after birth, lasts longer than the physiologic jaundice, and there are no identifiable causes.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Jaundice_due_to_Delayed_Conjugation_from_Breast_Milk_Inhibitors</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Jaundice_due_to_Delayed_Conjugation_from_Breast_Milk_Inhibitorses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Lupus_Erythematosus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Lupus_Erythematosus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A self-limited skin rash that appears in the neonatal period and usually resolves in four to six months after birth. It is caused by placental transfer of maternal autoantibodies, usually anti-Ro antibody. In a minority of cases, it is associated with congenital heart block, hepatitis, or thrombocytopenia. The mothers of the affected babies may be asymptomatic or suffer from systemic lupus erythematosus, Sjogren&apos;s syndrome, or rheumatoid arthritis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99236</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Lupus Erythematosus</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Lupus_Erythematosuses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Lupus_Erythematosus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Opiate_Withdrawal_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Opiate_Withdrawal_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Abstinence_Syndrome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A withdrawal syndrome that presents during the neonatal period and is caused by opioids abuse by the mother during pregnancy or abrupt discontinuation of opioid analgesics that are administered to the baby. It manifests with central nervous system abnormalities, vasomotor abnormalities, and respiratory abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99255</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Opiate Withdrawal Syndrome</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Opiate_Withdrawal_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Opiate_Withdrawal_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Research_Network_Terminology -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Research_Network_Terminology">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#NICHD_Subset"/>
        <Subset_Association1 rdf:datatype="&xsd;string"></Subset_Association1>
        <ID rdf:datatype="&xsd;string">Cxxxxx</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">NRNT</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal_Research_Network_Terminology</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Terminology developed to support the efforts of the Neonatal Research Network</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">Terminology for concepts associated with neonatal research contributed by four neonatal research networks: Vermont-Oxford Network (VON), Children&apos;s Hospital of Philadelphia (CHOP), NICHD Neonatal Research Network (NICHD-NRN) and NICHD Pediatric Terminology.</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Research_Network_Terminologies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Research_Network_Terminology</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Respiratory_Distress_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Respiratory_Distress_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Respiratory_System"/>
        <NCI_Definition rdf:datatype="&xsd;string">A condition of the newborn marked by dyspnea with cyanosis, most frequently occurring in premature infants, children of diabetic mothers and infants delivered by cesarean section, and sometimes with no predisposing cause.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C27560</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Respiratory Distress Syndrome</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Respiratory_Distress_Syndrome_in_the_Newborn</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Respiratory_Distress_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Respiratory_Distress_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Respiratory_System_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Respiratory_System_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A respiratory system disorder that occurs during the neonatal period. A representative example is the respiratory distress syndrome.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99232</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Respiratory System Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Respiratory_System_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Respiratory_System_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Rickets -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Rickets">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99233</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Rickets</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Rickets that usually affects premature infants. Factors that contribute to the development of neonatal rickets include calcium, phosphorus, or calciferol deficiency. It manifests with spontaneous fractures, respiratory distress, and growth developmental delays.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neonatal_Ricketses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neonatal_Rickets</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Stage -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Stage">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Child_Life_Stage"/>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage that begins at full term birth and continues until twenty-seven complete days of age.</NICHD_Definition>
        <ID rdf:datatype="&xsd;string">C89887</ID>
        <NCI_PT rdf:datatype="&xsd;string">Full Term Neonatal Stage</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Term Neonatal Stage</SYN>
        <NCI_Definition rdf:datatype="&xsd;string">The period at birth when a newborn is born after the full gestational period.</NCI_Definition>
        <ace_lexicon:CN_sg>Neonatal_Stage</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Stages</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Thrombocytopenia_due_to_Platelet_Alloimmunization -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Thrombocytopenia_due_to_Platelet_Alloimmunization">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neonatal_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C101200</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Neonatal Alloimmune Thrombocytopenia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Thrombocytopenia that is a result of incompatibilities between the platelets of the mother and the fetus.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neonatal_Thrombocytopenia_due_to_Platelet_Alloimmunization</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neonatal_Thrombocytopenia_due_to_Platelet_Alloimmunizations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A benign or malignant tissue growth resulting from uncontrolled cell proliferation. Benign neoplastic cells resemble normal cells without exhibiting significant cytologic atypia, while malignant cells exhibit overt signs such as dysplastic features, atypical mitotic figures, necrosis, nuclear pleomorphism, and anaplasia. Representative examples of benign neoplasms include papillomas, cystadenomas, and lipomas; malignant neoplasms include carcinomas, sarcomas, lymphomas, and leukemias.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3262</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neoplasm</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Neoplastic_Disease</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neoplasms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neoplasm</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm_of_Bone_Marrow -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm_of_Bone_Marrow">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Bone Marrow Neoplasm</NCI_PT>
        <ID rdf:datatype="&xsd;string">C35370</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Neoplasms that affect the bone marrow. Such neoplasms may arise in the bone marrow (e.g. myeloid leukemias) or may involve the bone marrow as secondary, metastatic tumors (e.g. metastatic carcinomas to the bone marrow).</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neoplasm_of_Bone_Marrows</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neoplasm_of_Bone_Marrow</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm_of_Heart -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm_of_Heart">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A benign or malignant, primary or metastatic neoplasm affecting the heart.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3081</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cardiac Neoplasm</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neoplasm_of_Hearts</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neoplasm_of_Heart</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm_of_Nervous_System -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm_of_Nervous_System">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A benign or malignant, primary or metastatic neoplasm involving the central or peripheral nervous system.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3268</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Nervous System Neoplasm</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neoplasm_of_Nervous_Systems</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neoplasm_of_Nervous_System</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nephroblastoma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nephroblastoma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An embryonal pediatric tumor of the kidney which may also be seen rarely in adults. The peak incidence of Wilms tumor is between the second and fifth year of life. Microscopically, it is composed of a mixture of cellular elements (blastemal, stromal, and epithelial). The most common sites of metastasis include the regional lymph nodes, lungs, and liver.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C40407</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Renal Wilms Tumor</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Nephroblastomas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Nephroblastoma</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nephrotic_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nephrotic_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Kidney_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A collection of symptoms that include severe edema, proteinuria, and hypoalbuminemia; it is indicative of renal dysfunction.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34845</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Nephrotic Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Nephrotic_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Nephrotic_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nervous_System_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nervous_System_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic or neoplastic disorder that affects the brain, spinal cord, or peripheral nerves.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26835</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Nervous System; Neurologic_Disorder</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Nervous System Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Nervous_System_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Nervous_System_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neural_Tube_Defect -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neural_Tube_Defect">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital defect characterized by failure of the neural tube to close completely; this results in the presence of openings in the brain or spinal cord. Examples of neural tube defects include encephalocele and spina bifida.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84923</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neural Tube Defect</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neural_Tube_Defect</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neural_Tube_Defects</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neuroblastoma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neuroblastoma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm_of_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A neuroblastic tumor characterized by the presence of neuroblastic cells, the absence of ganglion cells, and the absence of a prominent Schwannian stroma formation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3270</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neuroblastoma</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neuroblastomas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neuroblastoma</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neurocutaneous_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neurocutaneous_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A hereditary syndrome affecting the central nervous system that is associated with lesions of the skin and retina. Representative examples include neurofibromatosis, tuberous sclerosis, von Hippel-Lindau syndrome, and Sturge-Weber syndrome.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84348</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Phakomatosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neurocutaneous_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neurocutaneous_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neurodevelopmental_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neurodevelopmental_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">A childhood affliction that has a neurological basis and manifests as a developmental disability.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C89338</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neurodevelopmental Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neurodevelopmental_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neurodevelopmental_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neuroendocrine_Tumor -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neuroendocrine_Tumor">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A benign or malignant neoplasm composed of cells of neuroendocrine origin. Representative examples include paraganglioma, carcinoid tumor, and neuroendocrine carcinoma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3809</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neuroendocrine Neoplasm</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neuroendocrine_Tumors</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neuroendocrine_Tumor</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neurofibromatosis_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neurofibromatosis_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neurocutaneous_Syndrome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An autosomal dominant hereditary neoplastic syndrome. Two distinct clinicopathological entities are recognized: neurofibromatosis type 1 and neurofibromatosis type 2. Neurofibromatosis type 1 is associated with the presence of cafe-au-lait cutaneous lesions, multiple neurofibromas, malignant peripheral nerve sheath tumors, optic nerve gliomas, and bone lesions. Neurofibromatosis type 2 is associated with the presence of schwannomas, meningiomas, and gliomas.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C6727</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neurofibromatosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neurofibromatosis_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Neurofibromatosis_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neurological_Examination -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neurological_Examination">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Evaluation_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C81313</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neurologic Examination</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The assessment of the functionality of the brain, spinal column, and nerves.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Neurological_Examinations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Neurological_Examination</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Neurological_Finding -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Neurological_Finding">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A term that refers to the clinical manifestations resulting from pathologic processes that affect the central and peripheral nervous system.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3837</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Neurological Signs and Symptoms</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Neurological_Finding</ace_lexicon:CN_sg>
