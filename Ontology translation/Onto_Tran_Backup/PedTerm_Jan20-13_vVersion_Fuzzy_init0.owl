        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality of the heart characterized by the presence of three atria. The right or left atrium is divided into two parts by fibromuscular tissue or a membrane. It may be associated with other heart congenital abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84651</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cor Triatriatum</NCI_PT>
