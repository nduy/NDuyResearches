        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Physical_Symmetries</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Physical_Symmetry</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Physiologic_Lightening -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Physiologic_Lightening">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Intrapartum_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A physical feeling of being able to breathe better during late trimester of pregnancy when the baby starts to descend lower into the pelvic cavity.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92844</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Physiologic Lightening</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Physiologic_Lightening</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Physiologic_Lightenings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Placement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Placement">
