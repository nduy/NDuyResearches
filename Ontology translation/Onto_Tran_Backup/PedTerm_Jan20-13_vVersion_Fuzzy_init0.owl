    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Grade_III_Vesicoureteral_Reflux -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Grade_III_Vesicoureteral_Reflux">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vesicoureteric_Reflux"/>
        <ID rdf:datatype="&xsd;string">C98663</ID>
