        <ace_lexicon:CN_pl>Longitudinal_Fetal_Presentations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Longitudinal_Fetal_Presentation</ace_lexicon:CN_sg>
    </owl:Class>
    


