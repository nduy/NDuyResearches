        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C2943</ID>
        <NCI_PT rdf:datatype="&xsd;string">Choledochal Cyst</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Congenital cystic dilatation of the hepatic duct or bile duct.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
