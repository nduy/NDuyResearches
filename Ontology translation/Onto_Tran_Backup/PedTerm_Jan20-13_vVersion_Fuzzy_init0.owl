        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A symptom consisting of the involuntary expulsion of air from the nose.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50746</ID>
