        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Vesicoureteral reflux in which there is urine reflux into the ureter and renal pelvis. There is no dilatation of the ureter and the calyces.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Vesicoureteric Reflux, Grade II</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Grade_II_Vesicoureteral_Refluxes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Grade_II_Vesicoureteral_Reflux</ace_lexicon:CN_sg>
    </owl:Class>
    


