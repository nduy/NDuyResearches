        <NCI_PT rdf:datatype="&xsd;string">Persistent Fetal Tachycardia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Persistent_Fetal_Tachycardia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Persistent_Fetal_Tachycardias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Pulmonary_Hypertension_of_the_Newborn -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Persistent_Pulmonary_Hypertension_of_the_Newborn">
