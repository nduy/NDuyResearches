</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Narrowing of the laryngeal airway.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
