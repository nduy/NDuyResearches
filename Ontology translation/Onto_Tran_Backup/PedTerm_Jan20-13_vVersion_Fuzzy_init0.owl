        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Kernicterus_not_due_to_Isoimmunization</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Kernicterus_not_due_to_Isoimmunizations</ace_lexicon:CN_pl>
    </owl:Class>
    


