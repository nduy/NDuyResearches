        <ace_lexicon:CN_pl>Liver_Findings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Local_Anesthesia_Procedure -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Local_Anesthesia_Procedure">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anesthesia_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C81260</ID>
        <NCI_PT rdf:datatype="&xsd;string">Local Anesthesia Procedure</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The temporary suppression of sensation at a specific region of the body by pharmacological intervention. This type of anesthesia does not induce unconsciousness in the patient.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Local_Anesthesia_Procedures</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Local_Anesthesia_Procedure</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Lochial_Flow -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Lochial_Flow">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Postpartum_Process"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C78742</ID>
        <NCI_PT rdf:datatype="&xsd;string">Lochia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Vaginal discharge occurring during the post-partum period. It consists of a mixture of blood, mucus, and placental remnants.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Lochial_Flows</ace_lexicon:CN_pl>
