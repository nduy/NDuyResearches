        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Reflex"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C81181</ID>
        <NCI_PT rdf:datatype="&xsd;string">Infant Reflex</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Primitive reflex actions that newborns display in response to specific stimuli. These reflexes are involuntary and most disappear as the infant matures.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Infant_Reflexes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Infant_Reflex</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Infant_Stage -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Infant_Stage">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Child_Life_Stage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <ID rdf:datatype="&xsd;string">C89889</ID>
        <NCI_PT rdf:datatype="&xsd;string">Infancy</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The period of life between 28 days and 13 months of age.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Infant_Stages</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Infant_Stage</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Infarct -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Infarct">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hematological_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A localized pathological necrosis of tissue resulting from obstruction of the blood supply usually by a thrombus, an embolus, or vascular torsion.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C25738</ID>
        <NCI_PT rdf:datatype="&xsd;string">Infarction</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Infarcts</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Infarct</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Infarction_of_Spinal_Cord -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Infarction_of_Spinal_Cord">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Central_Nervous_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99063</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Ischemic necrosis of the spinal cord caused by occlusion of the arteries that supply blood to the spinal cord. Signs and symptoms include intermittent back pain, pain in the legs, paralysis, and incontinence.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Spinal Cord Infarction</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Infarction_of_Spinal_Cord</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Infarction_of_Spinal_Cords</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Infection_of_Skin -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Infection_of_Skin">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infectious_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An inflammatory process affecting the skin, caused by bacteria, viruses, parasites, or fungi. Examples of bacterial infection include carbuncles, furuncles, impetigo, erysipelas, and abscesses. Examples of viral infection include shingles, warts, molluscum contagiosum, and pityriasis rosea. Examples of parasitic infection include scabies and lice. Examples of fungal infection include athlete&apos;s foot, yeast infection, and ringworm.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35025</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Skin Infection</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Infection_of_Skins</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Infection_of_Skin</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Infectious_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Infectious_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder resulting from the presence and activity of a microbial, viral, or parasitic agent. It can be transmitted by direct or indirect contact.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26726</ID>
        <NCI_PT rdf:datatype="&xsd;string">Infectious Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Infectious_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Infectious_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Infective_Meningitis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Infective_Meningitis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Meningitis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C79598</ID>
        <NCI_PT rdf:datatype="&xsd;string">Infectious Meningitis</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Inflammation of the meninges of the brain and/or spinal cord caused by an infectious agent (viral, bacterial, or fungal). Symptoms include headache, fever, vomiting, neck stiffness, photophobia, confusion, and seizures.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Infective_Meningitises</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Infective_Meningitis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Infertility -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Infertility">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Female_Reproductive_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3836</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Inability to conceive for at least one year after trying and having unprotected sex. Causes of female infertility include endometriosis, fallopian tubes obstruction, and polycystic ovary syndrome. Causes of male infertility include abnormal sperm production or function, blockage of the epididymis, blockage of the ejaculatory ducts, hypospadias, exposure to pesticides, and health related issues.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Infertility</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Infertilities</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Infertility</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Inflammatory_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Inflammatory_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An infectious or non infectious disorder characterized by signs and symptoms derived from focal or extensive tissue infiltration by acute (e.g., polymorphonuclear) or chronic (e.g., lymphocytic-plasmacytic) inflammatory cells. Representative examples of infectious disorders include viral infections, bacterial infections, and parasitic infections. Representative examples of non-infectious inflammatory disorders include inflammatory bowel disease and inflammatory polyps.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C93210</ID>
        <NCI_PT rdf:datatype="&xsd;string">Inflammatory Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Inflammatory_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Inflammatory_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Influenza -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Influenza">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Viral_Disease"/>
        <NCI_Definition rdf:datatype="&xsd;string">An acute viral infection of the respiratory tract, occurring in isolated cases, in epidemics, or in pandemics; it is caused by serologically different strains of viruses (influenzaviruses) designated A, B, and C, has a 3-day incubation period, and usually lasts for 3 to 10 days. It is marked by inflammation of the nasal mucosa, pharynx, and conjunctiva; headache; myalgia; often fever, chills, and prostration; and occasionally involvement of the myocardium or central nervous system.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C53482</ID>
        <SYN rdf:datatype="&xsd;string">Flu</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Influenza</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Influenzas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Influenza</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Influenza_Vaccination -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Influenza_Vaccination">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Immunization"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C96408</ID>
        <NCI_PT rdf:datatype="&xsd;string">Influenza Vaccination</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The administration of live or attenuated influenza virus for the prophylaxis of influenza.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Influenza_Vaccination</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Influenza_Vaccinations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Inguinal_Hernia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Inguinal_Hernia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hernia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C34690</ID>
        <NCI_PT rdf:datatype="&xsd;string">Inguinal Hernia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The protrusion of a sac-like structure containing fibroadipose tissue through an abnormal opening in the inguinal region.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Inguinal_Hernia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Inguinal_Hernias</ace_lexicon:CN_pl>
    </owl:Class>
    


