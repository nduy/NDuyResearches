    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome characterized by the presence of congenital abnormalities that affect more than one organ or system.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99267</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Malformation Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Malformation_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Malformation_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_Syndrome_due_to_Known_Exogenous_Cause -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_Syndrome_due_to_Known_Exogenous_Cause">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_Syndrome"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome characterized by the presence of structural malformations that are present at birth and can be attributed to an exogenous cause.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101329</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Malformation Syndrome due to Known Exogenous Cause</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Malformation_Syndrome_due_to_Known_Exogenous_Cause</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Malformation_Syndrome_due_to_Known_Exogenous_Causes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_of_Thumb -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Malformation_of_Thumb">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality characterized by hypoplasia or absence of the thumb. It may be associated with other congenital abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98897</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Thumb Hypoplasia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Malformation_of_Thumbs</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Malformation_of_Thumb</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Metabolic_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Metabolic_Disease"/>
        <NCI_Definition rdf:datatype="&xsd;string">A group of disorders present at birth that involve genetic defects leading to disturbances in carbohydrate, lipid, lysosomal storage or amino acid metabolism in the body.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34816</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Metabolic Disorder</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Inborn_Error_of_Metabolism</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Metabolic_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Metabolic_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Methemoglobinemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Methemoglobinemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anemia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98898</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Methemoglobinemia</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Methemoglobinemia inherited in an autosomal recessive pattern. It is caused by deficiency of the enzyme NADH methemoglobin reductase or the presence of abnormal hemoglobin M. It presents with cyanosis early in life. There is no evidence of cardiopulmonary disease present.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Methemoglobinemias</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Methemoglobinemia</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Nephrotic_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Nephrotic_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Urinary_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal recessive inherited nephrotic syndrome that is present in the first week of life. It manifests with edema and proteinuria and usually has a poor prognosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C35337</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Nephrotic Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Nephrotic_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Nephrotic_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Omphalocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Omphalocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital defect in the muscles of the abdominal wall that results in the intestines and other abdominal organs developing outside the abdominal wall covered in a sac.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98997</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Omphalocele</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Omphaloceles</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Omphalocele</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Pelvic_Kidney -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Pelvic_Kidney">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Urinary_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality characterized by the failure of the kidney to ascend to its normal position and it remains in the pelvis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99006</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pelvic Kidney</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Pelvic_Kidneys</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Pelvic_Kidney</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Penoscrotal_Transposition -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Penoscrotal_Transposition">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Reproductive_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality characterized by the partial or complete transposition of the penis and scrotum. In cases of complete penoscrotal transposition, the scrotum is positioned anteriorly and above the penis. It may be associated with other congenital abnormalities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99010</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Penoscrotal Transposition</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Penoscrotal_Transposition</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Penoscrotal_Transpositions</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Phrenic_Nerve_Injury -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Phrenic_Nerve_Injury">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Traumatic_Injury"/>
        <ID rdf:datatype="&xsd;string">C103156</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Phrenic Nerve Injury</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Damage to the phrenic nerve that is present at birth.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Phrenic Nerve Injury, Congenital</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Phrenic_Nerve_Injury</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Phrenic_Nerve_Injuries</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Phrenic_Nerve_Palsy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Phrenic_Nerve_Palsy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <ID rdf:datatype="&xsd;string">C101199</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Phrenic Nerve Palsy</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Damage to the phrenic nerve that results in paralysis of the hemidiaphragm at birth.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Phrenic Nerve Palsy, Congenital</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Phrenic_Nerve_Palsies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Phrenic_Nerve_Palsy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Pigmented_Melanocytic_Nevus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Pigmented_Melanocytic_Nevus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A melanocytic nevus that is present at birth. It may present as a small macular, papular, or plaque-like lesion or as a large brown to black hairy skin lesion.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3944</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Melanocytic Nevus</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Pigmented_Melanocytic_Nevus</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Pigmented_Melanocytic_Nevuses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Posterior_Urethral_Valves -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Posterior_Urethral_Valves">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Urinary_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A developmental abnormality characterized by the presence of an obstructing membrane in the posterior urethra of the male newborn. It results in bladder obstruction.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99021</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Posterior Urethral Valves</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Posterior_Urethral_Valveses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Posterior_Urethral_Valves</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Postural_Scoliosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Postural_Scoliosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Scoliosis"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98899</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Postural Scoliosis</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Usually mild scoliosis that disappears when the person bends forward or sideways. The spine is structurally normal.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Postural_Scolioses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Postural_Scoliosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Pulmonary_Lymphangiectasis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Pulmonary_Lymphangiectasis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_Lung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in the lungs characterized by the presence of dilated lymphatic vessels in the interlobar, perivascular, and peribronchial areas of the lungs. Signs and symptoms appear at birth and include tachypnea, cyanosis, and respiratory distress.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99034</ID>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Pulmonary Lymphangiectasia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Congenital_Pulmonary_Lymphangiectases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Congenital_Pulmonary_Lymphangiectasis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Sequestration_of_Lung -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Sequestration_of_Lung">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_Lung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality of the lungs. It consists of a mass of lung parenchyma that does not communicate with the bronchial tree and receives its blood supply from the systemic circulation instead of the pulmonary circulation.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Bronchopulmonary Sequestration</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97124</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Sequestration_of_Lung</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Sequestration_of_Lungs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Skeletal_Dysplasia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Skeletal_Dysplasia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A term referring to disorders characterized by abnormalities in the development of bones and cartilage.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84978</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Osteochondrodysplasia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Skeletal_Dysplasia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Skeletal_Dysplasias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Supraventricular_Tachycardia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Supraventricular_Tachycardia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Supraventricular_Tachycardia"/>
        <NCI_Definition rdf:datatype="&xsd;string">An electrocardiographic finding of a tachycardia that originates above the ventricles that is present at birth.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101197</ID>
        <SYN rdf:datatype="&xsd;string">Congenital SVT; Supraventricular Tachycardia (SVT), Congential</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Congenital Supraventricular Tachycardia</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Congenital_Supraventricular_Tachycardia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Congenital_Supraventricular_Tachycardias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Systemic_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Systemic_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
