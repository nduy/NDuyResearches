        <ID rdf:datatype="&xsd;string">C98804</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Chylothorax that results from malignancies (usually lymphoma), trauma to the thoracic duct, tuberculosis, or sarcoidosis.</NCI_Definition>
