    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_Rate">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Numeric_Value"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C49678</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Respiratory Rate</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The rate of breathing (inhalation and exhalation) measured within in a unit time, usually expressed as breaths per minute.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Respiratory_Rates</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Respiratory_Rate</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_System_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_System_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Disease_or_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic or neoplastic disorder that affects the tracheobronchial tree and/or the lung parenchyma. Representative examples include infections, carcinomas, and lymphomas.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26871</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Respiratory System</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Respiratory Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Respiratory_System_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Respiratory_System_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_Tract_Aspiration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_Tract_Aspiration">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Respiratory_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Accidental inhalation of a foreign material into the lungs.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C83507</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Unintentional Material Aspiration</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Respiratory_Tract_Aspirations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Respiratory_Tract_Aspiration</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinal_Disorder -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinal_Disorder">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vision_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormal structure or function of the retina and its associated tissues.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26875</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinal Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinal_Disorder</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinal_Disorders</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinal_Examination -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinal_Examination">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Eye_/_Vision_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An examination of the retina of the eye using an ophthalmoscope.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101217</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinal Examination</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinal_Examination</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinal_Examinations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinitis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinitis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Inflammatory_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare inherited retinal dystrophy disorder characterized by spots of black bone-spicule pigmentation of the retinal pigment epithelium. It is manifested with decreased vision in low light or in the night, followed by decreased peripheral vision, and, eventual decreased central vision. It may lead to blindness.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85045</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinitis Pigmentosa</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">Retinitis is inflammation of the retina in the eye.</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinitis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinitises</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinoblastoma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinoblastoma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A malignant tumor that originates in the nuclear layer of the retina. As the most common primary tumor of the eye in children, retinoblastoma is still relatively uncommon, accounting for only 1% of all malignant tumors in pediatric patients. These tumors may be multifocal, bilateral, congenital, inherited, or acquired. Seventy-five percent of retinoblastomas are unilateral; 60% occur sporadically. A predisposition to retinoblastoma has been associated with 13q14 cytogenetic abnormalities. Patients with the inherited form also appear to be at increased risk for secondary nonocular malignancies such as osteosarcoma, malignant fibrous histiocytoma, and fibrosarcoma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C7541</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinoblastoma</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinoblastoma</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinoblastomas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinoic_Acid_Embryopathy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinoic_Acid_Embryopathy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetus_or_Newborn_Affected_by_Maternal_Transmission_of_Substance"/>
        <NCI_Definition rdf:datatype="&xsd;string">A rare syndrome that affects the fetus and is caused by the maternal use of retinoids during pregnancy. It is characterized by growth delay, skull and facial malformations, heart malformations, and central nervous system malformations.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98929</ID>
        <SYN rdf:datatype="&xsd;string">Fetal Isoretinoin Syndrome</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Fetal Retinoid Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Retinoic_Acid_Embryopathies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Retinoic_Acid_Embryopathy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Circulatory_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A bilateral retinopathy characterized by neovascularization, scarring, retinal detachment, and eventually blindness. It may be mild or severe. It occurs in babies born prematurely. Causes include oxygen toxicity and hypoxia.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34982</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurities</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Immature -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Immature">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <NCI_Definition rdf:datatype="&xsd;string">An immature state in which retinopathy of prematurity cannot be established.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101312</ID>
        <NCI_PT rdf:datatype="&xsd;string">Immature Retinopathy of Prematurity</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Retinopathy of Prematurity, Immature</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">Retinopathy of prematurity occurs in premature infants who are born before the retinal vessels complete their normal growth. It results in disorganized growth of retinal blood vessels, which may lead to scarring and retinal detachment.</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_Immature</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_Immatures</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_1_-_Demarcation_Line -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_1_-_Demarcation_Line">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An opthalmoscopic finding that refers to retinopathy of prematurity characterized by the presence of a faint demarcation line.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99047</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">Prior to the development of ROP in the premature infant, vascularization of the retina is incomplete or &quot;immature&quot;. In Stage 1: Demarcation Line is a thin but definite structure that separates the avascular retina anteriorly from the vascularized retina posteriorly. There is abnormal branching or arcading of vessels leading up to the demarcation line that is relatively flat, white, and lies within the plane of the retina.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity Stage 1 Demarcation Line</NCI_PT>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_Stage_1_-_Demarcation_Lines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_Stage_1_-_Demarcation_Line</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_2_-_Intraretinal_Ridge -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_2_-_Intraretinal_Ridge">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An opthalmoscopic finding that refers to retinopathy of prematurity characterized by the presence of an elevated ridge.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99048</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">Prior to the development of ROP in the premature infant, vascularization of the retina is incomplete or &quot;immature&quot;. In Stage 2: Intraretinal Ridge, the ridge arises from the demarcation line and has height and width, which extends above the plane of the retina. The ridge may change from white to pink and vessels may leave the plane of the retina posterior to the ridge to enter it.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity Stage 2 Intraretinal Ridge</NCI_PT>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_Stage_2_-_Intraretinal_Ridge</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_Stage_2_-_Intraretinal_Ridges</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_3_-_Ridge_with_Extraretinal_Fibrovascular_Proliferation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_3_-_Ridge_with_Extraretinal_Fibrovascular_Proliferation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An opthalmoscopic finding that refers to retinopathy of prematurity characterized by the presence of extraretinal fibrovascular tissue.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99049</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">Prior to the development of ROP in the premature infant, vascularization of the retina is incomplete or &quot;immature&quot;. In Stage 3: Ridge with extraretinal fibrovascular proliferation, the neovascularization extends from the ridge into the vitreous. This extraretinal proliferating tissue is continuous with the posterior aspect of the ridge, causing a ragged appearance as the proliferation becomes more extensive.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity Stage 3 Ridge with Extraretinal Fibroblastic Proliferation</NCI_PT>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_Stage_3_-_Ridge_with_Extraretinal_Fibrovascular_Proliferation</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_Stage_3_-_Ridge_with_Extraretinal_Fibrovascular_Proliferations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_4_-_Subtotal_Retinal_Detachment -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_4_-_Subtotal_Retinal_Detachment">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An opthalmoscopic finding that refers to retinopathy of prematurity characterized by the presence of subtotal retinal detachment.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99050</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">Prior to the development of ROP in the premature infant, vascularization of the retina is incomplete or &quot;immature&quot;. In Stage 4: Subtotal Retinal Detachment the retinal detachments are generally concave and most are circumferentially oriented. Retinal detachments usually begin at the point of fibrovascular attachment to the vascularized retina and the extent of detachment depends on the amount of neovascularization present.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity Stage 4 Subtotal Retinal Detachment</NCI_PT>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_Stage_4_-_Subtotal_Retinal_Detachments</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_Stage_4_-_Subtotal_Retinal_Detachment</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_5_-_Total_Retinal_Detachment -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_Stage_5_-_Total_Retinal_Detachment">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An opthalmoscopic finding that refers to retinopathy of prematurity characterized by the presence of total retinal detachment.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99051</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">Prior to the development of ROP in the premature infant, vascularization of the retina is incomplete or &quot;immature&quot;. In Stage 5: Total Retinal Detachment, the retinal detachments are generally tractional and usually funnel shaped. The configuration of the funnel itself is used for subdivision of this stage depending if the anterior and posterior portions are open or narrowed.</NICHD_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity Stage 5 Total Retinal Detachment</NCI_PT>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_Stage_5_-_Total_Retinal_Detachments</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_Stage_5_-_Total_Retinal_Detachment</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_in_Zone_1 -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_in_Zone_1">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99044</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity in Zone 1</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Retinopathy of prematurity located in zone 1 of the retina.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_in_Zone_1</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_in_Zone_1s</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_in_Zone_2 -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_in_Zone_2">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99045</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity in Zone 2</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Retinopathy of prematurity located in zone 2 of the retina.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_in_Zone_2</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_in_Zone_2s</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_in_Zone_3 -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_in_Zone_3">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99046</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity in Zone 3</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Retinopathy of prematurity located in zone 3 of the retina.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_in_Zone_3</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_in_Zone_3s</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_with_Plus_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity_with_Plus_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Retinopathy_of_Prematurity"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A stage of retinopathy of prematurity characterized by the presence of the following in at least two quadrants around the optic nerve: dilation and tortuosity of major retinal vasculature as a result of increased blood flow.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101036</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Retinopathy of Prematurity with Plus Disease</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Retinopathy_of_Prematurity_with_Plus_Diseases</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Retinopathy_of_Prematurity_with_Plus_Disease</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rett_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rett_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pervasive_Developmental_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A progressive neurologic disorder caused by mutations in the MECP2 gene on chromosome X. It almost exclusively affects girls. It is characterized by language and learning difficulties, poor communication skills, and repetitive hand motions. Other signs and symptoms include microcephaly, scoliosis, breathing abnormalities, and sleep disturbances.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75488</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Rett Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rett_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rett_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rh_Immune_Globulin_Administration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rh_Immune_Globulin_Administration">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Preventive_Intervention"/>
        <ID rdf:datatype="&xsd;string">C92947</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rh Immune Globulin Administration</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Rho(D) Immune Globulin Administration</SYN>
        <NCI_Definition rdf:datatype="&xsd;string">The administration of Rh Immune Globulin to a pregnant mother to ameliorate the effects of conflicting Rh factors during pregnancy.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rh_Immune_Globulin_Administrations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rh_Immune_Globulin_Administration</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rh_Incompatibility -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rh_Incompatibility">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Pregnancy_Complication"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A complication during pregnancy; it occurs when the mother is Rh-negative and the infant is Rh-positive. The mother&apos;s body develops antibodies against the fetal red blood cells leading to their destruction. This complication generally does not affect first-born Rh-positive babies. Rh-positive newborn babies from subsequent pregnancies develop complications of Rh incompatibility which include hemolysis, jaundice, enlarged liver and spleen, petechiae, hypotonia, neurologic damage, and heart problems.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84504</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rh Incompatibility</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rh_Incompatibilities</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rh_Incompatibility</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rh_factor_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rh_factor_Measurement">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Blood_Group_Antibody_Titer_Measurement"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An immunology test to measure for the presence of the Rh factor antigen in blood.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92948</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rh Factor Measurement</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Rh_factor_Measurement</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rh_factor_Measurements</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rhabdomyomatous_Neoplasm -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rhabdomyomatous_Neoplasm">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A benign neoplasm arising from striated muscle. It is characterized by the presence of rhabdomyoblasts.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3358</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rhabdomyoma</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rhabdomyomatous_Neoplasms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rhabdomyomatous_Neoplasm</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rhabdomyosarcoma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rhabdomyosarcoma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare aggressive malignant mesenchymal neoplasm arising from skeletal muscle. It usually occurs in children and young adults. Only a small percentage of tumors arise in the skeletal muscle of the extremities. The majority arise in other anatomical sites.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3359</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rhabdomyosarcoma</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Rhabdomyosarcoma</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rhabdomyosarcomas</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rhesus_Antibody_Titer_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rhesus_Antibody_Titer_Measurement">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Rh_factor_Measurement"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An immunology test that detects the quantity of anti-Rhesus antibodies in the serum of a pregnant woman.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99052</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rh Titer Measurement</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rhesus_Antibody_Titer_Measurements</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rhesus_Antibody_Titer_Measurement</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rhizomelic_Chondrodysplasia_Punctata_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rhizomelic_Chondrodysplasia_Punctata_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Connective_Tissue_Disorder"/>
        <NCI_Definition rdf:datatype="&xsd;string">An autosomal recessive inherited peroxisomal disorder caused by mutations in the PEX7, DHAPAT, and AGP genes. It is characterized by short limbs, bones and cartilage abnormalities, congenital cataracts, and severe mental retardation.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85047</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rhizomelic Chondrodysplasia Punctata</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Rhizomelic Dwarfism</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rhizomelic_Chondrodysplasia_Punctata_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rhizomelic_Chondrodysplasia_Punctata_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rhonchi -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rhonchi">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An abnormal sound similar to snoring heard on auscultation of the bronchial airways, suggesting a partial obstruction due to thick secretions, a muscular spasm, or a neoplasm.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87116</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rhonchi</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Rhonchi</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rhonchis</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rickets -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rickets">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Nutritional_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Bone softening and weakening usually caused by deficiency or impaired metabolism of vitamin D. Deficiency of calcium, magnesium, or phosphorus may also cause rickets. It predominantly affects children who suffer from severe malnutrition. It manifests with bone pain, fractures, muscle weakness, and skeletal deformities.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26878</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rickets</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Ricketses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rickets</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Right_Aortic_Arch -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Right_Aortic_Arch">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Great_Vessel_Abnormality"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">A congenital anomaly in which the aorta is displaced to the right and passes behind the esophagus, thus forming a vascular ring that may cause compression of the trachea and esophagus.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A syndrome resulting from structural defects of the arteries that arise from the aortic arch. Signs and symptoms include weakness, dizziness, arm numbness, blurred vision and transient ischemic attacks.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Aortic Arch Syndrome</NCI_PT>
        <ID rdf:datatype="&xsd;string">C34391</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Right_Aortic_Arches</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Right_Aortic_Arch</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Right_Hypoplastic_Heart_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Right_Hypoplastic_Heart_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Heart_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital cardiovascular disorder characterized by severe underdevelopment of the right side of the heart. The infants develop cyanosis shortly after birth. It is a condition that requires immediate emergency treatment.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99053</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypoplastic Right Heart Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Right_Hypoplastic_Heart_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Right_Hypoplastic_Heart_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Right_Occiput_Anterior -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Right_Occiput_Anterior">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anterior_Occiput"/>
        <NCI_Definition rdf:datatype="&xsd;string">A fetal position during delivery in which the fetus is in the birth canal and the back of the head is oriented towards the maternal right thigh region.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92871</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">ROA</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Right Occiput Anterior Presentation</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Right_Occiput_Anterior</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Right_Occiput_Anteriors</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Risk_Factor -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Risk_Factor">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Property_or_Attribute"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any aspect of an individual&apos;s life, behavior, an environmental exposure, or an inborn or inherited characteristic that increases the likelihood of a disease, condition or injury.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C17103</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Risk Factor</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Risk_Factors</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Risk_Factor</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Risk_Factor_Assessment -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Risk_Factor_Assessment">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Screening_or_Clinical_Tests_during_Pregnancy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A systematic gathering of information regarding the variables associated with an individual&apos;s increased risk of disease or infection.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C90498</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Risk Factor Assessment</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Risk_Factor_Assessments</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Risk_Factor_Assessment</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Robin_Sequence -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Robin_Sequence">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital malformation characterized by micrognathia, posterior retraction of the tongue, and cleft palate.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85010</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pierre Robin Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Robin_Sequence</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Robin_Sequences</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rooting_Reflex -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rooting_Reflex">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infant_Reflex"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An involuntary, primal response in the neonate to search for the nipple when the cheek is touched.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81320</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Rooting Reflex</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Rooting_Reflex</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rooting_Reflexes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rotavirus -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rotavirus">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Virus"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A genus of double stranded RNA viruses that carry 11 unique double helix molecules of RNA that encode one or two proteins each. The RNA is surrounded by a three-layered icosahedral protein capsid. Viral particles are up to 76.5 nm in diameter and are not enveloped.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C77199</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Rotavirus</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rotaviruses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rotavirus</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rotavirus_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rotavirus_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A viral vaccine that prevents against rotavirus infection, the leading cause of severe acute gastroenteritis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96394</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Rotavirus Vaccine</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rotavirus_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rotavirus_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Route_of_Administration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Route_of_Administration">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Technique"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <ID rdf:datatype="&xsd;string">C38114</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Designation of the part of the body through which or into which, or the way in which, the medicinal product is intended to be introduced. In some cases a medicinal product can be intended for more than one route and/or method of administration.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Route of Administration</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Route_of_Administrations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Route_of_Administration</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rubella_Immunization -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rubella_Immunization">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Immunization"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92872</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Rubella Immunization</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The administration of a live attenuated viral vaccine to prevent rubella infection.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Rubella_Immunization</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rubella_Immunizations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rubella_Infection -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rubella_Infection">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Viral_Disease"/>
        <NCI_Definition rdf:datatype="&xsd;string">A viral infection caused by the rubella virus. It is initially manifested with flu-like symptoms that last one or two days, followed by the development of a characteristic red rash which lasts from one to five days. The rash first appears in the neck and face. It subsequently spreads to the rest of the body.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85051</ID>
        <SYN rdf:datatype="&xsd;string">German Measles</SYN>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Rubella Infection</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Rubella_Infection</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rubella_Infections</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rubinstein-Taybi_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rubinstein-Taybi_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare genetic syndrome mapped to chromosome 16p13.3 and associated with mutations in the CREBBP gene. It is characterized by mental and growth retardation, distinctive facial features (prominent nose, low-set ears, microcephaly, and small mouth), and broad thumbs and great toes. Patients are at an increased risk of developing benign and malignant neoplasms, including nervous system neoplasms and malignant lymphoproliferative disorders.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75466</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rubinstein-Taybi Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Rubinstein-Taybi_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rubinstein-Taybi_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rupture_of_Membrane -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rupture_of_Membrane">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Intrapartum_Process"/>
        <NCI_Definition rdf:datatype="&xsd;string">Breaking or tearing of the amniotic membranes during childbirth leading to the leakage of amniotic fluid and the progression of labor.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92874</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Rupture of Membrane</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <SYN rdf:datatype="&xsd;string">amniorrhexis; breaking water</SYN>
        <ace_lexicon:CN_sg>Rupture_of_Membrane</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Rupture_of_Membranes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Russell-Silver_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Russell-Silver_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Developmental_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare inherited growth disorder characterized by growth retardation, feeding difficulties, failure to thrive, facial abnormalities and asymmetry of limbs. Camptodactyly or clinodactyly may be present.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85068</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Silver-Russell Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Russell-Silver_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Russell-Silver_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#S-Beta_Thalassemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#S-Beta_Thalassemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Thalassemia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder characterized by the body&apos;s inability to synthesize beta-globin chains, leading to the formation of abnormal hemoglobin and anemia. This inherited autosomal recessive blood disorder is caused by germline mutation of the HBB gene.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81288</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">S-Beta Thalassemia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>S-Beta_Thalassemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>S-Beta_Thalassemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#ST_Waveform_Analysis_Technology -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#ST_Waveform_Analysis_Technology">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Examination"/>
        <NCI_Definition rdf:datatype="&xsd;string">A method of fetal ECG surveillance during labor that monitors the ST segment, to indicate any fetal hypoxia.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92889</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">ST Waveform Analysis</NCI_PT>
        <SYN rdf:datatype="&xsd;string">STAN</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>ST_Waveform_Analysis_Technologies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>ST_Waveform_Analysis_Technology</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Agenesis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Agenesis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital abnormality characterized by partial or complete absence of the lower portion of the spine.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99054</ID>
        <NCI_PT rdf:datatype="&xsd;string">Caudal Regression Syndrome</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Sacral_Ageneses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Sacral_Agenesis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Dimple -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Dimple">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A sacral dimple, or pilonidal dimple, is a small hollow area or sinus present at birth and located just above the crease of the buttocks. In most cases, pilonidal dimples are benign and may just be accompanied by increased hair growth in the area.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87118</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sacral Dimple</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Sacral_Dimple</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Sacral_Dimples</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Meningocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Meningocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Meningocele"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in the sacral region of the spine in which the meninges protrude through a defect in the spinal column.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101212</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sacral Meningocele</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Sacral_Meningocele</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Sacral_Meningoceles</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Myelocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Myelocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Myelocele"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98900</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Herniation of spinal cord tissue and meninges through a defect in the sacral region of the vertebral column. The protrusion of the tissue is flush with the level of the skin surface.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sacral Myelocele</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Sacral_Myeloceles</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Sacral_Myelocele</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Myelomeningocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sacral_Myelomeningocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Myelomeningocele"/>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital abnormality in the sacral region of the spine, in which the spinal cord and meninges protrude through a defect in the spinal column. The protrusion is above the skin surface.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C101207</ID>
        <SYN rdf:datatype="&xsd;string">Congenital Sacral Meningocele</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sacral Myelomeningocele</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Sacral_Myelomeningoceles</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Sacral_Myelomeningocele</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sacrococcygeal_Teratoma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sacrococcygeal_Teratoma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A teratoma that is found at the base of the coccyx. It is the most commonly seen tumor in newborns.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99055</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sacrococcygeal Teratoma</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Sacrococcygeal_Teratomas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Sacrococcygeal_Teratoma</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Saethre-Chotzen_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Saethre-Chotzen_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Musculoskeletal_System"/>
        <NCI_Definition rdf:datatype="&xsd;string">A rare autosomal dominant syndrome caused by mutations in the TWIST1 gene. It is characterized by premature closure of skull bones resulting in abnormally shaped head, high forehead, hypertelorism, and facial asymmetry. It may be associated with fusion of certain fingers or toes.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Acrocephalosyndactyly Type III</SYN>
        <ID rdf:datatype="&xsd;string">C75034</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Type III Acrocephalosyndactyly</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Saethre-Chotzen_Syndrome</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Saethre-Chotzen_Syndromes</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sarcoma -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sarcoma">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neoplasm"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A usually aggressive malignant mesenchymal cell tumor most commonly arising from muscle, fat, fibrous tissue, bone, cartilage, and blood vessels. Sarcomas occur in both children and adults. The prognosis depends largely on the degree of differentiation (grade) of the tumor. Representative subtypes are liposarcoma, leiomyosarcoma, osteosarcoma, and chondrosarcoma.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C9118</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sarcoma</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Sarcomas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Sarcoma</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Scarf_Sign -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Scarf_Sign">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Newborn_Examination"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C89521</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Scarf Sign</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">When testing the newborn infant for neuromuscular maturity, the &quot;scarf sign&quot; test is carried out by drawing the newborn&apos;s arm across the chest to the opposite shoulder until resistance is felt. In term infants, the elbow should not cross the midline of the chest.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Scarf_Sign</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Scarf_Signs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Schizencephaly -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Schizencephaly">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Abnormality_of_the_Nervous_System"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare developmental abnormality characterized by the presence of clefs in the cerebral hemispheres. The abnormality may involve one or both cerebral hemispheres. Signs and symptoms include developmental delays, mental retardation, paralysis, presence of a small head, and seizures.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99056</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Schizencephaly</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Schizencephalies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Schizencephaly</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Schultze_Mechanism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Schultze_Mechanism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Delivery_of_Placenta"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C92846</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Placental Schultze Mechanism</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The separation of the placenta from the uterine wall during labor; it begins at the placental center and leads to an expulsion of the placenta after delivery of the baby.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Schultze_Mechanisms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Schultze_Mechanism</ace_lexicon:CN_sg>
    </owl:Class>
    


