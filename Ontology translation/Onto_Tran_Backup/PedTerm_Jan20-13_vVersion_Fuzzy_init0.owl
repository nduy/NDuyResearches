        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare syndrome caused by exposure of the fetus to valproic acid in the first three months of the pregnancy. It is characterized by musculoskeletal abnormalities, intellectual disability, spina bifida, and distinctive facial features.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98930</ID>
        <NCI_PT rdf:datatype="&xsd;string">Fetal Valproate Syndrome</NCI_PT>
