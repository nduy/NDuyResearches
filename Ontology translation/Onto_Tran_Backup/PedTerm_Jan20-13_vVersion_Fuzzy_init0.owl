        <ace_lexicon:CN_pl>Birth_Complications</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Birth_Complication</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Birth_Date -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Birth_Date">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Date"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Birth Date</NCI_PT>
        <ID rdf:datatype="&xsd;string">C68615</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
