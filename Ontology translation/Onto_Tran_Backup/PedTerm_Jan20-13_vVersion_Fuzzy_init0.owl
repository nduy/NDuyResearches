        <NCI_PT rdf:datatype="&xsd;string">Body Fluid or Substance</NCI_PT>
        <ID rdf:datatype="&xsd;string">C13236</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Material produced by living organisms; it can be a necessary constituent of, or product of an organismal process.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Biological_Substance</ace_lexicon:CN_sg>
