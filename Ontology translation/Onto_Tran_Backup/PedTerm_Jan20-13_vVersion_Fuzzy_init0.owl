</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Wharton&apos;s Jelly</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Mucous_Connective_Tissues</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Mucous_Connective_Tissue</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Mucus_Plug -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Mucus_Plug">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Biological_Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A mucus plug situated in the maternal cervical os during pregnancy that prevents entry of bacteria into the uterus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92752</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cervical Mucus Plug</NCI_PT>
