    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ounce -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ounce">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Unit_of_Measure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C48519</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Ounce</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The traditional unit of mass. The avoirdupois ounce is equal to 1/16 pound, or 28.3495 grams, or 0.911 457 troy ounce.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Ounces</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Ounce</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ovalocytosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ovalocytosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hematopoietic_System_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A peripheral blood finding in which a large number of erythrocytes are shaped in a slightly oval-shaped form.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C36293</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Ovalocytosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Ovalocytoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Ovalocytosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ovarian_Cyst -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ovarian_Cyst">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Cyst"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A cyst that arises from the ovary. Representative examples include simple, complex, corpus luteum, and endometrioid cysts. Symptoms include pelvic and abdominal pain and irregular periods.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3300</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Ovarian Cyst</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ovarian_Cyst</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ovarian_Cysts</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ovarian_Pregnancy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ovarian_Pregnancy">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Ectopic_Pregnancy"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An ectopic pregnancy of unknown etiology that occurs in the ovary instead of the uterine corpus. It may result in severe intra-abdominal bleeding.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92945</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Ovarian Pregnancy</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ovarian_Pregnancy</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ovarian_Pregnancies</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ovarian_Torsion -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ovarian_Torsion">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Female_Reproductive_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99084</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Ovarian Torsion</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Twisting of the ovary resulting in the cutoff of the blood supply to the ovary. It may develop in an enlarged or normal ovary and in the vast majority of cases is unilateral. Signs and symptoms include acute lower abdominal pain, nausea, vomiting, and fever.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Ovarian_Torsions</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Ovarian_Torsion</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ovulation -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ovulation">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Reproductive_Process"/>
        <ID rdf:datatype="&xsd;string">C66849</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Ovulation</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Release of Egg</SYN>
        <NCI_Definition rdf:datatype="&xsd;string">The discharge of a secondary oocyte from a vesicular follicle of the ovary.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Ovulations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Ovulation</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Oxygen_Saturation_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Oxygen_Saturation_Measurement">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Diagnostic_Procedure"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C60832</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Oxygen Saturation Measurement</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The determination of oxygen-hemoglobin saturation of blood either by withdrawing a sample and passing it through a classical photoelectric oximeter or by electrodes attached to some translucent part of the body like finger, earlobe, or skin fold. It includes non-invasive oxygen monitoring by pulse oximetry.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Oxygen_Saturation_Measurements</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Oxygen_Saturation_Measurement</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Oxytocin -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Oxytocin">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Biological_Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C2283</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Oxytocin</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Oxytocin (125 aa, ~13kDa) is encoded by the human OXT gene. This protein plays a role in smooth muscle contraction in both the mammary gland and uterus. Oxytocin also is involved in maternal-newborn bonding, cognition and many other psychological and physiological processes.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Oxytocins</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Oxytocin</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pain -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pain">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3303</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Pain</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The sensation of discomfort, distress, or agony, resulting from the stimulation of specialized nerve endings.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pains</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pain</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pallister-Killian_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pallister-Killian_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Genetic_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A very rare chromosomal disorder caused by tetrasomy of chromosome 12p. It is characterized by severe mental retardation, prominent forehead, sparse temporofrontal hair, hypertelorism, short nose, and streaks of hypopigmented skin.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C75458</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pallister-Killian Syndrome</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pallister-Killian_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pallister-Killian_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pallor -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pallor">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <NCI_Definition rdf:datatype="&xsd;string">An unusual or extreme paleness, state of decreased skin coloration.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50685</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">On_Examination_-_Color_Pale</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Pallor</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pallors</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pallor</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Panhypopituitarism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Panhypopituitarism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition of diminution or cessation of secretion of one or more hormones from the anterior pituitary gland. This may result from surgical or radiation ablation, non-secretory pituitary neoplasms, metastatic tumors, infarction, pituitary apoplexy, infiltrative or granulomatous processes, and other conditions.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C62591</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypopituitarism</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Panhypopituitarisms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Panhypopituitarism</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Panic_Disorder_with_Agoraphobia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Panic_Disorder_with_Agoraphobia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anxiety_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder in which an individual experiences recurrent, unexpected panic attacks and persistent concern about having additional panic attacks. Agoraphobia is a component of this disorder.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97194</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Panic Disorder with Agoraphobia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Panic_Disorder_with_Agoraphobia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Panic_Disorder_with_Agoraphobias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Panic_Disorder_without_Agoraphobia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Panic_Disorder_without_Agoraphobia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Anxiety_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder in which an individual experiences recurrent, unexpected panic attacks and persistent concern about having additional panic attacks. Agoraphobia is not a component of this disorder.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97193</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Neurological Development Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Panic Disorder without Agoraphobia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Panic_Disorder_without_Agoraphobia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Panic_Disorder_without_Agoraphobias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pap_Smear -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pap_Smear">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Preventive_Intervention"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A sample of secretions and superficial cells of the body of uterus, cervix, and ovaries; examined with a microscope to detect any abnormal cells.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C17348</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Papanicolaou Smear Procedure</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Pap_Smears</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Pap_Smear</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Paralysis_of_Diaphragm -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Paralysis_of_Diaphragm">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Musculoskeletal_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C99017</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Damage to the phrenic nerve that results in paralysis of the hemidiaphragm.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Phrenic Nerve Palsy</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Paralysis_of_Diaphragms</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Paralysis_of_Diaphragm</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Paralytic_Syndrome -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Paralytic_Syndrome">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Nervous_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C3310</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Paralysis</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">Partial or complete loss of function of one or more muscles. It is usually caused by damage to the nervous system.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Paralytic_Syndromes</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Paralytic_Syndrome</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Parasitic_Disease -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Parasitic_Disease">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Infectious_Disease"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A successful invasion of a host by an organism that uses the host for food and shelter.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C27864</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Parasitic Infection</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Parasitic_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Parasitic_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Parenteral_Route_of_Administration -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Parenteral_Route_of_Administration">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Route_of_Administration"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Administration of a substance by some means other than through the gastrointestinal tract: usually through injection, infusion, or implantation. Predominantly, the drug action is systemic, but in some cases, it is confined to local area.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C38291</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Parenteral Route of Administration</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Parenteral_Route_of_Administration</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Parenteral_Route_of_Administrations</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Partial_Anomalous_Pulmonary_Venous_Connection -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Partial_Anomalous_Pulmonary_Venous_Connection">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Congenital_Anomaly_of_Pulmonary_Veins"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital heart disorder in which one or two pulmonary veins are not connected to the left atrium and drain into the right atrium instead. It may lead to arrhythmias and pulmonary hypertension.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99004</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Partial Anomalous Pulmonary Venous Return</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Partial_Anomalous_Pulmonary_Venous_Connection</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Partial_Anomalous_Pulmonary_Venous_Connections</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Pass -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Pass">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Indicator"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C81275</ID>
