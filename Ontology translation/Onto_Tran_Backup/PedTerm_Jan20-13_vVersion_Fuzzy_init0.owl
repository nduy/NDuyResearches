    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Elliptocytosis -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Elliptocytosis">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Hematopoietic_System_Finding"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A peripheral blood finding in which a large number of erythrocytes are shaped in an elliptical form.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3004</ID>
        <NCI_PT rdf:datatype="&xsd;string">Elliptocytosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">Elliptocytosis, also known as ovalocytosis, is an inherited blood disorder in which an abnormally large number of the patient&apos;s erythrocytes (i.e. red blood cells) are elliptical rather than the typical biconcave disc shape. It is one of many red-cell membrane defects. In its severe forms, this disorder predisposes to haemolytic anaemia.</NICHD_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Elliptocytoses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Elliptocytosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Embryo_Transfer -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Embryo_Transfer">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Conception_Method"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C16541</ID>
        <NCI_PT rdf:datatype="&xsd;string">Embryo Transfer</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Refers to a step in the process of in vitro fertilization (IVF) whereby one or several embryos are removed from an embryo culture and placed into the uterus of the female with the intent to establish a pregnancy.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Embryo_Transfers</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Embryo_Transfer</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Embryonic_Stage -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Embryonic_Stage">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Child_Life_Stage"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">A human life stage, during prenatal development, that begins at fertilization and typically continues until the end of eight weeks after fertilization, with full formation of the embryo.</NICHD_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A stage of life in which an embryo is developing. The stage terminates with the complete formation of the embryo.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C99135</ID>
        <NCI_PT rdf:datatype="&xsd;string">Embryonic Stage</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association2>
        <ace_lexicon:CN_sg>Embryonic_Stage</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Embryonic_Stages</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Emergency_Caesarean_Section -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Emergency_Caesarean_Section">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Caesarian_Section"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A cesarean section that is unanticipated and carried out during the labor process when it is determined that a vaginal method of delivery would be risky.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92772</ID>
        <NCI_PT rdf:datatype="&xsd;string">Emergency Caesarean Section</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Emergency_Caesarean_Sections</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Emergency_Caesarean_Section</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Encephalocele -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Encephalocele">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Neural_Tube_Defect"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A congenital neural tube closure defect resulting in the protrusion of the brain through a skull opening. When the protrusion includes the meninges, the term encephalomeningocele is used.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84687</ID>
        <NCI_PT rdf:datatype="&xsd;string">Encephalocele</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Encephaloceles</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Encephalocele</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Encephalomalacia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Encephalomalacia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Brain_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
