        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Alterations in the skin&apos;s appearance during pregnancy due to hormonal level changes.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C92856</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pregnancy Related Skin Change</NCI_PT>
