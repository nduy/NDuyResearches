        <ace_lexicon:CN_sg>Allergen</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Allergens</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Allergic_Reaction -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Allergic_Reaction">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Signs_or_Symptoms"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A local or general reaction of an organism following contact with a specific allergen to which it has been previously exposed and to which it has become sensitized.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3114</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hypersensitivity</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
