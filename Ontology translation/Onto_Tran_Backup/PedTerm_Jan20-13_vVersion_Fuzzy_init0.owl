        <ace_lexicon:CN_pl>Encephalopathies</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Encephalopathy</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Endemic_Cretinism -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Endemic_Cretinism">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Endocrine_System_Disorder"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98921</ID>
        <NCI_PT rdf:datatype="&xsd;string">Endemic Cretinism</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Severely reduced physical and mental growth associated with pyramidal and extrapyramidal signs and symptoms, due to dietary iodine deficiency.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Endemic_Cretinism</ace_lexicon:CN_sg>
