        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Quantitative_Concept"/>
        <ID rdf:datatype="&xsd;string">C92907</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Relaxation Time between Uterine Contractions</SYN>
        <NCI_Definition rdf:datatype="&xsd;string">The time interval between uterine contractions during labor.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Uterine Contraction Interval</NCI_PT>
