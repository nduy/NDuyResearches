    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sickle_Cell-Beta-Thalassemia -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Sickle_Cell-Beta-Thalassemia">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Thalassemia"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A heterozygous state in which a person has a hemoglobin S allele along with a beta-thalassemia allele. The severity of the condition is determined to a large extent by the quantity of normal hemoglobin produced by the beta-thalassemia gene.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C95539</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Sickle Beta Thalassemia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
