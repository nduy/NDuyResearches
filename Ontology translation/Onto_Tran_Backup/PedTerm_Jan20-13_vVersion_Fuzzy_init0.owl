        <NCI_Definition rdf:datatype="&xsd;string">A very rare congenital syndrome characterized by hypoplasia of the optic nerve, impaired vision, absence of the septum pellucidum and hypopituitarism.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C85063</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Septo-Optic Dysplasia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
