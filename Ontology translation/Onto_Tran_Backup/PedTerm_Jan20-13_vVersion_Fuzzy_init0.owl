    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hormone_Measurement -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hormone_Measurement">
