    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Intrapartum_Cardiotocography">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Fetal_Examination"/>
