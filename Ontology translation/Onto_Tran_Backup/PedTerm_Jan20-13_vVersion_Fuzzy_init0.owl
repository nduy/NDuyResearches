        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A test developed at the University of Colorado Medical Center to assess the developmental status of infants and children from birth to six years of age.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C81245</ID>
        <NCI_PT rdf:datatype="&xsd;string">Denver Development Screening Test</NCI_PT>
