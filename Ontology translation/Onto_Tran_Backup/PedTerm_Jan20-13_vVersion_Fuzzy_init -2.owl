        <NCI_Definition rdf:datatype="&xsd;string">A type of labor where the labor pain or discomfort is felt by the pregnant mother in her back.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Back Labor</NCI_PT>
