    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Non -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Non">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
