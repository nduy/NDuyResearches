    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Khoc_gao -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Khoc_gao">
