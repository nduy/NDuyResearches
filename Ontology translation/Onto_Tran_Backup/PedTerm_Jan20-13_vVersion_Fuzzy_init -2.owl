        <ID rdf:datatype="&xsd;string">C87103</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Newborn Heart Rate</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The number of heartbeats of the newborn per minute; the normal range is 100 - 180 heartbeats per minute.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Newborn_Heart_Rate</ace_lexicon:CN_sg>
