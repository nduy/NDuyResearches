    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tran_duong_chap_mang_phoi_mac_phai -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tran_duong_chap_mang_phoi_mac_phai">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Tran_duong_chap_mang_phoi"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Acquired Chylothorax</NCI_PT>
        <ID rdf:datatype="&xsd;string">C98804</ID>
