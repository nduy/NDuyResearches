    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Chi_so_APGAR">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Tri_so"/>
        <NCI_PT rdf:datatype="&xsd;string">APGAR Score</NCI_PT>
        <ID rdf:datatype="&xsd;string">C73437</ID>
        <SYN rdf:datatype="&xsd;string">Component_of_Apgar_Score</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The numerical sum between zero and ten that is computed from individual values of zero to two that are assigned to five different areas of interest in newborn screenings. These areas are breathing, muscle tone, pulse rate, reflex irritability and skin color.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>APGAR_Score</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>APGAR_Scores</ace_lexicon:CN_pl>
    </owl:Class>
    


