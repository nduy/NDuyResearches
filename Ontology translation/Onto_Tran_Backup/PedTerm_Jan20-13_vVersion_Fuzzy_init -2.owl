        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A gliding joint between the distal ends of the tibia and fibula and the proximal end of the talus.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Ankle Joint</NCI_PT>
        <ID rdf:datatype="&xsd;string">C32078</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Ankle_Joint</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Ankle_Joints</ace_lexicon:CN_pl>
