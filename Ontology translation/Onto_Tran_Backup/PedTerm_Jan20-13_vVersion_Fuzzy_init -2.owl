        <ace_lexicon:CN_sg>Fetal_Heart_Rate</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Fetal_Heart_Rates</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nhip_tim_thai_co_so -->

