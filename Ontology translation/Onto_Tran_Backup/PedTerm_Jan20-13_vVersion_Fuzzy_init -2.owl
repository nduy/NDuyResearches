        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The reflex act of ejecting the contents of the stomach through the mouth.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Vomiting</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Vomiting</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Vomitings</ace_lexicon:CN_pl>
    </owl:Class>
    


