        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Clubbing_of_Fingerses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Clubbing_of_Fingers</ace_lexicon:CN_sg>
    </owl:Class>
    


