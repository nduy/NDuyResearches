        <NCI_Definition rdf:datatype="&xsd;string">A sequence of decimal digits (0-9) that is used for identifying a destination telephone line or other device in a telephone network.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C40978</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
