        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hand</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hands</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ten_nguoi -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ten_nguoi">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Thong_tin_ca_nhan"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A word or group of words indicating the identity of a person usually consisting of a first (personal) name and a last (family) name with an optional middle name. In some cultural traditions the family name comes first.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C25191</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Person Name</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Person_Names</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Person_Name</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tetanus_Toxoid_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tetanus_Toxoid_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Toxoid_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A preparation of formaldehyde-deactivated toxin isolated from the bacterium Clostridium tetani. Tetanus toxoid is used for booster injection and can stimulate the production of antitoxin antibodies. This agent may be used as an adjuvant in cancer vaccines.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2660</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Tetanus Toxoid Vaccine</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Tetanus_Toxoid_Vaccine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Tetanus_Toxoid_Vaccines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tetanus_and_Diphtheria_Toxoids_Adsorbed -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tetanus_and_Diphtheria_Toxoids_Adsorbed">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Toxoid_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A sterile, intramuscular suspension of alum (aluminum potassium sulfate)-precipitated toxoids indicated for active immunization for the prevention of tetanus and diphtheria for use in persons 7 years of age or older.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96405</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Tetanus and Diphtheria Toxoids Adsorbed</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Tetanus_and_Diphtheria_Toxoids_Adsorbeds</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Tetanus_and_Diphtheria_Toxoids_Adsorbed</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tho_bat_thuong -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tho_bat_thuong">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A change from the normal breathing pattern in an infant, child, or adult, in terms of the amplitude and frequency of inhalations and exhalations.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87089</ID>
        <NCI_PT rdf:datatype="&xsd;string">Irregular Respiration</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Irregular_Breathings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Irregular_Breathing</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tho_yeu -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tho_yeu">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A symptom and a finding during physical examination, characterized by a high-pitched, whistling sound during breathing. It results from the narrowing or obstruction of the respiratory airways. The most common causes of wheezing are asthma, chronic obstructive pulmonary disease, tracheobronchitis, and pulmonary edema.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C78718</ID>
        <ID rdf:datatype="&xsd;string">C87129</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Shallow inhalations and exhalations that indicate respiratory distress.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Weak Breathing</NCI_PT>
        <NCI_PT rdf:datatype="&xsd;string">Wheezing</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Wheezing</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Wheezings</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Weak_Breathing</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Weak_Breathings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Thoai_hoa_xuong_xop_cua_he_than_kinh_trung_uong -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Thoai_hoa_xuong_xop_cua_he_than_kinh_trung_uong">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_va_trieu_chung_o_he_than_kinh_trung_uong"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A disorder that belongs in the group of leukodystrophies. It is caused by mutations in the ASPA gene which is responsible for the production of the enzyme aspartoacylase. It is characterized by spongy degeneration of the white matter of the brain. Signs and symptoms appear in infancy and include mental retardation, loss of motor skills, abnormal muscle tone, feeding difficulties and a very large head.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C84611</ID>
        <NCI_PT rdf:datatype="&xsd;string">Canavan Disease</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">Spongy degeneration of central nervous system , spongy degeneration of white matter a rare hereditary form of leukodystrophy of early onset in which widespread demyelination and vacuolation of cerebral white matter gives it a spongy appearance; there is mental retardation, megalocephaly, atony of neck muscles, limb spasticity, and blindness, with death in infancy.</NICHD_Definition>
        <ace_lexicon:CN_pl>Central_Nervous_System_Spongy_Degenerations</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Central_Nervous_System_Spongy_Degeneration</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Thong_tin_ca_nhan -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Thong_tin_ca_nhan">
