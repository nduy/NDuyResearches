    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Khop_khuy_tay">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Phan_co_the"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A type of hinge joint located between the forearm and upper arm.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C32497</ID>
        <NCI_PT rdf:datatype="&xsd;string">Elbow Joint</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
