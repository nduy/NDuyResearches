    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Allergen -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Allergen">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A substance that elicits an allergic reaction.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Allergen</NCI_PT>
        <ID rdf:datatype="&xsd;string">C62651</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Allergen</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Allergens</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Amniotic_Fluid -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Amniotic_Fluid">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Biological_Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Amniotic Fluid</NCI_PT>
        <ID rdf:datatype="&xsd;string">C13188</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The fluid within the amniotic cavity which surrounds and protects the developing embryo. It is initially produced by the amnion and then later by the lungs and kidneys. The amount at term normally varies from 500 to 2000 ml.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Amniotic_Fluids</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Amniotic_Fluid</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Bacterial_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Bacterial_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any vaccine created by reducing the virulence of bacteria but still keeping the bacteria viable (live). In the production of an attenuated vaccine, the infectious agent is altered so that it becomes harmless or less virulent. This is in contrast to those vaccines produced by &quot;killing&quot; the pathogen (inactivated vaccine).</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Attenuated Bacteria Vaccine</NCI_PT>
        <ID rdf:datatype="&xsd;string">C62761</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Attenuated_Live_Bacterial_Vaccine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Attenuated_Live_Bacterial_Vaccines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Any vaccine created by reducing the virulence of the infectious agent but still keeping the agent viable (live). In the production of an attenuated vaccine, the infectious agent is altered so that it becomes harmless or less virulent. This is in contrast to those vaccines produced by killing the pathogen (inactivated vaccine).</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Attenuated Live Vaccine</NCI_PT>
        <ID rdf:datatype="&xsd;string">C97116</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Attenuated_Live_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Attenuated_Live_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Attenuated Live Virus Vaccine</NCI_PT>
        <ID rdf:datatype="&xsd;string">C1920</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Live vaccines prepared from microorganisms which have undergone physical adaptation (e.g., by radiation or temperature conditioning) or serial passage in laboratory animal hosts or infected tissue/cell cultures, in order to produce avirulent mutant strains capable of inducing protective immunity. Live-attenuated vaccines are used when a CD8+ T Cell (cellular cytotoxicity) response is desired.</NCI_Definition>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Attenuated_Live_Virus_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Attenuated_Live_Virus_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ban_chan -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ban_chan">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Phan_co_the"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C32622</ID>
        <NCI_PT rdf:datatype="&xsd;string">Foot</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The structure found below the ankle joint required for locomotion.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Foot</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Feet</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_he_ho_hap -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_he_ho_hap">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_hoac_Roi_loan"/>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic or neoplastic disorder that affects the tracheobronchial tree and/or the lung parenchyma. Representative examples include infections, carcinomas, and lymphomas.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26871</ID>
        <SYN rdf:datatype="&xsd;string">Disorder of Respiratory System</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Respiratory Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Respiratory_System_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Respiratory_System_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_hoac_Roi_loan -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_hoac_Roi_loan">
        <NCI_Definition rdf:datatype="&xsd;string">Any abnormal condition of the body or mind that causes discomfort, dysfunction, or distress to the person affected or those in contact with the person. The term is often used broadly to include injuries, disabilities, syndromes, symptoms, deviant behaviors, and atypical variations of structure and function.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2991</ID>
        <SYN rdf:datatype="&xsd;string">Disease</SYN>
        <NCI_PT rdf:datatype="&xsd;string">Disease or Disorder</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_pl>Disease_or_Disorders</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Disease_or_Disorder</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_phoi_ke -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_phoi_ke">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_phoi_man_tinh"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C26869</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Chronic progressive interstitial lung disorder characterized by the replacement of the lung tissue by connective tissue, leading to progressive dyspnea, respiratory failure, or right heart failure. Causes include chronic inflammatory processes, exposure to environmental irritants, radiation therapy, autoimmune disorders, certain drugs, or it may be idiopathic (no identifiable cause).</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Pulmonary Fibrosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Interstitial_Lung_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Interstitial_Lung_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_phoi_man_tinh -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Benh_phoi_man_tinh">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Roi_loan_phoi"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A non-neoplastic disorder of the lungs. Representative examples include chronic obstructive A persistent non-neoplastic disorder of the lungs. Representative examples include: chronic obstructive pulmonary disease, chronic bronchitis, emphysema, pulmonary fibrosis, pneumoconiosis, asbestosis, atelectasis, radiation induced pneumonitis, and radiation fibrosis.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98541</ID>
        <NCI_PT rdf:datatype="&xsd;string">Chronic Lung Disorder</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">Chronic lung disease (CLD) is a general term for long-term respiratory problems in premature babies. It is also known as bronchopulmonary dysplasia (BPD).Chronic lung disease is a condition in which damaged tissue in a newborn baby&apos;s lungs causes breathing and health problems. The lungs trap air or collapse, fill with fluid, and produce extra mucus.</NICHD_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <ace_lexicon:CN_sg>Chronic_Lung_Disease</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Chronic_Lung_Diseases</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Bilirubin -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Bilirubin">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Biological_Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A dark orange, yellow pigment that is the product of the breakdown of iron in the blood; it is conjugated in the liver and excreted in the bile.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Bilirubin</NCI_PT>
        <ID rdf:datatype="&xsd;string">C305</ID>
