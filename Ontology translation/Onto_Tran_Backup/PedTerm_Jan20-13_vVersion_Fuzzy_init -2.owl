</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Polyvalent Vaccine</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Polyvalent_Vaccine</ace_lexicon:CN_sg>
