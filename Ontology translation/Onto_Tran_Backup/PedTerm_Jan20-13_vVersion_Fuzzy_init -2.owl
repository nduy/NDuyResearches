</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Pound</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The traditional unit of mass. By international agreement, one avoirdupois pound is equal to exactly 0.453 592 37 kilogram, 16 ounces, or 1.215 28 troy pounds.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
