        <NCI_PT rdf:datatype="&xsd;string">Newborn Respiratory Rate</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The number of inhalations and exhalations of the newborn per minute; the normal range is 30 - 60 breaths per minute.</NCI_Definition>
