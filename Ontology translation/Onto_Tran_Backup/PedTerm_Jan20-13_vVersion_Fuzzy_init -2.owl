    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ngon_tay_hinh_chuy -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ngon_tay_hinh_chuy">
