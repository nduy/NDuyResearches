        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The statistical characterization of human populations or segments of human populations (e.g., characterization by age, sex, race, or income).</NCI_Definition>
