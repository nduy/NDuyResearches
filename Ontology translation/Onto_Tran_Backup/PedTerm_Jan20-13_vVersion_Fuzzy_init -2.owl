        <ID rdf:datatype="&xsd;string">C79608</ID>
        <NCI_PT rdf:datatype="&xsd;string">Laryngeal Stenosis</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">Laryngeal stenosis is a congenital or acquired narrowing of the upper airway that results in difficulty breathing.</NICHD_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Narrowing of the laryngeal airway.</NCI_Definition>
