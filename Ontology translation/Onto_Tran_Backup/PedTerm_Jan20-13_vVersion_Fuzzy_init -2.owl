        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C103191</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Episodes of cyanosis during the perinatal period.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Perinatal Cyanotic Attack</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Perinatal_Cyanotic_Attacks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Perinatal_Cyanotic_Attack</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim_co_the -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim_co_the">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Blue- or purplish-colored body; this is caused by excessive amounts of deoxygenated hemoglobin in the skin vessels of the body.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87065</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cyanotic Body</NCI_PT>
