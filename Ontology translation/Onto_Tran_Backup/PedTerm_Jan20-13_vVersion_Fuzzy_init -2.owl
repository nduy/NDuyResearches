        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The external sex organs.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Genitalia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Genitalias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Co_rut_lien_suon -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Co_rut_lien_suon">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <ID rdf:datatype="&xsd;string">C87087</ID>
        <NCI_PT rdf:datatype="&xsd;string">Intercostal Retractions</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Intercostal_Recession</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The marked inward movement of the muscles between the ribs during inhalation; they indicate that there is reduced pressure in the chest cavity and can be a sign of breathing difficulties.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Intercostal_Retractionses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Intercostal_Retractions</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Co_the_doi_xung -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Co_the_doi_xung">
