        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A vaccine designed to elicit an immune response either to more than one infectious agent or to several different antigenic determinants of a single agent.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C2848</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
