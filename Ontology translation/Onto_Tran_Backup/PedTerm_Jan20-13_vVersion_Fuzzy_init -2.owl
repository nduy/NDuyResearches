        <ace_lexicon:CN_sg>Laryngeal_Stenosis</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Hepatitis_A_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Hepatitis_A_Vaccine">
