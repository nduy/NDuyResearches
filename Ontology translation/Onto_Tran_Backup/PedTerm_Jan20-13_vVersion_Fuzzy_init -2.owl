        <ace_lexicon:CN_pl>Respiratory_Failures</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Suy_kiet_phoi_cap_tinh -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Suy_kiet_phoi_cap_tinh">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Suy_kiet_phoi"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_PT rdf:datatype="&xsd;string">Acute Respiratory Failure</NCI_PT>
        <ID rdf:datatype="&xsd;string">C27043</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Life-threatening respiratory failure that develops rapidly. Causes include injury, sepsis, drug overdose, and pancreatitis. It manifests with dyspnea and cyanosis and may lead to cardiovascular shock.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Acute_Respiratory_Failures</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Acute_Respiratory_Failure</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Suy_kiet_phoi_do_roi_loan_CNS -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Suy_kiet_phoi_do_roi_loan_CNS">
