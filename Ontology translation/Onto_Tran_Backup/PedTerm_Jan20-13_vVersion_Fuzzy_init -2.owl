        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A white cheese-like protective material that covers the skin of a fetus.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34328</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Pregnancy and Childbirth Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Vernix Caseosa</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vernix_Caseosas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vernix_Caseosa</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vi_Capsular_Polysaccharide_Typhoid_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vi_Capsular_Polysaccharide_Typhoid_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Polysaccharide_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A live attenuated injectable virus vaccine used to prevent typhoid, which is caused by Salmonella typhi.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C97127</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Vi Capsular Polysaccharide Typhoid Vaccine</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vi_Capsular_Polysaccharide_Typhoid_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vi_Capsular_Polysaccharide_Typhoid_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Viem_phoi -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Viem_phoi">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Roi_loan_phoi"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">An acute, acute and chronic, or chronic inflammation focally or diffusely affecting the lung parenchyma, due to infections (viruses, fungi, mycoplasma, or bacteria), treatment (e.g. radiation), or exposure (inhalation) to chemicals. Symptoms include cough, shortness of breath, fevers, chills, chest pain, headache, sweating, and weakness.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C3333</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Pneumonia</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Pneumonia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Pneumonias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_K -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Vitamin_K">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Substance"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C943</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">The term &quot;vitamin K&quot; refers to a group of chemically similar fat-soluble compounds called naphthoquinones: vitamin K1 (phytonadione) is found in plants and is the primary source of vitamin K for humans through dietary consumption, vitamin K2 compounds (menaquinones) are made by bacteria in the human gut, and vitamin K3 (menadione) is a water-soluble preparation available for adults only. Vitamin K is necessary for the liver to produce the coagulation factors II, VII, IX, and X, as well as the clotting factors protein C, protein S, and protein Z; vitamin K deficiency can result in deficiencies of these coagulation factors and excess bleeding. An injection of vitamin K is routinely given to newborn infants to prevent vitamin K deficiency bleeding, also known as hemorrhagic disease of the newborn. Vitamin K deficiency is rare in adults but may result from chronic malnutrition or an inability to absorb dietary vitamins.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Vitamin K</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Vitamin_Ks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Vitamin_K</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Web_Thanh_quan -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Web_Thanh_quan">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Tim_benh_ho_hap"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C98970</ID>
        <NCI_PT rdf:datatype="&xsd;string">Laryngeal Web</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">Tissue that develops between the vocal cords.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Laryngeal_Webs</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Laryngeal_Web</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Web_khi_quan -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Web_khi_quan">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Roi_loan_khi_quan"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A rare congenital or acquired abnormality characterized by the presence of a web-like thin layer of tissue that narrows the lumen of the trachea. It may result in wheezing, dyspnea, and respiratory failure.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C98629</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Tracheal Web</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Tracheal_Web</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Tracheal_Webs</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A bluish or purplish discoloration of the skin and mucous membranes resulting from a reduced amount of oxygenated hemoglobin in the blood.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C26737</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cyanosis</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Cyanosis</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Cyanoses</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim_chi -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim_chi">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">Blue- or purplish-colored limbs; this is caused by excessive amounts of deoxygenated hemoglobin in the skin vessels of the limbs.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C87066</ID>
        <NCI_PT rdf:datatype="&xsd;string">Cyanotic Limbs</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Cyanotic_Limbses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Cyanotic_Limbs</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim_chu_sinh -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Xanh_tim_chu_sinh">
