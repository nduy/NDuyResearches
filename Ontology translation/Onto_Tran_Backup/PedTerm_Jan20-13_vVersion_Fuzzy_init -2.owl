    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tang_bilirubin_mau -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tang_bilirubin_mau">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <NCI_Definition rdf:datatype="&xsd;string">Abnormally high level of bilirubin in the blood. Excess bilirubin is associated with jaundice.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C27088</ID>
        <NCI_PT rdf:datatype="&xsd;string">Elevated Bilirubin</NCI_PT>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <SYN rdf:datatype="&xsd;string">Physiological Hyperbilirubinemia</SYN>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hyperbilirubinemia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hyperbilirubinemias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tang_than_nhiet -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tang_than_nhiet">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition that manifests with abnormally high body temperature. In hyperthermic state, the hypothalamic set-point is normal but body temperature increases and overrides the ability to lose heat, resulting from exogenous heat exposure or endogenous heat production, e.g. in heat stroke, malignant hyperthermia, endocrine hyperthermia, or neuroleptic malignant syndrome. The concept does not refer to hyperpyrexia, the state when the hypothalamic set-point is reset at a higher temperature and is physiologically regulated.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C50589</ID>
        <NCI_PT rdf:datatype="&xsd;string">Hyperthermia</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Hyperthermia</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Hyperthermias</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tang_truong_luc_co -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tang_truong_luc_co">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C79750</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Increased involuntary muscle tone caused by central nervous system disorders that affect the regions interfering with voluntary movement. It results in gait, movement, and speech disturbances. Representative examples of disorders causing spasticity include brain or spinal cord injury, and multiple sclerosis.</NCI_Definition>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Spasticity</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Increased_Muscle_Tone</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Increased_Muscle_Tones</ace_lexicon:CN_pl>
    </owl:Class>
    


