    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Kem_an -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Kem_an">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C87111</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_Definition rdf:datatype="&xsd;string">Occurs either when an infant shows no interest in feeding or when there is an inability to take in adequate nutrition. Poor feeding is a nonspecific symptom of many disorders, including neurological, genetic, structural, metabolic, and infectious diseases.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Poor Feeding</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Poor_Feeding</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Poor_Feedings</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Khoang_mieng -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Khoang_mieng">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Phan_co_the"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C12421</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Oral Cavity</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The cavity located at the upper end of the alimentary canal, behind the teeth and gums that is bounded on the outside by the lips, above by the hard and soft palates and below by the tongue.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Oral_Cavities</ace_lexicon:CN_pl>
