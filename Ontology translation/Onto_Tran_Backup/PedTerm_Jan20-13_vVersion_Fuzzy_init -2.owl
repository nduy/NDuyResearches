        <NCI_Definition rdf:datatype="&xsd;string">Any part of an organism.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Body Part</NCI_PT>
        <SYN rdf:datatype="&xsd;string">Body_Structure</SYN>
        <ID rdf:datatype="&xsd;string">C32221</ID>
