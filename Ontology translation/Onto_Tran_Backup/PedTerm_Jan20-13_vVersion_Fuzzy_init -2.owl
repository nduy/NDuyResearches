    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tieu_chay -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tieu_chay">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Phu"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A condition of frequent and watery bowel movements.</NCI_Definition>
        <NCI_Definition rdf:datatype="&xsd;string">A condition that is characterized by the presence of generalized edema. Causes include congestive heart failure, liver failure, renal failure, and severe malnutrition.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Anasarca</NCI_PT>
        <ID rdf:datatype="&xsd;string">C2987</ID>
        <ID rdf:datatype="&xsd;string">C98811</ID>
        <NCI_PT rdf:datatype="&xsd;string">Diarrhea</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Anasarcas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Diarrhea</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Diarrheas</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Anasarca</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Tieu_toe_nuoc -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Tieu_toe_nuoc">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <ID rdf:datatype="&xsd;string">C87128</ID>
        <NCI_Definition rdf:datatype="&xsd;string">Frequent, loose, and watery stools are noted in most infants, even if they are fed formula, until they are six to eight weeks old; after that, the stools become firmer and less frequent.</NCI_Definition>
        <SYN rdf:datatype="&xsd;string">Liquid_Stool</SYN>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_PT rdf:datatype="&xsd;string">Watery Stool</NCI_PT>
