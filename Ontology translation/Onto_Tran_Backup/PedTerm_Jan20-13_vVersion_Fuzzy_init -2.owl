        <ace_lexicon:CN_sg>Female</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Females</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Oral_Polio_Vaccine -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Oral_Polio_Vaccine">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Attenuated_Live_Virus_Vaccine"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A vaccine that contains live attenuated polio virus. It is administered orally as polio prophylaxis in many areas of the world, but not in the U.S. since 2000.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C96401</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Childhood Immunization Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Oral Polio Vaccine</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Oral_Polio_Vaccine</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Oral_Polio_Vaccines</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Ounce -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Ounce">
