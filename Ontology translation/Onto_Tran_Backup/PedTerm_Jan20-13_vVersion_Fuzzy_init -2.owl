        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A measure of the average kinetic energy of a system of particles. Temperature may be quantified, in the context of thermodynamics, as the potential of one system to transfer thermal energy to another system until both systems reach a state of thermal equilibrium.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C25206</ID>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
