        <ace_lexicon:CN_pl>Demographicses</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Demographics</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Nhiet_do -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Nhiet_do">
