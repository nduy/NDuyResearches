</Subset_Association1>
        <NCI_PT rdf:datatype="&xsd;string">Rotavirus Vaccine</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Rotavirus_Vaccines</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Rotavirus_Vaccine</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Run -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Run">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <ID rdf:datatype="&xsd;string">C38038</ID>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <Subset_Association2 rdf:datatype="&xsd;string">Neonatal Research Network Terminology</Subset_Association2>
        <NCI_Definition rdf:datatype="&xsd;string">The shaking movement of the whole body or just a certain part of it, often caused by problems of the neurons responsible for muscle action.</NCI_Definition>
        <NCI_PT rdf:datatype="&xsd;string">Tremor</NCI_PT>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_sg>Tremor</ace_lexicon:CN_sg>
        <ace_lexicon:CN_pl>Tremors</ace_lexicon:CN_pl>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Rung_giat_co -->

    <owl:Class rdf:about="http://www.owl-ontologies.com/Ontology1358660052.owl#Rung_giat_co">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/Ontology1358660052.owl#Dau_hieu_hoac_trieu_chung"/>
        <SYN rdf:datatype="&xsd;string"></SYN>
        <NCI_Definition rdf:datatype="&xsd;string">A sudden, involuntary contraction of a muscle or group of muscles; these movements may develop as a symptom of a number of neurological diseases including epilepsy, Parkinson&apos;s disease, Alzheimer&apos;s disease, or Creutzfeldt-Jacob disease.</NCI_Definition>
        <ID rdf:datatype="&xsd;string">C34832</ID>
        <NCI_PT rdf:datatype="&xsd;string">Myoclonic Jerk</NCI_PT>
        <Subset_Association2 rdf:datatype="&xsd;string">NICHD Newborn Screening Terminology</Subset_Association2>
        <Subset_Association1 rdf:datatype="&xsd;string">NICHD Pediatric Terminology
</Subset_Association1>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Myoclonic_Jerks</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>Myoclonic_Jerk</ace_lexicon:CN_sg>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/Ontology1358660052.owl#Sac_duong_ho_hap -->

