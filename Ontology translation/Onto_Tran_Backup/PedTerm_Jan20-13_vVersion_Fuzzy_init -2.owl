        <NCI_PT rdf:datatype="&xsd;string">Submitting Facility</NCI_PT>
        <NCI_Definition rdf:datatype="&xsd;string">The hospital or medical institution that is submitting data or information.</NCI_Definition>
        <NICHD_Definition rdf:datatype="&xsd;string">_</NICHD_Definition>
        <ace_lexicon:CN_pl>Submitting_Facilities</ace_lexicon:CN_pl>
